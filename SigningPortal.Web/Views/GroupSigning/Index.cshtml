<div class="container-fluid p-4" style="background:#F6F7FB; min-height:100vh;">

    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between">
        <div class="title">

            Group Signing Transactions
        </div>
    </div>

    <p class="subtitle">Sign multiple documents in a single, streamlined transaction.</p>


    <!-- Search Box -->
    <div class="bg-white border mb-4 rounded-3 shadow-sm groupsigning-search-card d-none">
        <div class="groupsigning-search rounded-3">
            <i class="fa fa-search"></i>
            <input type="text" id="templateSearch" placeholder="Search …" />
        </div>
    </div>
    <!-- No Data Message -->
    <div id="noDataMessageDraft" style="display:none;">
        <div class="text-center py-5"
             style="border-radius: 12px; background:#f9fafb; margin-top:20px;">

            <!-- Icon Circle -->
            <div style="
            width:80px;
            height:80px;
            margin:0 auto 20px auto;
            background:#eef1f5;
            border-radius:50%;
            display:flex;
            align-items:center;
            justify-content:center;
        ">
                <i class="fa-regular fa-file-lines"
                   style="font-size:32px; color:#6b7280;"></i>
            </div>

            <!-- Main Title -->
            <h4 style="font-weight:600; color:#1f2937; margin-bottom:8px;">
                No documents found
            </h4>

            <!-- Subtitle -->
            <p style="color:#6b7280; font-size:15px; margin:0;">
                Upload your first document to get your first sign
            </p>

        </div>
    </div>

    <div class="bg-white border rounded-3 mb-4 shadow-sm groupsigning-search-card" id="cardslist">
        <div id="cardWrapper"></div>

        <div class="text-end mt-3">
            <button id="showMoreBtn" class="btn btn-outline-primary d-none">Show More</button>
            <button id="showLessBtn" class="btn btn-outline-secondary d-none">Show Less</button>
        </div>

    </div>


</div>
@section scripts {

    <script>

        var DocumentsSigningStatus = '@Url.Action("DocumentsSigningStatus", "GroupSigning")';
        var GetGroupSigningListUrl = '@Url.Action("GetGroupSigningList", "GroupSigning")';
        var groupsigninglist = [];
        var filteredGroupSignings=[];
        var index = 0;
        var index_val = 0;
        const INITIAL_VISIBLE_COUNT = 4;
        let isExpanded = false;
        $(document).ready(function () {
            getgroupsigninglist();

        });

        function getgroupsigninglist() {

            showShimmer(5); // 👈 show shimmer immediately

            $.ajax({
                url: GetGroupSigningListUrl, // ✅ correct API
                type: "GET",
                success: function (response) {
                    console.log(response);
                    if (!response.success) {
                        console.error(response.message);
                        return;
                    }
                    if (response.result.groupSigninglist.length < 1) {
                        document.getElementById("noDataMessageDraft").style.display = "block";
                        document.getElementById("cardslist").style.display = "none";
                        return;
                    }
                    document.getElementById("noDataMessageDraft").style.display = "none";
                    document.getElementById("cardslist").style.display = "block";
                    groupsigninglist = response.result.groupSigninglist || [];
                    renderDelegationCards();
                    updateTimestamps_forGroupSIgning();

                },
                error: ajaxErrorHandler
            });

        }
        function renderDelegationCards() {
            const wrapper = $("#cardWrapper");
            wrapper.empty();

            const dataToRender = isExpanded
                ? groupsigninglist
                : groupsigninglist.slice(0, INITIAL_VISIBLE_COUNT);

            generateGroupSigningCards(dataToRender);
        }

        $(document).on("click", ".action-btn", function (e) {
            e.stopPropagation();

            // Close other open dropdowns
            $(".dropdown-menu").not($(this).next()).removeClass("show");

            // Toggle current dropdown
            $(this).next(".dropdown-menu").toggleClass("show");
        });

        // Close dropdown when clicking outside
        $(document).on("click", function () {
            $(".dropdown-menu").removeClass("show");
        });
        function generateGroupSigningCards(groupList) {

            const wrapper = document.getElementById("cardWrapper");
            wrapper.innerHTML = "";
              if (!groupList || groupList.length === 0) {
        $("#cardWrapper").hide();
        $("#noDataMessageDraft").show();
        return;
    } else {
        $("#noDataMessageDraft").hide();
        $("#cardWrapper").show();
    }
            groupList.forEach(group => {

                const groupName = group.transaction || "-";
                var starttime = group.createdAt || "-";
                const totalcount = group.totalFileCount || "-";
                const successcount = group.successFileCount || "0";
                const failcount = group.failedFileCount || "0";
                const statusText = group.status || "-";
                if (statusText === "Completed") {
                    if (successcount == group.signingGroups.length) {
                        statusClass = "dg-status completed";
                        statushtml = `
                                                <span class="${statusClass}">
                                                            ${statusText}
                                </span>`;
                    }
                    else if (failcount === group.signingGroups.length) {
                        statusClass = "dg-status Cancelled";
                        statushtml = `
                                                <span class="${statusClass}">
                                                            ${statusText}
                                </span>`;
                    }
                    else {
                        statusClass = "dg-status partiallydone";
                        statushtml = `
                                                <span class="${statusClass}">
                                                           Partially done
                                </span>`;
                    }


                }
                else if (statusText === "In Progress") {
                    statusClass = "dg-status in-progress";
                    statushtml = `
                                                <span class="${statusClass}">
                                                           ${statusText}
                                                </span>`;
                }

                const card = document.createElement("div");
                card.className = "dg-card shadow-sm onhoverclass";
                var buttonsHtml = `
                                                                <div class="action-dropdown">
                                                                    <button class="action-btn rounded-3">Actions ▾</button>
                                                                    <div class="dropdown-menu">
                                                                                <button class="dropdown-item" onclick="handleDocumentsSigningStatus('${group._id}')">
                                                                             <i class='fa-regular fa-eye'></i>&nbsp;View
                                                                        </button>
                                                                    </div>
                                                                </div>
                                                            `;
                card.innerHTML = `
                                                <div class="dg-top">

                                                    <div class="dg-user">
                                                                 <img src="/img/icon/groupsigning_list_icon.png" style="width:2rem;" />
                                                        <div>
                                                         <div class="dg-col start-date">
                                                              <div class="dg-label-starttime">Start Date & Time</div>
                                                                            <div class="dg-value convert-time" style="text-align: left;" data-timestamp="${group.createdAt}">
                                                                      ${group.createdAt}
                                                                   </div>
                                                              </div>
                                                        </div>
                                                    </div>

                                                    <div class="dg-col">
                                                        <div class="dg-label">Total</div>
                                                                <div class="dg-value">${totalcount}</div>
                                                    </div>
                                                            <div class="dg-col">
                                                                <div class="dg-label">Signed</div>
                                                                        <div class="dg-value">${successcount}</div>
                                                            </div>
                                                                      <div class="dg-col">
                                                                        <div class="dg-label">Failed</div>
                                                                                <div class="dg-value">${failcount}</div>
                                                                    </div>

                                                    <div class="dg-col status-col" style="text-align:center;">
                                                        <div class="dg-label">Status</div>
                                                                ${statushtml}
                                                    </div>

                                                    ${buttonsHtml}

                                                </div>
                                            `;

                wrapper.appendChild(card);

            });
        }
        $("#templateSearch").on("input", function () {

    const searchText = $(this).val().toLowerCase().trim();

    if (!searchText) {
        filteredGroupSignings = [...allGroupSignings];
    } else {
        filteredGroupSignings = allGroupSignings.filter(group => {
            return (
                (group.transaction || "").toLowerCase().includes(searchText) ||
                (group.status || "").toLowerCase().includes(searchText)
            );
        });
    }

    generateGroupSigningCards(filteredGroupSignings);
});

        function handleDocumentsSigningStatus(groupId) {

            document.getElementById("navigationNetworkOverlay").style.display = "block";
            window.location.href = DocumentsSigningStatus + `?groupId=${groupId}`;
        }
        function convertToLocalTime(serverTime) {
            // Parse the server-sent time (with offset) into a Date object
            const date = new Date(serverTime);

            // Convert to user's local time
            const localTime = date.toLocaleString("en-US", { timeZone: Intl.DateTimeFormat().resolvedOptions().timeZone });

            return localTime;
        }
        function formatDateToDDMMYYYYtimewithoutseconds(dateString) {
            if (!dateString) return "";

            const date = new Date(dateString);
            const day = String(date.getDate()).padStart(2, "0");
            const month = String(date.getMonth() + 1).padStart(2, "0"); // Months are 0-based
            const year = date.getFullYear();

            let hours = date.getHours();
            const minutes = String(date.getMinutes()).padStart(2, "0");
            const seconds = String(date.getSeconds()).padStart(2, "0");

            const ampm = hours >= 12 ? "PM" : "AM";
            hours = hours % 12;
            hours = hours ? hours : 12; // Convert '0' to '12'
            const formattedHours = String(hours).padStart(2, "0");

            return `${day}/${month}/${year} ${formattedHours}:${minutes} ${ampm}`;
        }
        function updateTimestamps_forGroupSIgning() {
            document.querySelectorAll(".convert-time").forEach(function (element) {
                const serverTime = element.getAttribute("data-timestamp");
                if (serverTime) {
                    const localTime = convertToLocalTime(serverTime);
                    element.textContent = formatDateToDDMMYYYYtimewithoutseconds(localTime);

                }
            });

        }
        function updateShowMoreButtons() {
            console.log("Total delegations:", allDelegations.length);

            if (allDelegations.length <= INITIAL_VISIBLE_COUNT) {
                $("#showMoreBtn, #showLessBtn").addClass("d-none");
                return;
            }

            if (isExpanded) {
                $("#showMoreBtn").addClass("d-none");
                $("#showLessBtn").removeClass("d-none");
            } else {
                $("#showMoreBtn").removeClass("d-none");
                $("#showLessBtn").addClass("d-none");
            }
        }

        function showShimmer(count = 4) {
            const wrapper = document.getElementById("cardWrapper");
            wrapper.innerHTML = "";

            for (let i = 0; i < count; i++) {
                const shimmerCard = document.createElement("div");
                shimmerCard.className = "dg-card shimmer-card shadow-sm";

                shimmerCard.innerHTML = `
                                            <div class="dg-top">

                                                <div class="dg-user">
                                                    <div class="shimmer shimmer-avatar"></div>
                                                    <div>
                                                        <div class="shimmer shimmer-line md"></div>
                                                        <div class="shimmer shimmer-line sm"></div>
                                                    </div>
                                                </div>

                                                <div class="dg-col shimmer-col">
                                                    <div class="shimmer shimmer-line sm"></div>
                                                    <div class="shimmer shimmer-line md"></div>
                                                </div>

                                                <div class="dg-col shimmer-col">
                                                    <div class="shimmer shimmer-line sm"></div>
                                                    <div class="shimmer shimmer-line md"></div>
                                                </div>

                                                <div class="dg-col shimmer-col">
                                                    <div class="shimmer shimmer-line sm"></div>
                                                    <div class="shimmer shimmer-line sm"></div>
                                                </div>

                                            </div>
                                        `;

                wrapper.appendChild(shimmerCard);
            }
        }

        $("#showMoreBtn").on("click", function () {
            isExpanded = true;
            renderDelegationCards();
            updateShowMoreButtons();
            updateTimestamps_statuspage();
        });

        $("#showLessBtn").on("click", function () {
            isExpanded = false;
            renderDelegationCards();
            updateShowMoreButtons();
            updateTimestamps_statuspage();

            // Optional: scroll back to top of cards
            $('html, body').animate({
                scrollTop: $("#cardWrapper").offset().top - 100
            }, 400);
        });
        function cropFileNames(full, type) {

            // Adjust crop lengths based on screen width
            let start, end;
            if (type === "name") {
                const width = window.innerWidth;

                if (width >= 1300) {
                    start = 9;
                    end = 9;
                } else if (width >= 768) {
                    start = 7;
                    end = 7;
                }
                else if (width >= 460) {
                    start = 12;
                    end = 12;
                }
                else { // Small screens (mobiles)
                    start = 10;
                    end = 10;
                }

                if (full && full.length > start + end) {
                    return full.slice(0, start) + '...' + full.slice(-end);
                } else {
                    return full
                }
            } else {
                const width = window.innerWidth;

                if (width >= 1300) {
                    start = 15;
                    end = 15;
                } else if (width >= 768) {
                    start = 12;
                    end = 12;
                }
                else if (width >= 460) {
                    start = 13;
                    end = 13;
                }
                else { // Small screens (mobiles)
                    start = 10;
                    end = 10;
                }

                if (full && full.length > start + end) {
                    return full.slice(0, start) + '...' + full.slice(-end);
                } else {
                    return full
                }
            }

        }

    </script>
