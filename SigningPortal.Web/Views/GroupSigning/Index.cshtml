        color: #2563eb;
    }

    .partiallydone {
        background: #eff6ff;
        color: #2563eb;
    }

    /* action */
    .dg-action-btn {
        border: 1px solid #86d6b6;
        background: #ffffff;
        color: #0f766e;
        padding: 8px 14px;
        border-radius: 10px;
        font-size: 13px;
        cursor: pointer;
    }

        .dg-action-btn:hover {
            background: #0f766e;
