        }
        /* Status stays below label */
        .dg-status {
            margin-top: 4px;
            align-self: flex-start;
        }
        /* Actions full width */
        .action-dropdown {
            width: 100%;
        }

        .action-btn {
            width: 100%;
            text-align: center;
        }
    }

    @@media (min-width: 577px) and (max-width: 992px) {
        /* Allow wrapping */
        .dg-top {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            align-items: start;
        }
