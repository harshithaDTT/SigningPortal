        background: #e7f8ef;
        color: #16a34a;
        font-size: 13px;
        padding: 3px 10px;
        border-radius: 999px;
        font-weight: 500;
    }

        .dg-status.cancelled {
            background: #ffeaea;
            color: #cc0000;
        }

    .cancelled {
        background: #ffeaea;
        color: #cc0000;
    }

    .completed {
        background: #d1f4e0;
        color: #198754;
    }

    .dg-status.completed {
