        }

    .dropdown-menu {
        display: none;
    }

        .dropdown-menu.show {
            display: block;
        }
    /* ---------- SHIMMER BASE ---------- */
    .shimmer {
        position: relative;
        overflow: hidden;
        background: #f0f0f0;
        border-radius: 6px;
    }

        .shimmer::after {
            content: "";
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient( 90deg, transparent, rgba(255, 255, 255, 0.6), transparent );
            animation: shimmer 1.4s infinite;
        }

    /* ---------- SHIMMER CARD ---------- */
    .dg-card.shimmer-card {
        padding: 16px;
        margin-bottom: 16px;
    }

    .shimmer-avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
    }

    .shimmer-line {
        height: 12px;
        margin-top: 8px;
        border-radius: 4px;
    }

        .shimmer-line.sm {
            width: 80px;
        }

        .shimmer-line.md {
            width: 140px;
        }

        .shimmer-line.lg {
            width: 200px;
        }

    .shimmer-col {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .dg-top {
        flex-wrap: wrap;
