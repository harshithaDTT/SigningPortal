    @@media (max-width: 576px) {
        /* Stack card content vertically */
        .dg-top {
            flex-direction: column;
            align-items: flex-start;
            gap: 14px;
        }
        /* User section full width */
        .dg-user {
            width: 100%;
            min-width: unset;
        }
        /* Each column becomes vertical */
        .dg-col {
            width: 100%;
            min-width: unset;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
        }
        /* Label above value */
        .dg-label {
            font-size: 12px;
            font-weight: 500;
            color: #6b7280;
            margin-bottom: 2px;
        }

        .dg-value {
            font-size: 14px;
            font-weight: 600;
            color: #111827;
