            box-shadow: 0 3px 12px rgba(0, 0, 0, 0.2) !important;
        }

    /* top row */
    .dg-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
    }

    /* user */
    .dg-user {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 260px;
    }

    .dg-avatar {
        width: 40px;
        height: 40px;
        background-color: #009057 !important;
        border: 1px solid #009057;
        color: #fff;
        font-weight: 600;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .dg-name {
        font-size: 15px;
        font-weight: 600;
        color: #111827;
    }

    .dg-email {
