        cursor: pointer;
        padding: 2px 6px;
        border-radius: 50%;
    }

    
    .image-container:hover .remove-image-btn.uploaded {
        display: block;
    }

    .container {
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .qwer {
        display: flex;
        justify-content: space-between;
        
    }


    .step-label {
        position: absolute;
        
        width: 100px; /* Set the width based on your design */
        text-align: center;
        white-space: nowrap; /* Prevent text from wrapping */
        font-size: 15px;
    }

    .container .steps {
        display: flex;
        width: 76%;
        align-items: center;
        justify-content: space-between;
        position: relative;
        margin: 8px 30px;
    }

    .steps .circle {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 44px;
        width: 44px;
        color: #999;
        background: #e0e0e0;
        /* border-radius: 50%; */
        border: 3px solid #e0e0e0;
        z-index: 1;
        transition: all 300ms ease;
        overflow: hidden;
    }

        .steps .circle img {
            height: 56%;
            width: 47%;
        }

        .steps .circle.active {
            border-color: #acc43d;
            color: #4070f4;
            background-color: #acc43d;
        }


    .steps .progress-bar {
        position: absolute;
        top: 50%;
        left: 3%;
        transform: translateY(-50%);
        height: 3px;
        width: 94%;
        background: #e0e0e0;
        z-index: 0;
    }

    .progress-bar .indicator {
        position: absolute;
        height: 100%;
        width: 0%;
        background: #4070f4;
        transition: all 300ms ease;
    }

    .backImage {
        background-image: url('../img/dashboardBg.png');
        background-repeat: no-repeat;
        background-size: cover;
        background-position: 50%;
        
        background-color: rgba(255, 255, 255, 1);
    }

    .col-md-8, .col-md-4 {
        transition: all 0.5s ease-in-out;
    }

    .loader {
    border: 8px solid #f3f3f3;
    border-top: 8px solid #3498db;
    border-radius: 50%;
    width: 50px;
    height: 50px;
    animation: spin 1s linear infinite;
    position: absolute;
    top: 43%;
    left: 47%;
    transform: translate(-50%, -50%);
}

    @@keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    /* ===== RESPONSIVE STYLES ===== */
    @@media (max-width: 992px) {
        .col-md-8, .col-md-4 {
            width: 100%;
            max-width: 100%;
        }

        .row.backImage {
            flex-direction: column;
        }
    }

    @@media (max-width: 768px) {
        .card-body {
            padding: 0.5rem !important;
        }

        .progress-line {
            height: 2px;
        }

        .loader {
            width: 40px;
            height: 40px;
            border-width: 6px;
        }

        h4, h5 {
            font-size: 1rem;
        }

        .btn {
            padding: 0.5rem 0.75rem;
            font-size: 0.85rem;
        }
    }

    @@media (max-width: 576px) {
        .loader {
            width: 32px;
            height: 32px;
            border-width: 4px;
            left: 45%;
        }

        h4, h5 {
            font-size: 0.9rem;
        }

        .btn {
            padding: 0.4rem 0.6rem;
            font-size: 0.8rem;
        }

        .card-body {
            padding: 0.25rem !important;
        }
    }


