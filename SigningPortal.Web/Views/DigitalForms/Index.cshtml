@section scripts {

    <script>
            var myDigitalformsUrl="@Url.Action("myforms", "DigitalForms")";
            var GetDelegationbyorgidsuidUrl="@Url.Action("GetDelegationbyorgidsuid", "Documents")";
            var currentviewName='@ViewBag.ViewName';
        var sentFormsPartialUrl="@Url.Action("sent", "FormRequests")";
        var receivedFormsPartialUrl="@Url.Action("recived", "FormRequests")";
        var referredFormsPartialUrl="@Url.Action("reffered", "FormRequests")";

            var isFileUploaded = false;
            var PerpareDocumentContext = {

                filesizerestrict: @ViewBag.FileSizeLimit * 1024 * 1024,
                filesize: "@ViewBag.FileSizeLimit.ToString("0")",
            }

        // Bootstrap 5 Modal Initialization for DocType_Modal
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize modal instances using Bootstrap 5 API
            var docTypeModalEl = document.getElementById('DocType_Modal');
            var docTypeModal = docTypeModalEl ? new bootstrap.Modal(docTypeModalEl) : null;

            var digitalFormModalEl = document.getElementById('digitalFormModal');
            var digitalFormModal = digitalFormModalEl ? new bootstrap.Modal(digitalFormModalEl) : null;

            var digitalShowModalEl = document.getElementById('digitalShowModal');
            var digitalShowModal = digitalShowModalEl ? new bootstrap.Modal(digitalShowModalEl) : null;

            var sendFormModalEl = document.getElementById('sendFormModal');
            var sendFormModal = sendFormModalEl ? new bootstrap.Modal(sendFormModalEl) : null;

            // Handle createform button click to show DocType_Modal
            var createFormBtn = document.getElementById('createform');
            if (createFormBtn && docTypeModal) {
                createFormBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    docTypeModal.show();
                });
            }

            // Handle Cancel button to close DocType_Modal
            var cancelBtn = document.getElementById('CancelButton');
            if (cancelBtn && docTypeModal) {
                cancelBtn.addEventListener('click', function() {
                    docTypeModal.hide();
                });
            }

            // Expose modals globally for external JS compatibility
            window.docTypeModal = docTypeModal;
            window.digitalFormModal = digitalFormModal;
            window.digitalShowModal = digitalShowModal;
            window.sendFormModal = sendFormModal;

            // Legacy jQuery compatibility wrappers for external JS files
            if (typeof jQuery !== 'undefined') {
                jQuery.fn.modal = function(action) {
                    var el = this[0];
                    if (!el) return this;

                    var modalId = el.id;
                    var modalInstance = window[modalId.replace('_', '')] ||
                                        window[modalId.charAt(0).toLowerCase() + modalId.slice(1)] ||
                                        bootstrap.Modal.getInstance(el) ||
                                        new bootstrap.Modal(el);

                    if (action === 'show') {
                        modalInstance.show();
                    } else if (action === 'hide') {
                        modalInstance.hide();
                    } else if (action === 'toggle') {
                        modalInstance.toggle();
                    }
                    return this;
                };
            }

            // ─── Centralized Global Search ───────────────────────
            var globalSearchInput = document.getElementById('df-global-search');
            var globalSearchClear = document.getElementById('df-global-search-clear');

            function dispatchGlobalSearch() {
                var activeTabEl = document.querySelector('.df-tab.active');
                var tab = activeTabEl ? activeTabEl.getAttribute('data-tab') : '';
                if (tab === 'myTemplates' && typeof window.handleMyFormsSearch === 'function') {
                    window.handleMyFormsSearch();
                } else if (tab === 'sent' && typeof window.handleSentFormsSearch === 'function') {
                    window.handleSentFormsSearch();
                } else if (tab === 'received' && typeof window.handleReceivedFormsSearch === 'function') {
                    window.handleReceivedFormsSearch();
                } else if (tab === 'referred' && typeof window.handleRefferedFormsSearch === 'function') {
                    window.handleRefferedFormsSearch();
                }
            }

            if (globalSearchInput) {
                globalSearchInput.addEventListener('input', function () {
                    // Show/hide clear button
                    if (globalSearchClear) {
                        globalSearchClear.style.display = this.value.length > 0 ? 'flex' : 'none';
                    }
                    dispatchGlobalSearch();
                });

                globalSearchInput.addEventListener('keypress', function (e) {
                    if (e.key === 'Enter') { e.preventDefault(); dispatchGlobalSearch(); }
                });
            }

            if (globalSearchClear) {
                globalSearchClear.addEventListener('click', function () {
                    if (globalSearchInput) { globalSearchInput.value = ''; }
                    this.style.display = 'none';
                    dispatchGlobalSearch();
                });
            }
            // ─────────────────────────────────────────────────────
        });


    </script>

    @if (Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Development")
    {
        <script src="~/js/DigitalForms/Index.js" type="text/javascript" asp-append-version="true" defer></script>
    }
    else
    {
        <script src="~/dist/DigitalForms/Index.min.js" type="text/javascript" asp-append-version="true" defer></script>
    }


}

