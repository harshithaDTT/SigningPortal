@model List<SigningPortal.Web.ViewModels.DigitalForms.FormTemplateResponse>;

@using System.Security.Claims;
@using Newtonsoft.Json;

@{
    var Suid = User.FindFirst(ClaimTypes.UserData).Value;
    var userEmail = User.FindFirst(ClaimTypes.Email).Value;
}

<style>
    /* ============================================
           Card-Based Forms UI - EXACT match to _myforms.cshtml
           ============================================ */

    .hidden {
        display: none !important;
    }

    /* Search Bar - EXACT match to _myforms.cshtml */
    .search-bar {
        display: flex;
        align-items: center;
        width: 100%;
        background: #f9fafb;
        border: 0.0625rem solid #e2e8f0;
        box-shadow: 0 0.0625rem 0.25rem rgba(0,0,0,0.08);
        transition: all 0.2s ease-in-out;
        border-radius: 0.5rem;
    }

        .search-bar:hover {
            box-shadow: 0 0.125rem 0.5rem rgba(0,0,0,0.12);
        }

    .search-input {
        flex: 1;
        border: none;
        padding: 0.375rem 1.25rem;
        font-size: 0.875rem;
        outline: none;
        background: transparent;
    }

    .search-button {
        border: none;
        background: transparent;
        color: #4a5568;
        font-size: 0.9375rem;
        padding: 0.375rem 0.875rem;
        cursor: pointer;
    }

        .search-button:hover {
            background: rgba(0,0,0,0.08);
        }

    /* DOCUMENT CARD CONTAINER - EXACT match to _myforms.cshtml */
    .document-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 18px 22px;
        background: #ffffff;
        border-radius: 12px;
        border: 1px solid #e0dfdf;
        margin-bottom: 16px;
        transition: box-shadow .2s ease;
        box-shadow: 0 4px 9px rgba(25, 135, 84, 0.2);
    }

        .document-card:hover {
            box-shadow: 0 3px 12px rgba(0, 0, 0, 0.2) !important;
        }

        .document-card.search-hidden {
            display: none !important;
        }

    /* Right side container for status blocks and actions */
    .doc-right {
        display: flex;
        gap: 24px;
        flex: 0 1 40%;
        justify-content: space-between;
    }

    /* LEFT SIDE : ICON + FILE INFO - EXACT match to _myforms.cshtml */
    .doc-left {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .doc-icon-wrapper {
        width: 2.5rem;
        height: 2.5rem;
        background: linear-gradient(135deg, #0A1F44 0%, #059669 100%);
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .doc-icon-wrapper i {
            font-size: 1.25rem;
            color: #ffffff;
        }

        .doc-icon-wrapper img {
            width: 28px;
            height: 28px;
        }

    .doc-title {
        font-size: 18px;
        font-weight: 600;
        color: #1e293b;
        margin: 0;
    }

    /* Created / Expires Line */
    .doc-meta {
        margin: 4px 0 0;
        font-family: sans-serif;
        font-weight: 500;
        font-size: 14px;
        color: #919aa3 !important;
    }

    /* MIDDLE STATUS BLOCK - EXACT match to _myforms.cshtml */
    .doc-status-block {
        text-align: left;
        min-width: 180px;
    }

    .doc-status-heading {
        text-transform: uppercase;
        font-weight: 600;
        margin-bottom: 3px;
        font-family: 'Arial', sans-serif;
        font-size: 12px;
        color: #6c757d;
        letter-spacing: 0.5px;
    }

    .doc-status-text {
        font-size: 15px;
        font-weight: 600;
    }

    /* Status colors matching _myforms.cshtml */
    .status-published {
        color: #4caf50;
    }

    .status-unpublished {
        color: #64748B;
    }

    .status-draft {
        color: #ffa726;
    }

    /* Reusable pill styles for Status & Document Name */
    .pill {
        display: inline-flex;
        align-items: center;
        padding: 0.375rem 0.875rem;
        border-radius: 6px;
        font-size: 0.8125rem;
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 220px;
    }

    .pill-neutral {
        background: #f3f4f6;
        border: 1px solid #e5e7eb;
        color: #1f2937;
    }

    .status-new {
        color: #1d4ed8;
        border-radius: 6px;
        font-size: 0.8125rem;
        font-weight: 600;
    }

    .status-completed {
        color: #047857;
        font-size: 0.8125rem;
        font-weight: 600;
    }

    .status-inprogress {
        color: #b45309;
        font-size: 0.8125rem;
        font-weight: 600;
    }

    .status-other {
        color: #64748b;
        font-size: 0.8125rem;
        font-weight: 600;
    }

    .doc-name-pill {
        max-width: 200px;
        display: inline-flex;
        align-items: center;
        color: #1f2937;
        font-size: 0.8125rem;
        font-weight: 600;
    }

    .doc-name-holder {
        flex: 0 1 auto;
    }

    /* ACTION BUTTON - EXACT match to _myforms.cshtml */
    .doc-actions {
        position: relative;
        margin-bottom:auto;
        margin-top: auto;
    }

    .doc-action-btn {
        background: #d1f4e0;
        color: #198754;
        font-weight: 600;
        border: none;
        border-radius: 8px;
        padding: 7px 22px;
        display: flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        white-space: nowrap;
        font-size: 0.8rem;
    }

        .doc-action-btn:hover {
            background: #0ea66b;
            border-color: #0ea66b;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(25, 135, 84, 0.2);
        }

        .doc-action-btn i {
            font-size: 0.8rem;
        }

    .actions-dropdown {
        display: none;
        position: absolute;
        right: 0;
        top: 100%;
        background-color: #ffffff;
        min-width: 200px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
        border: 1px solid #e0e0e0;
        border-radius: 10px;
        padding: 8px;
        z-index: 100;
    }

    .doc-actions:hover .actions-dropdown {
        display: block;
    }

    .actions-dropdown a {
        color: #333;
        padding: 10px 12px;
        text-decoration: none;
        display: block;
        font-size: 14px;
        font-weight: 500;
        border-radius: 6px;
        transition: all 0.15s ease;
    }

        .actions-dropdown a:hover {
            background: #f0f7ff;
            color: #2C7BE5;
        }

    /* SHOW MORE BUTTON - Inside card with divider - EXACT match to _myforms.cshtml */
    .show-more-row {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        justify-content: center;
        padding: 16px 0 8px;
        margin-top: 8px;
        border-top: 1px solid #e5e7eb;
    }

    .show-more-wrapper {
        padding: 14px 0 5px;
        text-align: right;
    }

    .show-more-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 24px;
        color: #4976af;
        background-color: #dbeafe;
        border: none;
        border-radius: 6px;
        font-size: 0.9375rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .show-more-btn:hover {
            background-color: #bfdbfe;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.25);
        }

        .show-more-btn:focus {
            outline: none;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.3);
        }

        .show-more-btn:active {
            transform: translateY(0);
        }

        .show-more-btn i {
            font-size: 0.75rem;
            transition: transform 0.2s ease;
        }

        .show-more-btn:hover i {
            transform: translateY(2px);
        }

    /* All Loaded Message - EXACT match to _myforms.cshtml */
    .all-loaded-msg {
        display: flex;
        justify-content: center;
        align-items: center;
        text-align: center;
        padding: 12px 0 4px;
        color: #6b7280;
        font-weight: 500;
        font-size: 0.875rem;
    }

        .all-loaded-msg::before,
        .all-loaded-msg::after {
            content: '';
            flex: 1;
            max-width: 80px;
            height: 1px;
            background: linear-gradient(to right, transparent, #d1d5db);
            margin: 0 12px;
        }

        .all-loaded-msg::after {
            background: linear-gradient(to left, transparent, #d1d5db);
        }

    .no-forms-message {
        text-align: center;
        padding: 2rem;
        background-color: rgba(0, 0, 0, 0.05);
        border-radius: 8px;
        color: #555;
        font-weight: 500;
    }

    .no-search-results {
        display: none;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 3rem 2rem;
        text-align: center;
        background: #f8fafc;
        border: 1px dashed #e2e8f0;
        border-radius: 12px;
        margin-top: 1rem;
    }

        .no-search-results.visible {
            display: flex;
        }

        .no-search-results i {
            font-size: 3rem;
            color: #cbd5e1;
            margin-bottom: 1rem;
        }

        .no-search-results h4 {
            font-size: 1.1rem;
            color: #64748b;
            margin: 0 0 0.5rem 0;
            font-weight: 600;
        }

        .no-search-results p {
            font-size: 0.9rem;
            color: #94a3b8;
            margin: 0;
        }

    .status-container {
        position: relative;
        display: inline-block;
    }

    .popup {
        display: none;
        position: absolute;
        min-width: 280px;
        padding: 15px;
        background: #2563eb;
        color: #ffffff;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        font-size: 0.875rem;
        z-index: 10000;
        bottom: 100%;
        right: 0;
    }

    .status-container:hover .popup {
        display: block;
    }

    .popup .header {
        font-weight: 600;
        margin-bottom: 0.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.2);
        padding-bottom: 0.5rem;
    }

    .popup .email-list {
        padding-left: 1rem;
        margin: 0;
    }

    .popup p {
        line-height: 1.4;
        margin: 8px 0 4px;
        color: #fff;
        font-weight: 600;
        font-size: 0.875rem;
    }

    .popup ul {
        padding-left: 0;
        color: #fff;
        display: flex;
        flex-direction: column;
        list-style: none;
        gap: 6px;
    }

        .popup ul li {
            font-size: 0.8125rem;
            font-weight: 500;
            position: relative;
            padding-left: 24px;
        }

            .popup ul li.first-email::before {
                content: "";
                position: absolute;
                left: 0;
                top: 50%;
                transform: translateY(-50%);
                width: 14px;
                height: 14px;
                background-color: transparent;
                border: 2px solid #fff;
                border-radius: 50%;
            }

            .popup ul li.first-email::after {
                content: "";
                width: 6px;
                height: 6px;
                background-color: #fff;
                border-radius: 50%;
                position: absolute;
                top: 50%;
                left: 7px;
                transform: translate(-50%, -50%);
            }

            .popup ul li.no-bullet, .popup ul li.delegator-section {
                padding-left: 0;
            }

    /* View Button - EXACT match to _myforms.cshtml action button style */
    .view-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 7px 22px;
        border-radius: 8px;
        background: #d1f4e0;
        border: none;
        color: #198754;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        margin-top: auto;
        margin-bottom: auto;
    }

        .view-btn i {
            font-size: 0.8rem;
        }

        .view-btn:hover {
            background: #0ea66b;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(25, 135, 84, 0.2);
        }

    /* Responsive styles - EXACT match to _myforms.cshtml */
    @@media (max-width: 992px) {
        .document-card {
            flex-direction: column;
            align-items: flex-start;
            gap: 15px;
        }

        .doc-right {
            width: 100%;
        }

        .doc-status-block {
            min-width: auto;
        }

        .popup {
            display: none !important;
        }
    }

    @@media (max-width: 768px) {
        .doc-left {
            gap: 12px;
        }

        .doc-icon-wrapper {
            width: 45px;
            height: 45px;
            min-width: 45px;
        }

            .doc-icon-wrapper i {
                font-size: 20px;
            }

            .doc-icon-wrapper img {
                width: 22px;
                height: 22px;
            }

        .doc-title {
            font-size: 16px;
        }

        .doc-meta {
            font-size: 13px;
        }

        .doc-action-btn {
            padding: 6px 16px;
            font-size: 13px;
        }

        .doc-right {
            gap: 12px;
        }

        .doc-name-pill {
            max-width: 120px;
        }
    }

    @@media (max-width: 576px) {
        .document-card {
            padding: 14px 16px;
        }

        .doc-icon-wrapper {
            width: 40px;
            height: 40px;
            min-width: 40px;
        }

        .doc-title {
            font-size: 15px;
        }

        .doc-status-heading {
            font-size: 11px;
        }

        .doc-status-text {
            font-size: 14px;
        }

        .doc-name-pill {
            max-width: 80px;
            font-size: 0.75rem;
            padding: 0.25rem 0.6rem;
        }
    }
    .empty-state-wrapper {
        display: flex;
        justify-content: center;
        min-height: 280px;
    }

    .empty-state-card {
        background: #ffffff;
        border: 1px solid #E5E7EB;
        border-radius: 14px;
        padding: 48px 24px;
        text-align: center;
        width: 100%;
        height: 100%;
    }

    .empty-state-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
    }

        .empty-state-icon i {
            font-size: 5rem;
            color: #64748b;
        }

    .empty-state-title {
        font-size: 18px;
        font-weight: 600;
        color: #0F172A;
        letter-spacing: -0.02em;
    }

    .empty-state-text {
        font-size: 14px;
        font-weight: 500;
        color: #64748B;
        margin: 0;
        line-height: 1.6;
    }

</style>

@if (Model.Count == 0)
{
    <div class="empty-state-wrapper">
        <div class="empty-state-card">
            <div class="empty-state-icon">
                <i class="fa-regular fa-folder-open"></i>
            </div>

            <h4 class="empty-state-title">No forms available</h4>

            <p class="empty-state-text">
                No forms have been published for your organisation yet
            </p>
        </div>
    </div>


}
else
{
    <div class="d-flex justify-content-end mb-3">
        <div class="search-bar" style="max-width: 350px;">
            <input type="text" id="orgFormsSearchInput" class="search-input" placeholder="Type Form name & Enter">
            <button type="button" class="search-button" id="orgFormsSearchBtn"><i class="fa fa-search"></i></button>
        </div>
    </div>

    <div id="orgFormsCardsContainer" class="card shadow-sm border rounded-4 p-3">
        @foreach (var item in Model)
        {
            var statusClass = "status-new";
            var statusLabel = "New";
            if (item.FormResponse != null)
            {
                if (item.FormResponse.Status == "Completed") { statusClass = "status-completed"; statusLabel = "Completed"; }
                else if (item.FormResponse.Status == "In Progress") { statusClass = "status-inprogress"; statusLabel = "In Progress"; }
                else if (item.FormResponse.Status == "New") { statusClass = "status-new"; statusLabel = "New"; }
                else { statusClass = "status-other"; statusLabel = item.FormResponse.Status; }
            }

            <div class="document-card" data-form-name="@item.Template.TemplateName.ToLower()">
                <div class="doc-left">
                    <div class="doc-icon-wrapper"><i class="fa-solid fa-file-lines" style="font-size: 1.25rem; color: #ffffff;"></i></div>
                    <div>
                        <p class="doc-title">@item.Template.TemplateName</p>
                        <p class="doc-meta">
                            Created:<span class="convert-time" data-timestamp="@item.Template.CreatedAt.ToString("o")">@item.Template.CreatedAt.ToString("dd/MM/yyyy")</span>
                        </p>
                    </div>
                </div>
                <div class="doc-right">
                    @if (!string.IsNullOrEmpty(item.Template.DocumentName))
                    {
                        <div class="doc-status-block">
                            <div class="doc-status-heading">Document Name</div>
                            <div class="doc-name-holder">
                                <span class="doc-name-pill" title="@item.Template.DocumentName">@item.Template.DocumentName</span>
                            </div>
                        </div>
                    }
                    <div class="doc-status-block">
                        <div class="doc-status-heading">Status</div>
                        <div class="status-container">
                            <span class="pill @statusClass" style="cursor:pointer;">@statusLabel</span>
                            @if (item.FormResponse != null && item.FormResponse.Status == "Completed" && item.FormResponse.CompleteSignList != null)
                            {
                                <div class="popup">
                                    <p class="header"><span class="headersp">TOTAL RECIPIENTS: @(item.FormResponse.CompleteSignList?.Count() + item.FormResponse.PendingSignList?.Count())</span></p>
                                    <div class="row">
                                        <p style="text-align:left">SIGNED: @(item.FormResponse.CompleteSignList?.Count() ?? 0)</p>
                                        <ul class="email-list" style="margin-bottom:0;">
                                            @foreach (var i in item.FormResponse.TemplateRecepients.Where(r => r.Status == "Signed"))
                                            {
                                                <li class="first-email" style="display:flex;justify-content:start;"><span class="sec" style="padding-left:6%">@(i.HasDelegation? i.AlternateSignatories.FirstOrDefault()?.email : i.Signer.email)</span></li>
                                            }
                                        </ul>
                                    </div>
                                </div>
                            }
                            @if (item.FormResponse != null && (item.FormResponse.Status == "In Progress" || item.FormResponse.Status == "New") && item.FormResponse.PendingSignList != null)
                            {
                                <div class="popup">
                                    <p class="header"><span class="headersp">TOTAL RECIPIENTS: @(item.FormResponse.CompleteSignList?.Count() + item.FormResponse.PendingSignList?.Count())</span></p>
                                    <div class="row">
                                        <p style="text-align:left">PENDING: @(item.FormResponse.PendingSignList?.Count() ?? 0)</p>
                                        <ul class="email-list" style="margin-bottom:0;">
                                            @foreach (var i in item.FormResponse.TemplateRecepients.Where(r => r.Status == "Pending"))
                                            {
                                                <li class="first-email" style="display:flex;justify-content:start;"><span class="sec" style="padding-left:6%">@(i.HasDelegation? i.AlternateSignatories.FirstOrDefault()?.email : i.Signer.email)</span></li>
                                            }
                                        </ul>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                    @if (item.FormResponse == null || item.FormResponse.Status == "New")
                    {
                        <div class="doc-actions">
                            <button class="doc-action-btn" type="button">Actions <i class="fa fa-chevron-down"></i></button>
                            <div class="actions-dropdown">
                                <a asp-action="FillFormData" asp-route-tempId="@item.Template._id" asp-route-edmsId="@item.Template.EdmsId" asp-route-documentName="@item.Template.DocumentName" asp-route-flag="Preview" onclick="document.getElementById('navigationNetworkOverlay').style.display='block'"><i class="icon-pencil"></i> Preview</a>
                                <a href="#" class="fillFormBtn" data-id="@item.Template._id" data-edmsid="@item.Template.EdmsId" data-name="@item.Template.TemplateName" data-type="orgforms"><i class="icon-pencil"></i> Fill Form</a>
                            </div>
                        </div>
                    }
                    else
                    {
                        <a asp-action="PublishedDocumentStatus" asp-route-docuid="@item.FormResponse.FormId" onclick="document.getElementById('navigationNetworkOverlay').style.display='block'" class="view-btn">
                            <i class="fa fa-eye"></i>
                            <span>View</span>
                        </a>
                    }
                </div>
            </div>
        }
    </div>

    <div id="noSearchResultsOrgForms" class="no-search-results">
        <i class="fa-solid fa-search"></i><h4>No forms found</h4><p>Try adjusting your search terms or clear the search field</p>
    </div>

    <div class="d-flex justify-content-center mt-3"><div class="all-loaded-msg mb-3" id="allDocsLoadedMsgOrgForms" style="display: none;"></div></div>
    <div class="show-more-wrapper"><button type="button" id="showMoreBtnOrgForms" class="show-more-btn" style="display: none;">Show More <i class="fas fa-chevron-down"></i></button></div>
}

<script>
    var GetPreviewConfigUrl='@Url.Action("GetPreviewConfig", "DigitalForms")';
    var DigitalFormsIndexUrl='@Url.Action("Index", "DigitalForms")';
    var ValidateEsealUrl='@Url.Action("ValidateEseal", "DigitalForms")';
    var FillFormDataUrl='@Url.Action("FillFormData", "DigitalForms")';

    (function () {
        var pageSize = 5, currentlyShown = pageSize;
        function getCards() { return document.querySelectorAll('#orgFormsCardsContainer .document-card'); }
        function updateVisibility() {
            var showMoreBtn = document.getElementById('showMoreBtnOrgForms');
            var allLoadedMsg = document.getElementById('allDocsLoadedMsgOrgForms');
            var noResultsDiv = document.getElementById('noSearchResultsOrgForms');
            var searchInput = document.getElementById('orgFormsSearchInput');
            const card = document.getElementById("orgFormsCardsContainer");
            var hasSearchQuery = searchInput && searchInput.value.trim() !== '';
            var visibleCards = Array.from(getCards()).filter(function (card) { return !card.classList.contains('search-hidden'); });
            var totalVisible = visibleCards.length;
                if (totalVisible === 0) {
        if (showMoreBtn) showMoreBtn.style.display = "none";
        if (allLoadedMsg) allLoadedMsg.style.display = "none";

        if (noResultsDiv && hasSearchQuery) {
            noResultsDiv.classList.add("visible");
            card.style.display = "none";
        }

        return;
    } else {
        if (noResultsDiv) {
            noResultsDiv.classList.remove("visible");
            card.style.display = "flex";
        }
    }

            visibleCards.forEach(function (card, index) { if (index < currentlyShown) { card.classList.remove('hidden'); } else { card.classList.add('hidden'); } });
            if (showMoreBtn && allLoadedMsg) {
                   if (totalVisible < 5) {
                        showMoreBtn.style.display = 'none';
                        allLoadedMsg.style.display = 'none';
                        return;
                    }
                if (currentlyShown >= totalVisible) { showMoreBtn.style.display = 'none'; allLoadedMsg.style.display = 'flex'; allLoadedMsg.innerHTML = 'All ' + totalVisible + ' forms loaded'; } else { showMoreBtn.style.display = 'inline-flex'; allLoadedMsg.style.display = 'none'; } }
        }
        function handleShowMore(e) { e.preventDefault(); currentlyShown += pageSize; updateVisibility(); }
        function handleSearch() {
            var searchInput = document.getElementById('orgFormsSearchInput');
            if (!searchInput) return;
            var query = searchInput.value.toLowerCase().trim();
            getCards().forEach(function (card) {
                var formName = card.getAttribute('data-form-name') || '';
                if (query === '' || formName.indexOf(query) !== -1) { card.classList.remove('search-hidden'); } else { card.classList.add('search-hidden'); card.classList.add('hidden'); }
            });
            currentlyShown = pageSize;
            updateVisibility();
        }
        function init() {
            var showMoreBtn = document.getElementById('showMoreBtnOrgForms');
            var searchInput = document.getElementById('orgFormsSearchInput');
            var searchBtn = document.getElementById('orgFormsSearchBtn');
            if (showMoreBtn) showMoreBtn.addEventListener('click', handleShowMore);
            if (searchInput) { searchInput.addEventListener('keypress', function (e) { if (e.key === 'Enter') { e.preventDefault(); handleSearch(); } }); searchInput.addEventListener('input', handleSearch); }
            if (searchBtn) searchBtn.addEventListener('click', handleSearch);
            updateVisibility();
        }
        if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', init); } else { init(); }
    })();
</script>

@if (Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Development")
{
    <script src="~/js/DigitalForms/_orgforms.js" type="text/javascript" asp-append-version="true" defer></script>
}
else
{
    <script src="~/dist/DigitalForms/_orgforms.min.js" type="text/javascript" asp-append-version="true" defer></script>
}
