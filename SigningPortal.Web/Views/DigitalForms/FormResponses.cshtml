<div class="row m-0" style="height:100vh">
    <div class="col-md-12 p-0" style="height:100%">
        <div class="card background-image" style="height:100%">

            <div class="card-body background-image">
                <h3 class="common-heading-color">Form Responses</h3>
                <div class="row">
                    <div class="tab-content" style="padding:0px">

                        @if (Model.Count == 0)
                        {

                            <div class="empty-state-wrapper">
                                <div class="empty-state-card">
                                    <div class="empty-state-icon">
                                        <i class="fa-regular fa-folder-open"></i>
                                    </div>

                                    <h4 class="empty-state-title">No responses received yet</h4>

                                    <p class="empty-state-text">
                                        Form responses will appear here.
                                    </p>
                                </div>
                            </div>
                        }
                        else
                        {


                            <div class="text-center">
                                <div class="card-body px-0">
                                    <div class="dataTables_scrollBody" style="position: relative; overflow: auto; width: 100%;">
                                        <table id="MyOrgFormTb" class="display nowrap dataTable no-footer" style="width: 100%;">
                                            <thead style="text-align: left;">
                                                <tr>

                                                    @* <th>USER</th>
                                                    <th>EMAIL</th>
                                                    <th>SIGNED DATE</th> *@

                                                    <th></th>
                                                    @foreach (var signerResponse in Model[0].SignerResponses)
                                                    {
                                                        <th>@signerResponse.SignerDetails.RoleName.ToUpper()</th>
                                                    }
                                                    <th>STATUS</th>
                                                    @foreach (var property in Model[0].FormFieldData.Properties())
                                                    {
                                                        <th>@property.Name.Split('_')[0].ToUpper()</th>
                                                    }
                                                    <th>VIEW</th>
                                                </tr>
                                            </thead>
                                            <tbody style="text-align: left;">
                                                @foreach (var item in Model)
                                                {
                                                    <tr style="cursor:pointer;" onclick="modalForm('@item.EdmsId', '@item.SignerName')">
                                                        <td></td>
                                                        @* <td>@item.CreatedBy</td>
                                                        <td>@item.SignerEmail</td>
                                                        <td>@item.CreatedAt</td> *@

                                                        @foreach (var signerResponse in item.SignerResponses)
                                                        {
                                                            <td style="text-align:left !important">@signerResponse.SignerDetails.SignerEmail</td>
                                                        }
                                                        <td>
                                                            <span class="status-pill status-@item.Status.ToLower().Replace(" ", "-")">@item.Status</span>
                                                        </td>
                                                        @* @foreach (var property in item.FormFieldData.Properties())
                                                        {
                                                            <td>@property.Value</td>
                                                        } *@
                                                        @foreach (var key in Model[0].FormFieldData.Properties())
                                                        {
                                                            <td>@(item.FormFieldData.Properties().FirstOrDefault(p => p.Name == key.Name)?.Value ?? "")</td>
                                                        }
                                                        <td class="valigntop" style="text-align:center">
                                                            <div class="btn-group" onclick="modalForm('@item.EdmsId', '@item.SignerName')">
                                                                <a href="#">
                                                                    <i class="fa fa-eye"></i>
                                                                </a>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>


                        }




                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<div class="modal fade" id="digitalShowModal" tabindex="-1" role="dialog" aria-labelledby="digitalFormModalLabel" aria-hidden="false" data-backdrop="false" style="display:none;opacity: 1;padding-top: 1%;background-color: rgba(0, 0, 0, 0.2);">
    <div class="modal-dialog modal-lg" role="document" style="width:100%;margin-top:0">
        <div class="modal-content" style="height:90vh">
            <div class="modal-header">
                <button type="button" class="btn btn-primary" onclick="DownloadForm()">Download PDF</button>
                <img data-toggle="tooltip" data-placement="left" title="Close" style="text-align:left;width:16px;height:20px;margin-left:3%" src="~/assets/images/cross.svg" asp-append-version="true" onclick="closemodal()" />
            </div>
            <div class="modal-body" style="overflow-y:auto">


                <div id="pdf-container" style="overflow-y:auto;width:100%;height:100%"></div>

            </div>


        </div>
    </div>
</div>




<script src="~/local-cdns/Shared/pdfjs/2.10.377/pdf.min.js"></script>
<script>
    var pdfjsLib = window['pdfjs-dist/build/pdf'];
    let renderedPages = new Set();
    let pdfInstance = null;
    if (!pdfjsLib) {
        console.error('PDF.js library is not loaded.');
    } else {
        pdfjsLib.GlobalWorkerOptions.workerSrc = '@Url.Content("/local-cdns/Shared/pdfjs/2.10.377/pdf.worker.min.js")';
    }
    const pdfContainer = document.getElementById('pdf-container');

    $(document).ready(function () {
       $('#networkOverlay').hide();

        // $('#MyOrgFormTb').DataTable({
        //     searching: true,
        //     paging: true,
        //     lengthChange: false,
        //     pageLength: 5,
        //     orderClasses: false,
        //     stripeClasses: [],
        //     info: true,
        //     "ordering": false

        // });

        new DataTable('#MyOrgFormTb', {
            scrollX: true,
            destroy: true,
            pageLength: 7,
            lengthChange: false,
            ordering: false,
            responsive: {
                details: {
                    type: 'column',
                    target: 'tr'
                }
            },
            columnDefs: [
                { className: 'control', orderable: false, targets: 0 } // Makes 1st column only for expansion
            ]
            // drawCallback: function (settings) {
            //     var api = this.api();
            //     var rows = api.rows({ page: 'current' }).data().length;
            //     if (rows === 0) {

            //         $('#MyOrgFormTb tbody').html('<tr><td colspan="100%" style="text-align:center !important;">No matching records found</td></tr>');
            //     }
            // }
        });

    });


    var formbase64 = "";


    function renderPage(pageNum, container) {
        const canvasScale = 1.5;
        pdfInstance.getPage(pageNum).then(page => {
            const viewport = page.getViewport({ scale: canvasScale });

            const canvas = document.createElement('canvas');
            const context = canvas.getContext('2d');
            canvas.width = viewport.width;
            canvas.height = viewport.height;
            canvas.style.width = '100%';

            container.innerHTML = '';
            container.appendChild(canvas);

            const renderContext = {
                canvasContext: context,
                viewport: viewport
            };

            page.render(renderContext).promise.then(() => {

            }).catch(err => {
                console.error(`Render failed for page ${pageNum}:`, err);
            });

        }).catch(err => {
            console.error(`Failed to get page ${pageNum}:`, err);
        });
    }


    function base64ToArrayBuffer(base64) {
        const binaryString = window.atob(base64);
        const len = binaryString.length;
        const bytes = new Uint8Array(len);
        for (let i = 0; i < len; i++) {
            bytes[i] = binaryString.charCodeAt(i);
        }
        return bytes.buffer;
    }
    function modalForm(EdmsId, SignerName) {
        $("#digitalShowModal").modal('show');
        FileName = SignerName + "_signed";

        $.ajax({
            url: '@Url.Action("GetPreviewConfig", "DigitalForms")',
            type: 'GET',
            data: {
                edmsId: EdmsId
            },
            beforeSend: function () {
                $('#overlay').show();
            },
            complete: function () {
                $('#overlay').hide();
            },
            success: function (resp) {
                if (resp.success) {

                    formbase64 = resp.result;
                    const pdfArrayBuffer = base64ToArrayBuffer(resp.result);
                    pdfjsLib.getDocument({ data: pdfArrayBuffer }).promise.then(pdf => {
                        pdfInstance = pdf;
                        setupPlaceholders(pdf.numPages);
                        setupLazyObserver();

                    }).catch(error => {
                        console.error('Error loading PDF:', error);
                    });

                } else {
                    swal({
                        title: 'Error',
                        text: resp.message,
                        type: 'error',
                    }, function (isConfirm) {
                        if (isConfirm) {
                            document.getElementById("navigationNetworkOverlay").style.display = "block";
                            window.location.href = '@Url.Action("Index", "DigitalForms")';
                        }
                    });
                }
            },
            // error: function (xhr, status, error) {
            //     console.log(error);
            //     swal({
            //         title: 'Error',
            //         text: 'Something went wrong!',
            //         type: 'error',
            //     }, function (isConfirm) {
            //         if (isConfirm) {
            //             window.location.href = '@Url.Action("Index", "DigitalForms")';
            //         }
            //     });
            // }
            error: function (xhr, status, error) {
                if (xhr.status === 500) {
                    swal({
                        title: "Server Error",
                        text: "An internal server error occurred. Redirecting...",
                        type: "error"
                    }, function (isConfirm) {
                        if (isConfirm) {
                            document.getElementById("navigationNetworkOverlay").style.display = "block";
                            window.location.href = '@Url.Action("Index", "DigitalForms")';
                        }
                    });
                } else {

                    ajaxErrorHandler(xhr, status, error);
                }
            }
        });
    }
    function DownloadForm() {
        var byteCharacters = atob(formbase64);
        var byteNumbers = new Array(byteCharacters.length);

        for (var i = 0; i < byteCharacters.length; i++) {
            byteNumbers[i] = byteCharacters.charCodeAt(i);
        }

        var byteArray = new Uint8Array(byteNumbers);
        var blob = new Blob([byteArray], { type: 'application/pdf' });


        var link = document.createElement('a');
        link.href = URL.createObjectURL(blob);
        link.download = 'SignedForm.pdf';
        link.click();
    };
    function closemodal() {
        const pdfContainer = document.getElementById('pdf-container');
        pdfContainer.innerHTML = '';
        renderedPages = new Set();
        $("#digitalShowModal").modal('hide');

    }

    function setupPlaceholders(totalPages) {

        for (let pageNum = 1; pageNum <= totalPages; pageNum++) {
            const placeholder = document.createElement('div');
            placeholder.className = 'pdf-page';
            placeholder.dataset.pageNumber = pageNum;
            placeholder.style.position = 'relative';
            placeholder.style.minHeight = '600px'; // approximate
            pdfContainer.appendChild(placeholder);
        }
    }

    function setupLazyObserver() {
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const pageNum = parseInt(entry.target.dataset.pageNumber);
                    if (!renderedPages.has(pageNum)) {
                        renderPage(pageNum, entry.target);
                        renderedPages.add(pageNum);
                    }
                }
            });
        }, {
            root: null,
            rootMargin: '200px',
            threshold: 0.1
        });

        document.querySelectorAll('.pdf-page').forEach(pageDiv => {
            observer.observe(pageDiv);
        });
    }
</script>