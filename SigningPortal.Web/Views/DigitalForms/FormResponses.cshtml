@model List<SigningPortal.Web.ViewModels.DigitalForms.FormResponse>;

@using System.Security.Claims;
@using Newtonsoft.Json;

@{
    var Suid = User.FindFirst(ClaimTypes.UserData).Value;
    var userEmail = User.FindFirst(ClaimTypes.Email).Value;
}




<style>
    /* ========================================
               Modern CSS Design System Variables
               ======================================== */
    :root {
        --df-primary: #10b981;
        --df-primary-hover: #059669;
        --df-primary-light: #d1fae5;
        --df-accent: #3b82f6;
        --df-accent-hover: #2563eb;
        --df-text-primary: #1e293b;
        --df-text-secondary: #64748b;
        --df-text-muted: #94a3b8;
        --df-bg-page: #f8fafc;
        --df-bg-card: #ffffff;
        --df-bg-hover: #f1f5f9;
        --df-bg-toolbar: #f0fdf4;
        --df-border-color: #e2e8f0;
        --df-shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
        --df-shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        --df-shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        --df-radius-sm: 8px;
        --df-radius-md: 12px;
        --df-radius-lg: 16px;
        --df-transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* ========================================
               Card & Container Styling
               ======================================== */
    .card.background-image {
        background: var(--df-bg-card);
        border: 1px solid var(--df-border-color);
        border-radius: var(--df-radius-lg);
        box-shadow: var(--df-shadow-md);
    }

    .card-body.background-image {
        padding: 1.5rem;
        background: var(--df-bg-card);
    }

    .common-heading-color {
        color: var(--df-text-primary);
        font-weight: 700;
        font-size: 1.875rem !important;
        letter-spacing: -0.025em;
        margin-bottom: 1.5rem;
        padding-bottom: 0.75rem;
    }

    /* ========================================
               DataTable Styling
               ======================================== */
    .dataTables_wrapper {
        padding: 0;
    }

    .dataTables_scrollBody::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }

    .dataTables_scrollBody::-webkit-scrollbar-thumb {
        background-color: var(--df-text-muted);
        border-radius: 4px;
    }

    .dataTables_scrollBody::-webkit-scrollbar-track {
        background-color: var(--df-bg-page);
        border-radius: 4px;
    }

    .dataTables_scrollBody {
        scrollbar-width: thin;
        scrollbar-color: var(--df-text-muted) var(--df-bg-page);
        border-radius: var(--df-radius-md);
    }

    .dataTables_wrapper.no-footer .dataTables_scrollBody {
        border-bottom: 1px solid var(--df-border-color);
    }

    .dataTables_scroll {
        border: 1px solid var(--df-border-color);
        border-radius: var(--df-radius-md);
        overflow: hidden;
        box-shadow: var(--df-shadow-sm);
    }

    /* ========================================
               Table Headers
               ======================================== */
    #MyOrgFormTb thead {
        visibility: hidden;
        bottom: 22px;
        height: 0;
        position: relative;
        overflow: hidden;
        border: none;
    }

    .dataTables_scrollBody thead th {
        font-size: 0.75rem;
        font-weight: 600 !important;
        color: var(--df-text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 16px 18px;
        background: #ebedef;
        border-bottom: none !important;
    }

    .dataTables_scrollBody thead {
        background: linear-gradient(135deg, var(--df-bg-toolbar), #ecfdf5);
    }

    th {
        font-size: 0.75rem;
        font-weight: 600 !important;
        color: var(--df-text-secondary);
        background: linear-gradient(135deg, var(--df-bg-toolbar), #ecfdf5);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    #MyOrgFormTb thead tr {
        visibility: collapse;
    }

    /* ========================================
               Table Body
               ======================================== */
    table {
        table-layout: auto;
        width: auto;
        border-collapse: separate;
        border-spacing: 0;
    }

    th, td {
        width: 150px;
        text-align: left;
        padding: 14px 18px;
        border-bottom: 1px solid var(--df-border-color);
    }

    td {
        color: var(--df-text-primary) !important;
        text-align: left !important;
        font-size: 0.9375rem;
        font-weight: 500;
        transition: var(--df-transition);
        vertical-align: middle;
    }

    #MyOrgFormTb tbody tr {
        transition: var(--df-transition);
        background: var(--df-bg-card);
    }

        #MyOrgFormTb tbody tr:hover td {
            background-color: rgba(16, 185, 129, 0.05) !important;
        }

        #MyOrgFormTb tbody tr:hover {
            cursor: pointer;
            box-shadow: var(--df-shadow-sm);
        }

    /* ========================================
               Status Pills
               ======================================== */
    .status-pill {
        display: inline-flex;
        align-items: center;
        padding: 0.375rem 0.875rem;
        border-radius: 9999px;
        font-size: 0.8125rem;
        font-weight: 600;
        letter-spacing: 0.025em;
        text-transform: capitalize;
    }

    .status-completed {
        color: #065f46;
        padding-left:0px;
    }

    .status-pending,
    .status-new {
        color: #92400e;
    }

    .status-in-progress {
        color: #1e40af;
    }

    .status-declined,
    .status-failed {
        color: #991b1b;
    }

    .status-expired {
        color: #374151;
    }

    /* ========================================
               PDF Preview
               ======================================== */
    .pdf-page {
        width: 98%;
        position: relative;
        display: inline-block;
        margin: 1%;
        border: 1px solid var(--df-border-color);
        box-shadow: var(--df-shadow-md);
        border-radius: var(--df-radius-sm);
        background: var(--df-bg-card);
    }

    /* ========================================
               Expand/Collapse Icons
               ======================================== */
    table.dataTable > tbody > tr > td.control::before {
        font-size: 16px;
        font-weight: bold;
        color: var(--df-primary);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        width: 26px;
        height: 26px;
        line-height: 26px;
        border-radius: 50%;
        background: rgba(16, 185, 129, 0.1);
        transition: var(--df-transition);
    }

    table.dataTable > tbody > tr > td.control:hover::before {
        background: rgba(16, 185, 129, 0.2);
    }

    table.dataTable > tbody > tr.parent > td.control::before {
        font-size: 13px !important;
        font-weight: bold;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        width: 26px;
        height: 26px;
        line-height: 26px;
        border-radius: 50%;
    }

    table.dataTable tbody tr.parent td.control::before {
        background: linear-gradient(135deg, var(--df-primary), var(--df-primary-hover)) !important;
        color: white !important;
    }

    /* ========================================
               Modal Styling
               ======================================== */
    .modal-content {
        border-radius: var(--df-radius-lg);
        border: none;
        box-shadow: var(--df-shadow-lg);
        overflow: hidden;
    }

    .modal-header {
        border-bottom: 1px solid var(--df-border-color);
        padding: 16px 20px;
        background: var(--df-bg-page);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

        .modal-header .btn-primary {
            background: linear-gradient(135deg, var(--df-primary), var(--df-primary-hover));
            border: none;
            border-radius: var(--df-radius-sm);
            padding: 10px 20px;
            font-weight: 600;
            box-shadow: 0 2px 8px rgba(79, 70, 229, 0.25);
            transition: var(--df-transition);
        }

            .modal-header .btn-primary:hover {
                transform: translateY(-1px);
                box-shadow: 0 4px 12px rgba(79, 70, 229, 0.35);
            }

    .modal-body {
        padding: 20px;
        background: var(--df-bg-page);
    }

    #pdf-container {
        background: var(--df-bg-card);
        border-radius: var(--df-radius-md);
        padding: 16px;
    }

    /* ========================================
               DataTable Pagination & Info
               ======================================== */
    .dataTables_info {
        font-size: 0.875rem;
        color: var(--df-text-secondary);
        padding: 14px 0;
        font-weight: 500;
    }

    .dataTables_paginate {
        padding: 14px 0;
    }

        .dataTables_paginate .paginate_button {
            padding: 8px 14px;
            margin: 0 3px;
            border-radius: var(--df-radius-sm);
            border: 1px solid var(--df-border-color);
            background: var(--df-bg-card);
            color: var(--df-text-primary) !important;
            font-size: 0.875rem;
            font-weight: 500;
            transition: var(--df-transition);
        }

            .dataTables_paginate .paginate_button:hover {
                background: var(--df-bg-hover) !important;
                border-color: var(--df-primary) !important;
                color: var(--df-primary) !important;
            }

            .dataTables_paginate .paginate_button.current {
                background: linear-gradient(135deg, var(--df-primary), var(--df-primary-hover)) !important;
                border-color: var(--df-primary) !important;
                color: white !important;
                box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
            }

            .dataTables_paginate .paginate_button.disabled {
                opacity: 0.5;
                cursor: not-allowed;
            }

    /* ========================================
               Empty State
               ======================================== */
    .text-center .p-4 {
        background: var(--df-bg-page) !important;
        border-radius: var(--df-radius-md);
        color: var(--df-text-secondary);
        font-weight: 500;
        padding: 2rem !important;
    }

    /* ========================================
               View Icon
               ======================================== */
    .btn-group a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: var(--df-radius-sm);
        transition: var(--df-transition);
    }

        .btn-group a:hover {
            background: var(--df-primary-light);
            transform: translateY(-2px);
            box-shadow: var(--df-shadow-sm);
        }

        .btn-group a img {
            width: 20px;
            height: 20px;
            opacity: 0.75;
            transition: var(--df-transition);
        }

        .btn-group a:hover img {
            opacity: 1;
        }

    /* ========================================
               Responsive Adjustments
               ======================================== */
    @@media (max-width: 767px) {
        .card-body.background-image {
            padding: 1rem;
        }

        .common-heading-color {
            font-size: 1.5rem !important;
            margin-bottom: 1rem;
        }

        th, td {
            padding: 10px 12px;
            font-size: 0.8125rem;
        }

        .status-pill {
            padding: 0.3rem 0.65rem;
            font-size: 0.75rem;
        }

        .btn-group a {
            width: 32px;
            height: 32px;
        }

            .btn-group a img {
                width: 18px;
                height: 18px;
            }
    }

    @@media (max-width: 480px) {
        .common-heading-color {
            font-size: 1.25rem !important;
        }

        th, td {
            padding: 8px 10px;
            font-size: 0.75rem;
        }
    }

    /* ========================================
               Media Queries for Zoom Levels
               ======================================== */
    @@media (min-width: 800px) {
        .dataTables_scroll {
            max-width: 100%;
            margin: 0 auto;
        }
    }

    @@media (min-width: 1092px) {
        .dataTables_scroll {
            max-width: 100%;
        }
    }

    @@media (min-width: 1365px) {
        .dataTables_scroll {
            max-width: 100%;
        }
    }

    @@media (min-width: 1440px) {
        .dataTables_scroll {
            max-width: 100%;
        }
    }

    #MyOrgFormTb_filter{
        margin-bottom:2%;
        margin-right:0.5%;
    }

    thead th {
        padding:10px 10px !important;
    }

    .empty-state-card {
        background: #ffffff;
        border: 1px solid #E5E7EB;
        border-radius: 14px;
        padding: 48px 24px;
        text-align: center;
        width: 100%;
        height: 100%;
    }

    .empty-state-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
    }

        .empty-state-icon i {
            font-size: 5rem;
            color: #64748b;
        }

    .empty-state-title {
        font-size: 18px;
        font-weight: 600;
        color: #0F172A;
        letter-spacing: -0.02em;
    }

    .empty-state-text {
        font-size: 14px;
        font-weight: 500;
        color: #64748B;
        margin: 0;
        line-height: 1.6;
    }
</style>
