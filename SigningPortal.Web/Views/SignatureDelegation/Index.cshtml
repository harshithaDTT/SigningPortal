        function showShimmer(count = 4) {
            const wrapper = document.getElementById("cardWrapper");
            wrapper.innerHTML = "";

            for (let i = 0; i < count; i++) {
                const shimmerCard = document.createElement("div");
                shimmerCard.className = "dg-card shimmer-card shadow-sm";

                shimmerCard.innerHTML = `
                                            <div class="dg-top">

                                                <div class="dg-user">
                                                    <div class="shimmer shimmer-avatar"></div>
                                                    <div>
                                                        <div class="shimmer shimmer-line md"></div>
                                                        <div class="shimmer shimmer-line sm"></div>
                                                    </div>
                                                </div>

                                                <div class="dg-col shimmer-col">
                                                    <div class="shimmer shimmer-line sm"></div>
                                                    <div class="shimmer shimmer-line md"></div>
                                                </div>

                                                <div class="dg-col shimmer-col">
                                                    <div class="shimmer shimmer-line sm"></div>
                                                    <div class="shimmer shimmer-line md"></div>
                                                </div>

                                                <div class="dg-col shimmer-col">
                                                    <div class="shimmer shimmer-line sm"></div>
                                                    <div class="shimmer shimmer-line sm"></div>
                                                </div>

                                            </div>
                                        `;

                wrapper.appendChild(shimmerCard);
            }
        }
        function handleEmptyState(count) {
            if (count === 0) {
                $("#cardslist").hide();

                if (activetab === "mydelegation") {
                    $("#Mydelegationsempty").show();
                    $("#receiveddelegationsempty").hide();
                } else {
                    $("#receiveddelegationsempty").show();
                    $("#Mydelegationsempty").hide();
                }
            } else {
                $("#cardslist").show();
                $("#Mydelegationsempty").hide();
                $("#receiveddelegationsempty").hide();
            }
        }
        $("#delegationSearch").on("input", function () {
            const searchText = $(this).val().toLowerCase().trim();

            // If search box is empty → show default list
            if (!searchText) {
                renderDelegationCards();
                return;
            }

            // Filter delegations by delegate email
            const filteredData = allDelegations.filter(d => {
                if (!d.delegatees || d.delegatees.length === 0) return false;

                const delegateEmail = d.delegatees[0].delegateeEmail || "";
                return delegateEmail.toLowerCase().includes(searchText);
            });

            // Render filtered cards
            generateCards(filteredData);

            // Optional: handle empty state
            handleEmptyState(filteredData.length);
        });

        function renderDelegationCards() {
            const wrapper = $("#cardWrapper");
            wrapper.empty();

            const dataToRender = isExpanded
                ? allDelegations
                : allDelegations.slice(0, INITIAL_VISIBLE_COUNT);

            generateCards(dataToRender);
        }
      
        function generateCards(data) {

            const wrapper = document.getElementById("cardWrapper");
            wrapper.innerHTML = "";
            var textval = '';
            if (activetab === "mydelegation") {
                textval = ` <span class="dg-to-label">To:</span>`;
            } else {
                textval = ` <span class="dg-to-label">From:</span>`;
            }
            data.forEach(d => {

                const card = document.createElement("div");
                card.className = "dg-card shadow-sm onhoverclass";

                const delegate = d.delegatees[0];

                const fullnameval = cropFileNames(delegate.fullName, "name");
                const emailval = delegate.delegateeEmail;

                /* ---------- STATUS ---------- */
                let statusText = d.delegationStatus;
                let statusClass = "";
                let statushtml = "";

                if (["Cancelled", "Rejected"].includes(statusText)) {
                    statusClass = "dg-status cancelled";
                    statushtml = `
                                        <span class="${statusClass}">
                                                    ${statusText}
                                        </span>`;
                }
                else if (["Expired", "Completed"].includes(statusText)) {
                    statusClass = "dg-status expired";
                    statushtml = `
                                        <span class="${statusClass}">
                                                    ${statusText}
                                        </span>`;
                }
                else if (statusText === "Active") {
                    statusClass = "dg-status active";
                    statushtml = `
                                        <span class="${statusClass}">
                                                    ${statusText}
                                        </span>`;
                }
                else {
                    statusClass = "dg-status new";
                    statushtml = `
                                        <span class="${statusClass}">
                                                   ${statusText}
                                        </span>`;
                }


                /* ---------- ACTION DROPDOWN ---------- */
                let buttonsHtml = "";

                if (["Cancelled", "Expired", "Completed", "Rejected"].includes(statusText)) {
                    buttonsHtml = `
                                                        <div class="action-dropdown">
                                                            <button class="action-btn rounded-3">Actions ▾</button>
                                                            <div class="dropdown-menu">
                                                                <button class="dropdown-item disabled-blur" style="color:red;"><i class='fa fa-circle-minus'></i>&nbsp; Revoke</button>
                                                                <button class="dropdown-item" onclick="getdetails('${d._id}')">
                                                                                    <i class='fa-regular fa-eye'></i>&nbsp;View
                                                                </button>
                                                            </div>
                                                        </div>
                                                    `;
                } else {
                    buttonsHtml = `
                                                        <div class="action-dropdown">
                                                                    <button class="action-btn rounded-3">Actions ▾</button>
                                                            <div class="dropdown-menu">
                                                                        <button class="dropdown-item" onclick="revokeDelegate('${d._id}')" style="color:red;">
                                                                            <i class='fa fa-circle-minus'></i>&nbsp; Revoke
                                                                </button>
                                                                <button class="dropdown-item" onclick="getdetails('${d._id}')">
                                                                                            <i class='fa-regular fa-eye'></i>&nbsp;View
                                                                </button>
                                                            </div>
                                                        </div>
                                                    `;
                }

                /* ---------- NEW UI CARD ---------- */
                card.innerHTML = `
                                                    <div class="dg-top">

                                                        <div class="dg-user">
                                                            <div class="dg-avatar">
                                                                ${delegate.fullName[0].toUpperCase()}
                                                            </div>
                                                            <div>
                                                                <div class="dg-name" title="${delegate.fullName}">${fullnameval}</div>
                                                                     <div class="dg-to-row">
                                                                           ${textval}
                                                                           <div class="dg-email">${emailval}</div>
                                                                     </div>
                                                            </div>
                                                        </div>
                                                                <div class="dg-col start-date">
                                                            <div class="dg-label">Start Date & Time</div>
                                                            <div class="dg-value convert-time" data-timestamp="${d.startDateTime}">
                                                                ${d.startDateTime}
                                                            </div>
                                                        </div>

                                                                <div class="dg-col end-date">
                                                            <div class="dg-label">End Date&Time</div>
                                                            <div class="dg-value convert-time" data-timestamp="${d.endDateTime}">
                                                                ${d.endDateTime}
                                                            </div>
                                                        </div>

                                                                <div class="dg-col status-col" style="text-align:left;">
                                                            <div class="dg-label">Status</div>
                                                                    ${statushtml}
                                                        </div>

                                                        ${buttonsHtml}

                                                    </div>

                                                `;

                wrapper.appendChild(card);
            });
        }

        function updateShowMoreButtons() {
            console.log("Total delegations:", allDelegations.length);

            if (allDelegations.length <= INITIAL_VISIBLE_COUNT) {
                $("#showMoreBtn, #showLessBtn").addClass("d-none");
                return;
            }

            if (isExpanded) {
                $("#showMoreBtn").addClass("d-none");
                $("#showLessBtn").removeClass("d-none");
            } else {
                $("#showMoreBtn").removeClass("d-none");
                $("#showLessBtn").addClass("d-none");
            }
        }


        $("#showMoreBtn").on("click", function () {
            isExpanded = true;
            renderDelegationCards();
            updateShowMoreButtons();
            updateTimestamps_statuspage();
        });

        $("#showLessBtn").on("click", function () {
            isExpanded = false;
            renderDelegationCards();
            updateShowMoreButtons();
            updateTimestamps_statuspage();

            // Optional: scroll back to top of cards
            $('html, body').animate({
                scrollTop: $("#cardWrapper").offset().top - 100
            }, 400);
        });


        function getdetails(delegationId) {
            $.ajax({
                url: '@Url.Action("Previewdetails", "SignatureDelegation")',
                type: "GET",
                data: { delegationId: delegationId },
                success: function (response) {
                    if (!response.success) {
                        console.error(response.message);
                        return;
                    }
                    console.log(response);
                    openDelegationModal(response.result);
                },
                error: function (xhr, status, error) {
                    console.error("Error fetching data:", error);
                }
            });
        }
        function openDelegationModal(data) {

            /* ---------- FORMAT DATE ---------- */
            function formatDate(isoString) {
                if (!isoString) return "-";
                const date = new Date(isoString);
                return date.toLocaleString("en-GB", {
                    day: "2-digit",
                    month: "2-digit",
                    year: "numeric",
                    hour: "2-digit",
                    minute: "2-digit",
                    hour12: true
                });
            }

            /* ---------- STATUS CLASS ---------- */
            function getStatusClass(status) {
                switch (status) {
                    case "Active":
                        return "active";
                    case "Expired":
                        return "expired";
                    case "Cancelled":
                        return "cancelled";
                    case "Rejected":
                        return "rejected";
                    default:
                        return "new";
                }
            }

            /* ---------- HEADER ---------- */
            const summaryHtml = `
                                                                                                <div class="delegation-summary-header">
                                                                                                    <div class="summary-left">
                                                                                                        <div class="info-icon">i</div>

                                                                                                        <div>
                                                                                                            <div class="title-row">
                                                                                                                <h3>Signature Delegation Details</h3>
                                                                                                            </div>

                                                                                                            <div class="dates">
                                                                                                                <span>Start Date: ${formatDate(data.startDateTime)}</span>
                                                                                                                <span>End Date: ${formatDate(data.endDateTime)}</span>
                                                                                                            </div>
                                                                                                        </div>
                                                                                                    </div>

                                                                                                    <span class="status-chip ${getStatusClass(data.delegationStatus)}">
                                                                                                        ${data.delegationStatus}
                                                                                                    </span>
                                                                                                </div>
                                                                                            `;

            document.getElementById("delegationSummary").innerHTML = summaryHtml;

            /* ---------- DELEGATE LIST ---------- */
            const listContainer = document.getElementById("delegateListContainer");
            listContainer.innerHTML = "";


            (data.delegatees || []).forEach(d => {

                const imageSrc = d.thumbnail
                    ? `data:image/jpeg;base64,${d.thumbnail}`
                    : "https://via.placeholder.com/48";

                const row = document.createElement("div");
                row.className = "delegate-row ";
                var fullnameval = cropFileNames(d.fullName, "name");
                var emailval = cropFileNames(d.email, "email");
                row.innerHTML = `
                                                                                                        <img src="${imageSrc}" alt="delegate" />

                                                                                                        <div class="delegate-info" style="margin-left:1rem;">
                                                                                                            <label style="dg-label">Name</label>
                                                                                                                    <div>${fullnameval || "-"}</div>
                                                                                                        </div>

                                                                                                        <div class="delegate-info">
                                                                                                                    <label style="dg-label">Email</label>
                                                                                                                    <div>${emailval || "-"}</div>
                                                                                                        </div>

                                                                                                        <div class="delegate-status ${getStatusClass(data.delegationStatus)}">
                                                                                                            ${data.delegationStatus}
                                                                                                        </div>
                                                                                                    `;

                listContainer.appendChild(row);
            });

            /* ---------- SHOW MODAL ---------- */
            document.getElementById("delegationModalOverlay").classList.remove("d-none");
        }


        function closeDelegationModal() {
            document.getElementById("delegationModalOverlay").classList.add("d-none");
        }

                function cropFileNames(full, type) {
            if (!full) return "";

            let visible;

            const width = window.innerWidth;

            if (type === "name") {
                if (width >= 1300) visible = 18;
                else if (width >= 768) visible = 14;
                else if (width >= 460) visible = 16;
                else visible = 12;
            } else {
                if (width >= 1300) visible = 30;
                else if (width >= 768) visible = 24;
                else if (width >= 460) visible = 26;
                else visible = 20;
            }

            if (full.length <= visible) return full;

            const half = Math.floor(visible / 2);

            return (
                full.slice(0, half) +
                "..." +
                full.slice(full.length - half)
            );
        }

    </script>
