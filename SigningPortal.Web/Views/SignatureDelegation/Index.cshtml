@section scripts {
    <link rel="stylesheet" href="~/local-cdns/Shared/datetimepicker/2.5.20/jquery.datetimepicker.min.css">
    <script src="~/local-cdns/Shared/jquery/3.6.0/jquery.min.js"></script>
    <script src="~/local-cdns/Shared/datetimepicker/2.5.20/jquery.datetimepicker.full.min.js"></script>


    <script>

        var userEmail = '@userEmail';
        var viewmodel = @Html.Raw(Json.Serialize(Model));
        var emailInputValue = [];
        var delegateEmails = [];
        var index = 0;
        var emailIsValid = false;
        var index_val = 0;
        var delegateeobj = [];
        let allDelegations = [];
        const INITIAL_VISIBLE_COUNT = 4;
        let isExpanded = false;
        const emailRegex = /^\w+([\.-]?\w+)*@@\w+([\.-]?\w+)*(\.\w{2,6})+$/;
        var usersuid = '@Suid';
        var loginorgid = '@OrganizationUid';
        var activetab = '';
        $(document).ready(function () {
            $('#networkOverlay').hide();

            $('#StartDateTime').datetimepicker({
                format: 'd-m-Y H:i',
                step: 15,
                minDate: '@minDateTime',
                scrollInput: false
            });

            $('#EndDateTime').datetimepicker({
                format: 'd-m-Y H:i',
                step: 15,
                minDate: '@minDateTime',
                scrollInput: false
            });

            $('#StartDateTime').attr('placeholder', 'DD-MM-YYYY HH:MM');
            $('#EndDateTime').attr('placeholder', 'DD-MM-YYYY HH:MM');
            function calculateDuration() {
                var startVal = $('#StartDateTime').val();
                var endVal = $('#EndDateTime').val();

                if (!startVal || !endVal) {
                    $('#durationValue').text('0 days');
                    return;
                }

                // Convert "d-m-Y H:i" → JS Date
                var startParts = startVal.split(/[- :]/);
                var endParts = endVal.split(/[- :]/);

                var startDate = new Date(
                    startParts[2],        // year
                    startParts[1] - 1,    // month
                    startParts[0],        // day
                    startParts[3],        // hour
                    startParts[4]         // minute
                );

                var endDate = new Date(
                    endParts[2],
                    endParts[1] - 1,
                    endParts[0],
                    endParts[3],
                    endParts[4]
                );

                if (endDate < startDate) {
                    $('#durationValue').text('0 days');
                    return;
                }

                var diffMs = endDate - startDate;
                var diffDays = Math.ceil(diffMs / (1000 * 60 * 60 * 24));

                $('#durationValue').text(diffDays + ' days');
            }

            // Trigger calculation when date changes
            $('#StartDateTime, #EndDateTime').on('change', calculateDuration);
            $('#DelegateEmail').on('change', function () {

                var emailInputValue = $(this).val().trim();

                // Empty check
                if (emailInputValue === "") {
                    toastr.error('Please enter an Email');
                    return;
                }

                // Email format validation
                if (!emailRegex.test(emailInputValue)) {
                    toastr.error('Please enter a valid Email');
                    return;
                }

                // Self-delegation check
                if (userEmail === emailInputValue) {
                    toastr.error('You cannot assign yourself as Delegatee');
                    return;
                }

                // Organization email validation
                if (!Array.isArray(viewmodel.emails) ||
                    !viewmodel.emails.includes(emailInputValue)) {

                    toastr.error("This email does not belong to this organization");
                    return;
                }

                // ✅ Update delegatee object (single delegatee)
                delegateeobj = []; // reset previous value

                delegateeobj.push({
                    email: emailInputValue
                });

                // Optional: store separately if needed
                delegateEmails = [emailInputValue];

            });
            getdelegationlist();

        });

        $(document).on("click", ".action-btn", function (e) {
            e.stopPropagation();

            // Close other open dropdowns
            $(".dropdown-menu").not($(this).next()).removeClass("show");

            // Toggle current dropdown
            $(this).next(".dropdown-menu").toggleClass("show");
        });

        // Close dropdown when clicking outside
        $(document).on("click", function () {
            $(".dropdown-menu").removeClass("show");
        });
        $(document).on("click", ".dg-tab-btn", function () {

            $(".dg-tab-btn").removeClass("active");
            $(this).addClass("active");

            if (this.id === "tabMyDelegations") {
                getdelegationlist();
                console.log("My Delegations");
            } else {
                getdelegationReceivedlist();
                console.log("Received");
            }
        });

        function convertToDesiredFormat(dateTimeStr) {
            if (!dateTimeStr) return '';

            // Split the input string into date and time parts
            var dateParts = dateTimeStr.split(' ')[0].split('-'); // ['30', '09', '2024']
            var timeParts = dateTimeStr.split(' ')[1].split(':'); // ['21', '52']

            // Create a Date object using the date and time parts (note: months are 0-indexed in JavaScript)
            var date = new Date(
                dateParts[2],           // Year (e.g., 2024)
                dateParts[1] - 1,       // Month (e.g., 09 -> 8 because it's zero-indexed)
                dateParts[0],           // Day (e.g., 30)
                timeParts[0],           // Hours (e.g., 21)
                timeParts[1]            // Minutes (e.g., 52)
            );

            var year = date.getFullYear();
            var month = ('0' + (date.getMonth() + 1)).slice(-2); // Add 1 to month as it is zero-indexed
            var day = ('0' + date.getDate()).slice(-2);
            var hours = ('0' + date.getHours()).slice(-2);
            var minutes = ('0' + date.getMinutes()).slice(-2);

            return `${year}-${month}-${day}T${hours}:${minutes}`;
        }

        $('#submitButton').click(function () {

            // --- Get date values ---
            var startRaw = $('#StartDateTime').val();
            var endRaw = $('#EndDateTime').val();

            if (!startRaw) {
                toastr.error('Please select start date');
                return;
            }

            if (!endRaw) {
                toastr.error('Please select end date');
                return;
            }
            var reason = $('#delegationReason').val().trim();


            var startDateTime = convertToDesiredFormat(startRaw);
            var endDateTime = convertToDesiredFormat(endRaw);

            if (!startDateTime || startDateTime === "NaN-aN-aNTaN:aN") {
                toastr.error('Please select valid start date');
                return;
            }

            if (!endDateTime || endDateTime === "NaN-aN-aNTaN:aN") {
                toastr.error('Please select valid end date');
                return;
            }

            if (startDateTime === endDateTime) {
                toastr.error('Delegation start and end time cannot be same');
                return;
            }

            if (startDateTime > endDateTime) {
                toastr.error('Please select correct end date time');
                return;
            }

            var now = new Date();
            var startDate = new Date(startDateTime);

            if (startDate <= now) {
                toastr.error('Start date & time must be in the future');
                return;
            }

            // --- Email validation ---
            var EmailInputValue = $('#DelegateEmail').val().trim();

            if (!EmailInputValue) {
                toastr.error('Please enter an email');
                return;
            }

            if (!emailRegex.test(EmailInputValue)) {
                toastr.error('Please enter a valid Email');
                return;
            }

            if (EmailInputValue === userEmail) {
                toastr.error('You cannot assign yourself as Delegatee');
                return;
            }

            if (!Array.isArray(viewmodel.emails) || !viewmodel.emails.includes(EmailInputValue)) {
                toastr.error('This email does not belong to this organization');
                return;
            }
            var token = $('input[name="__RequestVerificationToken"]').val();
            if (token) {
                xhr.setRequestHeader('RequestVerificationToken', token);
            }
            // --- Build model ---
            var model = {
                StartDateTime: new Date(startDateTime).toISOString(),
                EndDateTime: new Date(endDateTime).toISOString(),
                Reason: reason,
                Emails: [EmailInputValue]   // backend-compatible
            };

            // --- AJAX call ---
            $.ajax({
                url: '@Url.Action("AddDelegation", "SignatureDelegation")',
                type: 'POST',
                data: JSON.stringify(model),
                headers: {
                    'RequestVerificationToken': token
                },
                contentType: 'application/json',
                beforeSend: function () {
                    $('#overlay').show();
                },
                complete: function () {
                    $('#overlay').hide();
                },
                success: function (response) {
                    if (response.status === "Failed") {
                        swal({
                            title: 'Server response',
                            text: response.message,
                            type: 'info'
                        });
                    } else {
                        swal({
                            title: 'Success',
                            text: response.message,
                            type: 'success'
                        }, function () {
                            window.location.href = '@Url.Action("Index", "SignatureDelegation")';
                        });
                    }
                },
                error: ajaxErrorHandler
            });

        });

        function revokeDelegate(delegationId) {
            // Send an AJAX request to the controller

            $.ajax({
                url: '@Url.Action("RevokeDelegate", "SignatureDelegation")',
                type: 'POST',
                data: { delegationId: delegationId },
                beforeSend: function () {
                    $('#overlay').show();
                },
                complete: function () {
                    $('#overlay').hide();
                },
                error: ajaxErrorHandler,
                success: function (response) {
                    if (response.status == "Failed") {
                        swal({
                            title: 'Server response',
                            text: response.message,
                            type: 'info',
                        }, function (isConfirm) {
                            if (isConfirm) {
                                window.location.href = '@Url.Action("Index", "SignatureDelegation")';
                            }
                        });
                    }
                    else {
                        swal({
                            title: 'Success',
                            text: response.message,
                            type: 'success',
                        }, function (isConfirm) {
                            if (isConfirm) {
                                window.location.href = '@Url.Action("Index", "SignatureDelegation")';
                            }
                        });

                    }
                }
            });
        }


        function formatDateToDDMMYYYYtime(dateString) {
            if (!dateString) return "";

            const date = new Date(dateString);
            const day = String(date.getDate()).padStart(2, "0");
            const month = String(date.getMonth() + 1).padStart(2, "0"); // Months are 0-based
            const year = date.getFullYear();

            let hours = date.getHours();
            const minutes = String(date.getMinutes()).padStart(2, "0");
            const seconds = String(date.getSeconds()).padStart(2, "0");

            const ampm = hours >= 12 ? "PM" : "AM";
            hours = hours % 12;
            hours = hours ? hours : 12; // Convert '0' to '12'
            const formattedHours = String(hours).padStart(2, "0");

            return `${day}/${month}/${year} ${formattedHours}:${minutes}:${seconds} ${ampm}`;

        }

        function convertToLocalTime(serverTime) {
            // Parse the server-sent time (with offset) into a Date object
            const date = new Date(serverTime);

            // Convert to user's local time
            const localTime = date.toLocaleString("en-US", { timeZone: Intl.DateTimeFormat().resolvedOptions().timeZone });

            return localTime;
        }

        function updateTimestamps_statuspage() {
            document.querySelectorAll(".convert-time").forEach(function (element) {
                const serverTime = element.getAttribute("data-timestamp");
                if (serverTime) {
                    const localTime = convertToLocalTime(serverTime);
                    element.textContent = formatDateToDDMMYYYYtime(localTime);

                }
            });

        }
        function handleCreateDelegation() {
            document.getElementById("delegationcard").style.display = "none";
            document.getElementById("newdelegationdiv").style.display = "block";
            document.getElementById("listtabpart").style.display = "none";

        }
        function handleCloseCreateDelegation() {
            document.getElementById("delegationcard").style.display = "block";
            document.getElementById("newdelegationdiv").style.display = "none";
            document.getElementById("listtabpart").style.display = "block";
        }

        function handlePreview(delegationId) {
            window.location.href = '@Url.Action("Preview", "SignatureDelegation")' + `?DelegationId=${delegationId}`;
        }

        function getdelegationlist() {

            showShimmer(5); // 👈 show shimmer immediately
            activetab = "mydelegation";
            $.ajax({
                url: '@Url.Action("Listitems", "SignatureDelegation")',
                type: "GET",
                success: function (response) {

                    if (!response.success) {
                        console.error(response.message);
                        return;
                    }
                    if (response.result.delegationList.length < 1) {
                        document.getElementById("Mydelegationsempty").style.display = "block";
                        document.getElementById("receiveddelegationsempty").style.display = "none";
                        document.getElementById("cardslist").style.display = "none";
                        return;
                    }
                    document.getElementById("Mydelegationsempty").style.display = "none";
                    document.getElementById("receiveddelegationsempty").style.display = "none";
                    document.getElementById("cardslist").style.display = "block";
                    allDelegations = response.result.delegationList || [];
                    renderDelegationCards(); // 👈 replaces shimmer
                    updateShowMoreButtons();
                    updateTimestamps_statuspage();
                },
