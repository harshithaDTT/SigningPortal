                    document.getElementById("receiveddelegationsempty").style.display = "none";
                    document.getElementById("Mydelegationsempty").style.display = "none";
                    document.getElementById("cardslist").style.display = "block";
                    allDelegations = response.result.delegationList || [];
                    renderDelegationCards(); // 👈 replaces shimmer
