@model SigningPortal.Web.ViewModels.SignatureDelegation.ListViewModel
@{
    await Html.RenderPartialAsync("_AlertBox");
}
<style>


    .custom-dropdown {
        position: relative;
        display: inline-block;
    }

    .custom-dropdown-content {
        display: none;
        position: absolute;
        background-color: #fff;
        min-width: 120px;
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
        z-index: 1;
        border: 1px solid #ced4da;
        border-radius: 0.25rem;
    }

        .custom-dropdown-content a {
            color: #333;
            padding: 0.25rem 1rem;
            text-decoration: none;
            display: block;
            font-size: 14px;
        }

            .custom-dropdown-content a:hover {
                background-color: #333;
                color: white;
            }

    .custom-dropdown:hover .custom-dropdown-content {
        display: block;
    }

    .custom-dropdown-content li {
        list-style: none;
    }

    /* Style for the dropdown button */
    .btn-dropdown-toggle {
        /* / Default button color / / Default text color /  */
        border: none;
    }


    .card-content {
        overflow-y: auto; /* Add overflow-y to enable vertical scrolling if needed */
        max-height: 645px; /* Add max-height to limit the height of the card content */
    }

    .card-title {
        margin-bottom: 10px !important;
    }



    .btn-outline-secondary:not(:disabled):not(.disabled).active, .btn-outline-secondary:not(:disabled):not(.disabled):active, .show > .btn-outline-secondary.dropdown-toggle {
        color: #fff;
        background-color: transparent !important;
        border-color: transparent !important;
    }

    .dataTables_wrapper {
        position: relative !important;
        clear: both !important;
        width: 100% !important;
    }

    .btn {
        text-transform: capitalize !important;
        font-size: 12px !important;
    }
    /* Styling the expand "+" icon */
    table.dataTable > tbody > tr > td.control::before {
        font-size: 20px; /* Make the icon bigger */
        font-weight: bold;
        color: #007bff; /* Blue color */
        display: inline-block;
        text-align: center;
        width: 24px; /* Ensures proper alignment */
        height: 24px; /* Ensures proper alignment */
        line-height: 24px; /* Centers icon vertically */
        border-radius: 24px;
    }

    /* Styling the collapse "−" icon */
    table.dataTable > tbody > tr.parent > td.control::before {
        font-size: 15px !important;
        font-weight: bold;
        display: inline-block;
        text-align: center;
        width: 20px;
        height: 20px;
        line-height: 20px;
        border-radius: 20px;
    }

    table.dataTable tbody tr.parent td.control::before {
        background-color: forestgreen !important;
        color: white !important;
    }
</style>

