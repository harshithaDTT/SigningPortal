                                            <td class="convert-time" data-timestamp="@item.StartDateTime.ToString("o")">
                                                @item.StartDateTime.ToString("MM/dd/yyyy, hh:mm:ss tt")
                                            </td>
                                            <td class="convert-time" data-timestamp="@item.EndDateTime.ToString("o")">
