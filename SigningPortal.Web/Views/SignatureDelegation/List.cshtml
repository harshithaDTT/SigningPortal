                                    <a asp-action="Preview" asp-route-DelegationId="@item._id">
                                    <i class="icon-docs"></i>View
                                    </a>
                                    </li>
                                    }
                                    </ul>
                                    </div>
                                    </td>*@
                                            <td class="valigntop">
                                                <div class="custom-dropdown">
