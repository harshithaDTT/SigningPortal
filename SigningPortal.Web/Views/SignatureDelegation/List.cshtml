            //         const formattedStartDate = startDate.toLocaleDateString('en-GB') + ' ' + startDate.toLocaleTimeString();
            //         $(this).text(formattedStartDate);
            //     } else {
            //         $(this).text('Invalid Date');
            //     }
            // });

            // // Loop through each table row that has a 'data-end' attribute
            // $('td[data-end]').each(function () {
            //     const utcEnd = $(this).attr('data-end');
            //     const endDate = new Date(utcEnd);
            //     if (!isNaN(endDate.getTime())) {
            //         // Format the date and time separately without a comma
            //         const formattedEndDate = endDate.toLocaleDateString('en-GB') + ' ' + endDate.toLocaleTimeString();
            //         $(this).text(formattedEndDate);
            //     } else {
            //         $(this).text('Invalid Date');
            //     }
            // });

            updateTimestamps_statuspage();
             
        });

        function handleCreateDelegation() {
            document.getElementById("navigationNetworkOverlay").style.display = "block";

            window.location.href = '@Url.Action("CreateDelegation", "SignatureDelegation")';
        }

        function handlePreview(delegationId) {
            document.getElementById("navigationNetworkOverlay").style.display = "block";

            window.location.href = '@Url.Action("Preview", "SignatureDelegation")' + `?DelegationId=${delegationId}`;
        }
        function revokeDelegate(delegationId) {
            // Send an AJAX request to the controller

            $.ajax({
                url: '@Url.Action("RevokeDelegate", "SignatureDelegation")',
                type: 'POST',
                data: { delegationId: delegationId },
                beforeSend: function () {
                    $('#overlay').show();
                },
                complete: function () {
                    $('#overlay').hide();
                },
                error: ajaxErrorHandler,
                success: function (response) {
                    if (response.status == "Failed") {
                        swal({
                            title: 'Server response',
                            text: response.message,
                            type: 'info',
                        }, function (isConfirm) {
                            if (isConfirm) {
                                window.location.href = '@Url.Action("List", "SignatureDelegation")';
                            }
                        });
                    }
                    else {
                        swal({
                            title: 'Success',
                            text: response.message,
                            type: 'success',
                        }, function (isConfirm) {
                            if (isConfirm) {
                                window.location.href = '@Url.Action("List", "SignatureDelegation")';
                            }
                        });

                    }
                }
            });
        }

    </script>
}