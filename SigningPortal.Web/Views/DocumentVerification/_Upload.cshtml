@model List<SigningPortal.Web.ViewModels.DocumentVerificationViewModel.VerificationViewModel>
@inject IConfiguration Configuration

@{
    var currentStaging = Configuration["CurrentStaging"];
    var OkImageUrl = Url.Content($"/Images_change/{currentStaging}/icons8-0k-241.png");
    var CancelImageUrl = Url.Content("/img/icon/icons8-cancel-24.png");
}

@{
    int count = 1;
}

<style>
    .dv-report-page {
        background: #f5f7fa;
        min-height: 100vh;
        padding: 12px;
    }

    .dv-report-card {
        max-width: 980px;
        margin: 0 auto;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(15, 23, 42, 0.06);
        overflow: hidden;
    }

    .dv-report-header {
        padding: 12px 16px;
        border-bottom: 1px solid #e5e7eb;
        background: #fafcff;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        flex-wrap: wrap;
    }

    .dv-report-title {
        margin: 0;
        font-size: 1.1rem;
        font-weight: 700;
        color: #0f172a;
    }

    .dv-report-summary {
        font-size: 0.78rem;
        color: #64748b;
        font-weight: 600;
    }

    .dv-meta-row {
        padding: 14px 16px;
        display: grid;
        grid-template-columns: 1.5fr .8fr;
        gap: 12px;
        border-bottom: 1px solid #e5e7eb;
        background: #ffffff;
    }

    .dv-meta-label {
        font-size: 0.66rem;
        color: #94a3b8;
        font-weight: 700;
        letter-spacing: .04em;
        text-transform: uppercase;
    }

    .dv-meta-value {
        margin-top: 4px;
        font-size: 0.95rem;
        font-weight: 600;
        color: #0f172a;
        word-break: break-word;
    }

    .dv-sign-list {
        padding: 14px 16px 16px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        background: #fbfcfe;
    }

    .dv-sign-card {
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        background: #ffffff;
        padding: 12px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        flex-wrap: wrap;
        box-shadow: 0 1px 3px rgba(15, 23, 42, 0.04);
    }

    .dv-sign-left {
        display: flex;
        align-items: center;
        gap: 8px;
        min-width: 0;
    }

    .dv-sign-index {
        width: 24px;
        height: 24px;
        border-radius: 999px;
        background: #ecfdf5;
        color: #047857;
        font-size: 0.72rem;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .dv-sign-name {
        margin: 0;
        font-size: 0.9rem;
        font-weight: 600;
        color: #0f172a;
        line-height: 1.3;
    }

    .dv-sign-time {
        margin: 0;
        font-size: 0.77rem;
        color: #64748b;
        line-height: 1.2;
    }

    .dv-sign-status {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border-radius: 999px;
        padding: 4px 9px;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        background: #ecfdf5;
        color: #047857;
    }

        .dv-sign-status.invalid {
            background: #fee2e2;
            color: #991b1b;
        }

        .dv-sign-status img {
            width: 12px;
            height: 12px;
            object-fit: contain;
        }

    @@media (max-width: 640px) {
        .dv-meta-row {
            grid-template-columns: 1fr;
        }

        .dv-report-page {
            padding: 8px;
        }
    }
</style>

<div class="dv-report-page">
    <div class="dv-report-card">
        <div class="dv-report-header">
            <h3 class="dv-report-title">Signature Details</h3>
            <span class="dv-report-summary">@Model.Count signers</span>
        </div>

        <div class="dv-meta-row">
            <div>
                <div class="dv-meta-label">Document Name</div>
                <div class="dv-meta-value">@Model[0].documentName</div>
            </div>
            <div>
                <div class="dv-meta-label">Policy</div>
                <div class="dv-meta-value">QES AdESQC</div>
            </div>
        </div>

        <div class="dv-sign-list">
            @foreach (var item in Model)
            {
                var validClass = item.signatureValid ? "dv-sign-status" : "dv-sign-status invalid";
                var statusText = item.signatureValid ? "Verified" : "Invalid";
                var statusImage = item.signatureValid ? OkImageUrl : CancelImageUrl;

                <div class="dv-sign-card">
                    <div class="dv-sign-left">
                        <span class="dv-sign-index">@count</span>
                        <div>
                            <p class="dv-sign-name">@item.signedBy</p>
                            <p class="dv-sign-time">
                                Signed: <span class="convert-time" data-timestamp="@item.signedTime.ToString("o")">@item.signedTime</span>
                            </p>
                        </div>
                    </div>

                    <div class="@validClass">
                        <img src="@statusImage" alt="validation status" asp-append-version="true" />
                        @statusText
                    </div>
                </div>
                count++;
            }
        </div>
    </div>
</div>

@if (Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Development")
{
    <script src="~/js/DocumentVerification/_Upload.js" type="text/javascript" asp-append-version="true" defer></script>
}
else
{
    <script src="~/dist/DocumentVerification/_Upload.min.js" type="text/javascript" asp-append-version="true" defer></script>
}
