@model SigningPortal.Web.ViewModels.FormRequests.AllFormRequestsListViewModel
@using System.Security.Claims;
@using Newtonsoft.Json;

@{
    ViewData["Title"] = "View";
    var Suid = User.FindFirst(ClaimTypes.UserData).Value;
    var userEmail = User.FindFirst(ClaimTypes.Email).Value;
    var bulksign = User.IsInRole("bulkSign");
    var AccountType = User.FindFirst("AccountType").Value;
    var OrganizationName = "";
    var OrganizationUid = "";
    var login_esealsignatoryrole = User.IsInRole("eSealSignatory");
    var selfemails = "";
    if (AccountType != "Self") { selfemails = User.FindFirst("SelfEmails").Value; OrganizationName = User.FindFirst("OrganizationName").Value; OrganizationUid = User.FindFirst("OrganizationUid").Value; }
}

<style>
    /* ============================================
           Card-Based Forms UI - EXACT match to _myforms.cshtml
           ============================================ */

    .hidden {
        display: none !important;
    }

    /* Search Bar - EXACT match to _myforms.cshtml */
    .search-bar {
        display: flex;
        align-items: center;
        width: 100%;
        background: #f9fafb;
        border: 0.0625rem solid #e2e8f0;
        box-shadow: 0 0.0625rem 0.25rem rgba(0,0,0,0.08);
        transition: all 0.2s ease-in-out;
    }

        .search-bar:hover {
            box-shadow: 0 0.125rem 0.5rem rgba(0,0,0,0.12);
        }

    .search-input {
        flex: 1;
        border: none;
        padding: 0.375rem 1.25rem;
        font-size: 0.875rem;
        outline: none;
        background: transparent;
    }

    .search-button {
        border: none;
        background: transparent;
        color: #4a5568;
        font-size: 0.9375rem;
        padding: 0.375rem 0.875rem;
        cursor: pointer;
    }

        .search-button:hover {
            background: rgba(0,0,0,0.08);
        }

    /* DOCUMENT CARD CONTAINER - EXACT match to _myforms.cshtml */
    .document-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 18px 22px;
        background: #ffffff;
        border-radius: 12px;
        border: 1px solid #e0dfdf;
        margin-bottom: 16px;
        transition: box-shadow .2s ease;
        box-shadow: 0 4px 9px rgba(25, 135, 84, 0.2);
    }

        .document-card:hover {
            box-shadow: 0 3px 12px rgba(0, 0, 0, 0.2) !important;
        }

        .document-card.search-hidden {
            display: none !important;
        }

    /* Right side container for status blocks and actions */
    .doc-right {
        display: flex;
        align-items: center;
        gap: 24px;
        flex: 0 1 50%;
        justify-content: space-between;
    }

    /* LEFT SIDE : ICON + FILE INFO - EXACT match to _myforms.cshtml */
    .doc-left {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .doc-icon-wrapper {
        width: 2.5rem;
        height: 2.5rem;
        background: linear-gradient(135deg, #0A1F44 0%, #059669 100%);
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .doc-icon-wrapper i {
            font-size: 1.25rem;
            color: #ffffff;
        }

        .doc-icon-wrapper img {
            width: 28px;
            height: 28px;
        }

    .doc-title {
        font-size: 18px;
        font-weight: 600;
        color: #1e293b;
        margin: 0;
    }

    /* Created / Expires Line */
    .doc-meta {
        margin: 4px 0 0;
        font-family: sans-serif;
        font-weight: 500;
        font-size: 14px;
        color: #919aa3 !important;
    }

    /* MIDDLE STATUS BLOCK - EXACT match to _myforms.cshtml */
    .doc-status-block {
        text-align: left;
        min-width: 120px;
    }

    .doc-status-heading {
        text-transform: uppercase;
        font-weight: 600;
        margin-bottom: 3px;
        font-family: 'Arial', sans-serif;
        font-size: 12px;
        color: #6c757d;
        letter-spacing: 0.5px;
    }

    .doc-sentto-block {
        text-align: left;
        min-width: 200px;
        max-width: 280px;
    }

    .doc-sentto-emails {
        font-size: 0.8125rem;
        color: #475569;
        line-height: 1.5;
        max-height: 60px;
        overflow-y: auto;
    }

    .status-badge {
        padding: 0.375rem 0.875rem;
        border-radius: 6px;
        font-size: 0.8125rem;
        font-weight: 600;
        display: inline-block;
        text-align: center;
    }

    .status-new {
        color: #1d4ed8;
        border-radius: 6px;
        font-size: 0.8125rem;
        font-weight: 600;
    }

    .status-completed {
        color: #047857;
        font-size: 0.8125rem;
        font-weight: 600;
    }

    .status-inprogress {
        color: #b45309;
        font-size: 0.8125rem;
        font-weight: 600;
    }

    .status-other {
        color: #64748b;
        font-size: 0.8125rem;
        font-weight: 600;
    }

    /* SHOW MORE BUTTON - EXACT match to _myforms.cshtml */
    .show-more-row {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        justify-content: center;
        padding: 16px 0 8px;
        margin-top: 8px;
        border-top: 1px solid #e5e7eb;
    }

    .show-more-wrapper {
        padding: 14px 0 5px;
        text-align: right;
    }

    .show-more-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 24px;
        color: #4976af;
        background-color: #dbeafe;
        border: none;
        border-radius: 6px;
        font-size: 0.9375rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .show-more-btn:hover {
            background-color: #bfdbfe;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.25);
        }

        .show-more-btn:focus {
            outline: none;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.3);
        }

        .show-more-btn:active {
            transform: translateY(0);
        }

        .show-more-btn i {
            font-size: 0.75rem;
            transition: transform 0.2s ease;
        }

        .show-more-btn:hover i {
            transform: translateY(2px);
        }

    /* All Loaded Message - EXACT match to _myforms.cshtml */
    .all-loaded-msg {
        display: flex;
        justify-content: center;
        align-items: center;
        text-align: center;
        padding: 12px 0 4px;
        color: #6b7280;
        font-weight: 500;
        font-size: 0.875rem;
    }

        .all-loaded-msg::before,
        .all-loaded-msg::after {
            content: '';
            flex: 1;
            max-width: 80px;
            height: 1px;
            background: linear-gradient(to right, transparent, #d1d5db);
            margin: 0 12px;
        }

        .all-loaded-msg::after {
            background: linear-gradient(to left, transparent, #d1d5db);
        }

    .no-forms-message {
        text-align: center;
        padding: 2rem;
        background-color: rgba(0, 0, 0, 0.05);
        border-radius: 8px;
        color: #555;
        font-weight: 500;
    }

    .no-search-results {
        display: none;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 3rem 2rem;
        text-align: center;
        background: #f8fafc;
        border: 1px dashed #e2e8f0;
        border-radius: 12px;
        margin-top: 1rem;
    }

        .no-search-results.visible {
            display: flex;
        }

        .no-search-results i {
            font-size: 3rem;
            color: #cbd5e1;
            margin-bottom: 1rem;
        }

        .no-search-results h4 {
            font-size: 1.1rem;
            color: #64748b;
            margin: 0 0 0.5rem 0;
            font-weight: 600;
        }

        .no-search-results p {
            font-size: 0.9rem;
            color: #94a3b8;
            margin: 0;
        }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .page-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: #1e293b;
        margin: 0;
    }

    .template-preview-link {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.875rem;
        color: #64748b;
    }

        .template-preview-link a {
            display: flex;
            align-items: center;
        }

        .template-preview-link img {
            width: 24px;
            height: 24px;
            opacity: 0.7;
            transition: opacity 0.2s;
        }

        .template-preview-link a:hover img {
            opacity: 1;
        }

    /* Header-specific layout (scoped to Sent header) */
    .sent-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.75rem 0;
    }

    .sent-header-left {
        display: flex;
        align-items: center;
    }

    .header-left-inner {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .header-icon-wrapper {
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 0.75rem;
        background: linear-gradient(135deg, #0A1F44 0%, #059669 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ffffff;
        font-size: 1.25rem;
        flex-shrink: 0;
    }

    .sent-title-block {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .page-subtitle {
        font-size: 0.95rem;
        color: #6b7280;
        margin: 0;
        line-height: 1.2;
    }

    @@media (max-width: 576px) {
        .header-icon-wrapper {
            width: 2.25rem;
            height: 2.25rem;
            font-size: 1.1rem;
            border-radius: 0.625rem;
        }

        .page-title {
            font-size: 1.125rem;
        }

        .sent-title-block {
            min-width: 0;
        }

        .header-left-inner {
            width: 100%;
        }
    }

    .sent-header-right {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

        .sent-header-right .template-preview-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 0.45rem 0.75rem;
            border-radius: 8px;
            background: transparent;
            color: #64748b;
            text-decoration: none;
            flex-shrink: 0;
        }

            .sent-header-right .template-preview-link:hover {
                background: rgba(0,0,0,0.03);
            }

    @@media (max-width: 576px) {
        .sent-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.5rem;
        }

        .sent-header-right {
            width: 100%;
            display: flex;
            justify-content: flex-end;
        }

            .sent-header-right .template-preview-link {
                width: auto;
            }
    }

    .status-container {
        position: relative;
        display: inline-block;
    }

    .popup {
        display: none;
        position: absolute;
        min-width: 280px;
        padding: 15px;
        background: #059669;
        color: #ffffff;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        font-size: 0.875rem;
        z-index: 10000;
        bottom: 100%;
        right: 0;
    }

    .status-container:hover .popup {
        display: block;
    }

    .popup .header {
        font-weight: 600;
        margin-bottom: 0.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.2);
        padding-bottom: 0.5rem;
    }

    .popup p {
        line-height: 1.4;
        margin: 8px 0 4px;
        color: #fff;
        font-weight: 600;
        font-size: 0.875rem;
    }

    .popup ul {
        padding-left: 0;
        color: #fff;
        display: flex;
        flex-direction: column;
        list-style: none;
        gap: 6px;
        margin: 0;
        text-align: left;
    }

        .popup ul li {
            font-size: 0.8125rem;
            font-weight: 500;
            position: relative;
            padding-left: 24px;
        }

            .popup ul li.first-email::before {
                content: "";
                position: absolute;
                left: 0;
                top: 50%;
                transform: translateY(-50%);
                width: 14px;
                height: 14px;
                background-color: transparent;
                border: 2px solid #fff;
                border-radius: 50%;
            }

            .popup ul li.first-email::after {
                content: "";
                width: 6px;
                height: 6px;
                background-color: #fff;
                border-radius: 50%;
                position: absolute;
                top: 50%;
                left: 7px;
                transform: translate(-50%, -50%);
            }

            .popup ul li.no-bullet {
                padding-left: 0;
            }

    /* ============================================
           RESPONSIVE BREAKPOINTS - EXACT match to _myforms.cshtml
           ============================================ */
    @@media (max-width: 1200px) {
        .doc-right {
            flex: 0 1 55%;
        }
    }

    @@media (max-width: 992px) {
        .document-card {
            flex-direction: column;
            align-items: flex-start;
            gap: 15px;
        }

        .doc-right {
            width: 100%;
            flex: 1;
            justify-content: space-between;
        }

        .doc-status-block, .doc-sentto-block {
            min-width: auto;
        }

        .popup {
            display: none !important;
        }
    }

    @@media (max-width: 768px) {
        .doc-left {
            gap: 12px;
        }

        .doc-icon-wrapper {
            width: 2.25rem;
            height: 2.25rem;
        }

            .doc-icon-wrapper i {
                font-size: 1.1rem;
            }

        .doc-title {
            font-size: 16px;
        }

        .doc-meta {
            font-size: 13px;
        }

        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }

    @@media (max-width: 576px) {
        .document-card {
            padding: 14px 16px;
        }

        .doc-icon-wrapper {
            width: 2rem;
            height: 2rem;
        }

            .doc-icon-wrapper i {
                font-size: 1rem;
            }

        .doc-title {
            font-size: 15px;
        }

        .doc-status-heading {
            font-size: 11px;
        }

        .doc-right {
            flex-direction: column;
            align-items: center;
            gap: 8px;
        }
    }

    /* ACTION BUTTON - EXACT match to _myforms.cshtml doc-action-btn */
    .view-btn,
    .doc-action-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 0.5rem 1rem;
        background: #d1f4e0;
        color: #198754;
        border: none;
        border-radius: 8px;
        font-size: 0.875rem;
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .view-btn:hover,
        .doc-action-btn:hover {
            background: #0ea66b;
            color: #fff;
            box-shadow: 0 4px 12px rgba(5, 150, 105, 0.3);
            transform: translateY(-1px);
        }

        .view-btn i,
        .doc-action-btn i {
            font-size: 14px;
        }
</style>

<div class="row m-0">
    <div class="col-md-12 p-0" style="height:100%;">
        <div class="card background-image" style="height:100%;padding-left:2%;border:none">
            <div class="card-body">

                @if (Model.bulksignSentFormListRequests.Count == 0)
                {
                    <div class="no-forms-message"><i class="fa-regular fa-folder-open" style="font-size: 2rem; color: #97a1b5; margin-bottom: 1rem; display: block;"></i>No Records Are Found</div>
                }
                else
                {
                    <div class="page-header sent-header">
                        <div class="sent-header-left">
                            <div class="header-left-inner">
                                <div class="header-icon-wrapper" aria-hidden="true"><i class="fa-solid fa-file-lines" style="color: #ffffff;"></i></div>
                                <div class="sent-title-block">
                                    <h3 class="page-title">Sent Form List</h3>
                                    <p class="page-subtitle" aria-hidden="true">Monitor sent forms status</p>
                                </div>
                            </div>
                        </div>
                        <div class="sent-header-right">
                            <div class="template-preview-link">
                                Template Preview
                                <a asp-action="FillFormData" asp-route-tempId="@Model.bulksignSentFormListRequests[0].FormId" asp-route-edmsId="@Model.bulksignSentFormListRequests[0].EdmsId" asp-route-documentName="@Model.bulksignSentFormListRequests[0].DocumentName" asp-route-flag="previewsend" asp-route-docuid="@Model.bulksignSentFormListRequests[0]._id" asp-route-Status="@Model.bulksignSentFormListRequests[0].Status" onclick="document.getElementById('navigationNetworkOverlay').style.display='block'">
                                    <img src='@Url.Content("~/assets/images/eyeicon.png")' alt="View" asp-append-version="true" style="margin-left: 8px;" />
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end mb-3">
                        <div class="search-bar" style="max-width: 350px;">
                            <input type="text" id="bulksignSentSearchInput" class="search-input" placeholder="Type Form name & Enter">
                            <button type="button" class="search-button" id="bulksignSentSearchBtn"><i class="fa fa-search"></i></button>
                        </div>
                    </div>

                    <div id="bulksignSentCardsContainer" class="card shadow-sm border rounded-4 p-3">
                        @foreach (var item in Model.bulksignSentFormListRequests)
                        {
                            var statusClass = "status-new";
                            var statusLabel = item.Status;
                            if (item.Status == "Completed") { statusClass = "status-completed"; }
                            else if (item.Status == "In Progress") { statusClass = "status-inprogress"; }
                            else if (item.Status == "New") { statusClass = "status-new"; }
                            else { statusClass = "status-other"; }

                            var allEmails = new List<string>();
                            if (item.CompleteSignList != null) { allEmails.AddRange(item.CompleteSignList.Select(s => s.email)); }
                            if (item.PendingSignList != null) { allEmails.AddRange(item.PendingSignList.Select(s => s.email)); }

                            <div class="document-card" data-form-name="@item.DocumentName.ToLower()">
                                <div class="doc-left">
                                    <div class="doc-icon-wrapper"><i class="fa-solid fa-file-lines" style="color: #ffffff;"></i></div>
                                    <div>
                                        <p class="doc-title">@item.DocumentName</p>
                                        <p class="doc-meta">Created: <span class="convert-time" data-timestamp="@item.CreatedAt.ToString("o")">@item.CreatedAt.ToString("dd/MM/yyyy")</span><span class="mx-1 pl-1 pr-1">•</span>Expires: <span class="convert-time" data-timestamp="@item.ExpieryDate.ToString("o")">@item.ExpieryDate.ToString("dd/MM/yyyy")</span></p>
                                    </div>
                                </div>
                                <div class="doc-right">
                                    <div class="doc-sentto-block">
                                        <div class="doc-status-heading">Sent To</div>
                                        <div class="doc-sentto-emails">@string.Join(", ", allEmails.Take(3))@(allEmails.Count > 3 ? $" +{allEmails.Count - 3} more" : "")</div>
                                    </div>
                                    <div class="doc-status-block">
                                        <div class="doc-status-heading">Status</div>
                                        <div class="status-container">
                                            <span class="@statusClass" style="cursor:pointer;">@statusLabel</span>
                                            @if (item.Status == "Completed" && item.CompleteSignList != null)
                                            {
                                                <div class="popup">
                                                    <p class="header"><span>TOTAL RECIPIENTS: @(item.CompleteSignList?.Count() + item.PendingSignList?.Count())</span></p>
                                                    <div class="row">
                                                        <p style="text-align:left">SIGNED: @(item.CompleteSignList?.Count() ?? 0)</p>
                                                        <ul>
                                                            @foreach (var signer in item.CompleteSignList)
                                                            {
                                                                <li class="first-email">@signer.email</li>
                                                            }
                                                        </ul>
                                                    </div>
                                                </div>
                                            }
                                            @if ((item.Status == "In Progress" || item.Status == "New") && item.PendingSignList != null)
                                            {
                                                <div class="popup">
                                                    <p class="header"><span>TOTAL RECIPIENTS: @(item.CompleteSignList?.Count() + item.PendingSignList?.Count())</span></p>
                                                    <div class="row">
                                                        <p style="text-align:left">PENDING: @(item.PendingSignList?.Count() ?? 0)</p>
                                                        <ul>
                                                            @foreach (var signer in item.PendingSignList)
                                                            {
                                                                <li class="first-email">@signer.email</li>
                                                            }
                                                        </ul>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                    <a asp-action="DocumentStatus" asp-route-tempId="@item.FormId" asp-route-docuid="@item._id" onclick="document.getElementById('navigationNetworkOverlay').style.display='block'" class="view-btn">
                                        <i class="fa fa-eye"></i>
                                        <span>View</span>
                                    </a>
                                </div>
                            </div>
                        }
                        <div class="show-more-wrapper"><button type="button" id="showMoreBtnBulksignSent" class="show-more-btn" style="display: none;">Show More <i class="fas fa-chevron-down"></i></button></div>
                    </div>

                    <div id="noSearchResultsBulksignSent" class="no-search-results">
                        <i class="fa-solid fa-search"></i><h4>No forms found</h4><p>Try adjusting your search terms or clear the search field</p>
                    </div>

                    <div class="d-flex justify-content-center mt-3"><div class="all-loaded-msg mb-3" id="allDocsLoadedMsgBulksignSent" style="display: none;"></div></div>

                }

            </div>
        </div>
    </div>
</div>

<script src="~/local-cdns/Shared/pdfjs/2.10.377/pdf.min.js"></script>
<script>
    var pdfjsLib = window['pdfjs-dist/build/pdf'];
    if (!pdfjsLib) { console.error('PDF.js library is not loaded.'); } else { pdfjsLib.GlobalWorkerOptions.workerSrc = '@Url.Content("/local-cdns/Shared/pdfjs/2.10.377/pdf.worker.min.js")'; }
    var loginOrgId = '@OrganizationUid';
    var viewName = "BulksignSentDocuments";
    var bulksignPermisson = '@bulksign';

    $(document).ready(function () { $('#networkOverlay').hide(); });

    (function () {
        var pageSize = 5, currentlyShown = pageSize;
        function getCards() { return document.querySelectorAll('#bulksignSentCardsContainer .document-card'); }
        function updateVisibility() {
            var showMoreBtn = document.getElementById('showMoreBtnBulksignSent');
            var allLoadedMsg = document.getElementById('allDocsLoadedMsgBulksignSent');
            var noResultsDiv = document.getElementById('noSearchResultsBulksignSent');
            var searchInput = document.getElementById('bulksignSentSearchInput');
            const card = document.getElementById("bulksignSentCardsContainer");
            var hasSearchQuery = searchInput && searchInput.value.trim() !== '';
            var visibleCards = Array.from(getCards()).filter(function (card) { return !card.classList.contains('search-hidden'); });
            var totalVisible = visibleCards.length;
                if (totalVisible === 0) {
        if (showMoreBtn) {
            showMoreBtn.style.display = "none";
        }

        if (allLoadedMsg) {
            allLoadedMsg.style.display = "none";
        }

        if (noResultsDiv && hasSearchQuery) {
            noResultsDiv.classList.add("visible");
            card.style.display = "none";
        }

        return;
    } else {
        if (noResultsDiv) {
            noResultsDiv.classList.remove("visible");
            card.style.display = "flex";
        }
    }

            visibleCards.forEach(function (card, index) { if (index < currentlyShown) { card.classList.remove('hidden'); } else { card.classList.add('hidden'); } });
            if (showMoreBtn && allLoadedMsg) {
                  if (totalVisible < 5) {
                        showMoreBtn.style.display = 'none';
                        allLoadedMsg.style.display = 'none';
                        return;
                    }
                if (currentlyShown >= totalVisible) { showMoreBtn.style.display = 'none'; allLoadedMsg.style.display = 'flex'; allLoadedMsg.innerHTML = 'All ' + totalVisible + ' forms loaded'; } else { showMoreBtn.style.display = 'inline-flex'; allLoadedMsg.style.display = 'none'; } }
        }
        function handleShowMore(e) { e.preventDefault(); currentlyShown += pageSize; updateVisibility(); }
        function handleSearch() {
            var searchInput = document.getElementById('bulksignSentSearchInput');
            if (!searchInput) return;
            var query = searchInput.value.toLowerCase().trim();
            getCards().forEach(function (card) {
                var formName = card.getAttribute('data-form-name') || '';
                if (query === '' || formName.indexOf(query) !== -1) { card.classList.remove('search-hidden'); } else { card.classList.add('search-hidden'); card.classList.add('hidden'); }
            });
            currentlyShown = pageSize;
            updateVisibility();
        }
        function init() {
            var showMoreBtn = document.getElementById('showMoreBtnBulksignSent');
            var searchInput = document.getElementById('bulksignSentSearchInput');
            var searchBtn = document.getElementById('bulksignSentSearchBtn');
            if (showMoreBtn) showMoreBtn.addEventListener('click', handleShowMore);
            if (searchInput) { searchInput.addEventListener('keypress', function (e) { if (e.key === 'Enter') { e.preventDefault(); handleSearch(); } }); searchInput.addEventListener('input', handleSearch); }
            if (searchBtn) searchBtn.addEventListener('click', handleSearch);
            updateVisibility();
        }
        if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', init); } else { init(); }
    })();
</script>
