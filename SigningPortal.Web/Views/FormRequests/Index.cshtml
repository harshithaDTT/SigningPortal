<style>
	/* Custom dropdown menu style */
	.custom-dropdown {
		position: relative;
		display: inline-block;
	}

	.custom-dropdown-content {
		display: none;
		position: absolute;
		background-color: #fff;
		min-width: 120px;
		box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
		z-index: 1;
		border: 1px solid #ced4da;
		border-radius: 0.25rem;
	}

		.custom-dropdown-content a {
			color: #333;
			padding: 0.25rem 1rem;
			text-decoration: none;
			display: block;
			font-size: 14px;
		}

			.custom-dropdown-content a:hover {
				background-color: #333;
				color: white;
			}

	.custom-dropdown:hover .custom-dropdown-content {
		display: block;
	}

	.custom-dropdown-content li {
		list-style: none;
	}

	.btn {
		text-transform: capitalize !important;
		font-size: 12px !important;
	}

	/* Ensure full width for table */
	.table-container {
		width: 100%;
		overflow-x: auto;
	}

	.table {
		width: 100%;
		max-width: 100%;
		margin-bottom: 1rem;
		background-color: transparent;
	}

	.dataTables_wrapper {
		position: relative !important;
		clear: both !important;
		width: 100% !important;
	}

	.card-title {
		margin-bottom: 10px !important;
	}


	.popup {
		display: none;
		position: absolute;
		min-width: 280px;
		padding: 15px;
		background-image: linear-gradient(90deg, #30b6ac, #81bc73);
		color: #000;
		border-radius: 6px;
		box-shadow: 0 0 24px rgba(0, 0, 0, .25);
		font-size: 80%;
		z-index: 10000;
		opacity: 0;
		transition: opacity 0.3s, visibility 0.3s;
		bottom: 100%;
		/*/ Position above the status / */
		right: 0;
		/*/ Align to the right of the status container / */
		transform: translateX(0) translateY(-10px);
		/*/ Adjust vertical positioning /*/
	}

	.status-container:hover .popup {
		display: block;
		opacity: 1;
		visibility: visible;
	}

	.popup::after {
		content: "";
		position: absolute;
		bottom: -10px;
		/*/ Position the arrow / */
		right: 20px;
		/*/ Adjust arrow to align with the popup /*/
		width: 0;
		height: 0;
		border-left: 10px solid transparent;
		/*/ Transparent left side /*/
		border-top: 10px solid #81bc73;
		/*/ Visible top side /*/
	}

	.popup .header {
		font-weight: 600;
		text-align: center;
		margin-bottom: 0;
		font-size: 14px;
	}

	.popup .headersp {
		padding-bottom: 5px;
		border-bottom: 1px solid;
	}

	.popup .row {
		display: contents;
	}

	.popup p {
		line-height: 1 !important;
		margin-bottom: 0;
		padding-bottom: 5px;
		color: #fff;
		font-weight: 600;
		font-size: 13px;
	}

	.popup ul {
		padding-left: 0;
		color: #fff;
		display: flex;
		flex-direction: column;
		/*/ Ensure vertical alignment /*/
		list-style: none;
	}

		.popup ul li {
			font-size: 14px;
			font-weight: 600;
			position: relative;
			margin-bottom: 0;
		}

			.popup ul li.first-email::before {
				content: "";
				position: absolute;
				left: 0;
				top: 50%;
				transform: translateY(-50%);
				width: 14px;
				height: 14px;
				background-color: transparent;
				border: 2px solid #fff;
				border-radius: 50%;
			}

			.popup ul li.first-email::after {
				content: "";
				width: 6px;
				height: 6px;
				background-color: #fff;
				border-radius: 50%;
				position: absolute;
				top: 50%;
				left: 7px;
				transform: translate(-50%, -50%);
			}

			.popup ul li.no-bullet,
			.popup ul li.delegator-section {
				padding-left: 0;
				list-style-type: none;
				margin-left: 0;
				/*/ Reset margin for left alignment /*/
			}

	/*/ Ensure alignment of items in the popup /*/
	.popup ul {
		padding-left: 0;
		color: #fff;
		display: flex;
		flex-direction: column;
		list-style: none;
	}

	@@media (max-width: 575px) {
		
		.nav-tabs .active {
			background-color: transparent !important;
			border: none !important;
			color: black !important;
			opacity: 1;
			border-bottom: 3px solid #acc33e !important;
		}
	}
	
	/* Enhanced responsive styles */
	@@media (max-width: 768px) {
		.card-body {
			padding: 1rem;
		}
		
		.common-heading-color {
			font-size: 1.25rem !important;
			margin-bottom: 1rem !important;
		}
		
		.nav-tabs {
			flex-direction: column;
			border-bottom: none;
			gap: 0.25rem;
		}
		
		.nav-tabs .nav-item {
			width: 100%;
		}
		
		.nav-tabs .nav-link {
			width: 100%;
			text-align: left;
			padding: 0.75rem 1rem;
			border-radius: 8px;
			background: #f8fafc;
			margin: 0 !important;
		}
		
		.nav-tabs .nav-link.active {
			background: linear-gradient(135deg, #10b981, #059669) !important;
			color: white !important;
			border: none !important;
		}
		
		.tab-content {
			padding: 0.75rem;
		}
		
		.popup {
			position: fixed !important;
			left: 50% !important;
			right: auto !important;
			top: 50% !important;
			bottom: auto !important;
			transform: translate(-50%, -50%) !important;
			max-width: calc(100vw - 2rem);
			z-index: 10001;
		}
		
		.popup::after {
			display: none;
		}
		
		.modal-dialog {
			margin: 0;
			max-width: 100%;
		}
		
		.modal-content {
			border-radius: 16px 16px 0 0;
			min-height: auto;
		}
	}
	
	@@media (max-width: 480px) {
		.card-body {
			padding: 0.75rem;
		}
		
		.common-heading-color {
			font-size: 1.125rem !important;
		}
		
		.nav-tabs .nav-link {
			font-size: 0.8125rem;
			padding: 0.625rem 0.75rem;
		}
	}
</style>

