<script>
	var loginEmail = '@userEmail';
	var loginorgUid = '@OrganizationUid';
	var loginSuid = '@Suid';
	var issent = '@issentpresent';
	$(document).ready(function () {
		$('#networkOverlay').hide();
		var viewName = '@ViewBag.ViewName';
		// if (viewName == "MyDocuments") {
		// 	myDocument();
		// }
		// else
		if (viewName == "SentDocuments") {
			// $("select.form-control").val("Send");
			sendDocument();
		} else if (viewName == "RecievedDocuments") {
			// $("select.form-control").val("recived");
			receivedDoc();
		}
		else if (viewName == "RefferedDocuments") {
			// $("select.form-control").val("reffered");
			refferedDoc();
		}
		else {
			if (issent === 'False') {
				// $("select.form-control").val("recived");
				receivedDoc();
			}
			else {
				// $("select.form-control").val("Send");
				sendDocument();
			}
		}
		$(".dropdown-toggle").dropdown();
	});

	// Set initial slider position and max-width
	updateSlider();

	$(".nav-tabs a").click(function () {
		var tabName = $(this).attr("aria-controls");
		activateTab(tabName);
		deleteList = [];
	});


	function updateSlider() {
		var $activeTab = $(".nav-tabs .nav-link.active");
		if ($activeTab.length === 0) return;

		var tabWidth = $activeTab.outerWidth();
		var textWidth = $activeTab[0].scrollWidth; // Get accurate text width
		var tabPosition = $activeTab.position();

		var sliderWidth = Math.min(textWidth + 20, 150); // Add padding but limit max-width to 150px

		if (tabPosition) {
			$(".slider").css({
				"left": tabPosition.left + (tabWidth / 2) - (sliderWidth / 2), // Center under text
				"width": sliderWidth + "px", // Dynamic width with max limit
				"max-width": "180px", // Maximum width constraint
				"transition": "left 0.3s ease-in-out, width 0.3s ease-in-out" // Smooth animation
			});
		}
	}


	// function changeTab(selectedTab) {
	// 	if (selectedTab === "Send") {
	// 		sendDocument();
	// 	} else if (selectedTab === "recived") {
	// 		receivedDoc();
	// 	} else if (selectedTab === "reffered") {
	// 		refferedDoc();
	// 	}
	// }


	function activateTab(tabName) {
		$(".RowCheckbox").prop('checked', false);
		$("#del").addClass('classshide');

		var $tab = $(`[aria-controls=${tabName}]`);
		if ($tab.length === 0) {
			return;
		}

		

		$(".nav-link").removeClass('active');

		// Add 'active' class to the current tab
		$tab.addClass('active');

		updateSlider();

		// Add 'show active' classes to the active tab content and remove from others
		$(`#${tabName}`).addClass('show active').siblings().removeClass('show active');

		// Add 'active-tab' class to the active tab and remove from others
		$(".nav-link").removeClass('active-tab');
		$tab.addClass('active-tab');
	}




	function myDocument() {
		const currentUrl = window.location.href.split('?')[0];
		const newUrl = `${currentUrl}?viewName=MyDocuments`;
		window.history.pushState(null, '', newUrl);

		$.ajax({
			type: 'GET',
			url: '@Url.Action("draft", "FormRequests")',
			beforeSend: function () {
				$('#overlay').show();
			},
			complete: function () {
				$('#overlay').hide();
			},
			error: ajaxErrorHandler,
			success: function (data) {
				
				if (data != null) {
					$('#sendDoc').css('display', 'none');
					$('#receiveDoc').css('display', 'none');

					$('#myDoc').css('display', 'block');

					
					$('#myDoc').html(data);
					activateTab('List');
				}
				else {
					swal({
						type: 'error',
						title: 'Error',
						text: response.message
					});
				}
			}


		});
	}

	function sendDocument() {
		const currentUrl = window.location.href.split('?')[0];
		const newUrl = `${currentUrl}?viewName=SentDocuments`;
		window.history.pushState(null, '', newUrl);
		$(".home-tab").removeClass('active');
		$.ajax({
			type: 'GET',
			url: '@Url.Action("sent", "FormRequests")',
			beforeSend: function () {
				$('#overlay').show();
			},
			complete: function () {
				$('#overlay').hide();
			},
			error: ajaxErrorHandler,
			success: function (data) {
				if (data != null) {
					$('#myDoc').css('display', 'none');
					$('#receiveDoc').css('display', 'none');
					$('#refferedDoc').css('display', 'none');

					$('#sendDoc').css('display', 'block');


					$('#sendDoc').html(data);
					activateTab('SendTb');
				}
				else {
					swal({
						type: 'error',
						title: 'Error',
						text: response.message
					});
				}
			}


		});
	}

	function receivedDoc() {
		const currentUrl = window.location.href.split('?')[0];
		const newUrl = `${currentUrl}?viewName=RecievedDocuments`;
		window.history.pushState(null, '', newUrl);
		$(".home-tab").removeClass('active');
		$.ajax({
			type: 'GET',
			url: '@Url.Action("recived", "FormRequests")',
			beforeSend: function () {
				$('#overlay').show();
			},
			complete: function () {
				$('#overlay').hide();
			},
			error: ajaxErrorHandler,
			success: function (data) {
				if (data != null) {
					$('#myDoc').css('display', 'none');
					$('#sendDoc').css('display', 'none');
					$('#refferedDoc').css('display', 'none');

					$('#receiveDoc').css('display', 'block');

					
					$('#receiveDoc').html(data);
					activateTab('RecvTb');
				}
				else {
					swal({
						type: 'error',
						title: 'Error',
						text: response.message
					});
				}
			}


		});
	}

	function refferedDoc() {
		const currentUrl = window.location.href.split('?')[0];
		const newUrl = `${currentUrl}?viewName=RefferedDocuments`;
		window.history.pushState(null, '', newUrl);
		$(".home-tab").removeClass('active');
		$.ajax({
			type: 'GET',
			url: '@Url.Action("reffered", "FormRequests")',
			beforeSend: function () {
				$('#overlay').show();
			},
			complete: function () {
				$('#overlay').hide();
			},
			error: ajaxErrorHandler,
			success: function (data) {
				if (data != null) {
					$('#myDoc').css('display', 'none');
					$('#sendDoc').css('display', 'none');
					$('#receiveDoc').css('display', 'none');

					$('#refferedDoc').css('display', 'block');
					$('#refferedDoc').html(data);
					activateTab('ReffTb');
				}
				else {
					swal({
						type: 'error',
						title: 'Error',
						text: response.message
					});
				}
			}


		});
	}
	function closemodal() {
		$("#digitalShowModal").modal('hide');
	}


</script>



