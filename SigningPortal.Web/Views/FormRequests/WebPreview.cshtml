@model SigningPortal.Web.ViewModels.DigitalForms.FillFormData;
@{
    var AccountType = User.FindFirst("AccountType").Value;
}

<link rel="stylesheet" href="/local-cdns/Shared/bootstrap/4.3.1/css/bootstrap.min.css">
<style>
    /* ========================================
           MODERN UI DESIGN SYSTEM - WebPreview
           Aligned with UsePdfForm.cshtml theme
           ======================================== */
    :root {
        --font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        --primary-green: #10b981;
        --primary-green-dark: #059669;
        --primary-green-light: #d1fae5;
        --accent-blue: #3b82f6;
        --accent-purple: #8b5cf6;
        --text-primary: #1e293b;
        --text-secondary: #64748b;
        --text-muted: #94a3b8;
        --bg-page: #f8fafc;
        --bg-card: #ffffff;
        --bg-section: #f7f8fa;
        --border-color: #e2e8f0;
        --border-light: #f1f5f9;
        --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        --radius-sm: 8px;
        --radius-md: 12px;
        --radius-lg: 16px;
        --radius-xl: 20px;
        --transition-fast: 150ms cubic-bezier(0.4, 0, 0.2, 1);
        --transition-base: 200ms cubic-bezier(0.4, 0, 0.2, 1);
        --transition-smooth: 300ms cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* ========================================
           Card & Container Styling
           ======================================== */
    .card.background-image {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 0px;
        box-shadow: var(--shadow-md);
    }

    .card-body {
        padding: 1.5rem;
    }

    .well.form-box {
        background: #ebedef !important;
        border-bottom: 1px solid var(--border-light);
        padding: 16px 24px;
        border-radius: var(--radius-md) var(--radius-md) 0 0;
        display: flex;
        align-items: center;
    }

        .well.form-box h4 {
            color: var(--text-primary);
            font-weight: 700;
            font-size: 1.25rem;
            margin: 0;
        }

    /* ========================================
           Editor Styling
           ======================================== */
    #editor {
        width: 100%;
        min-height: 100vh;
        height: 100vh;
        max-width: 210mm;
        background-color: var(--bg-card);
        border: 1px solid var(--border-color);
        margin: 0 auto;
        overflow: hidden;
        border-radius: var(--radius-sm);
        box-shadow: var(--shadow-sm);
    }

    .tool-button {
        width: 150px;
        padding: 10px 20px;
        color: #fff;
        border: none;
        border-radius: var(--radius-md);
        cursor: pointer;
        font-size: 16px;
        margin: 5px;
        transition: all var(--transition-base);
    }

    .option-wrapper {
        display: flex;
        align-items: center;
        margin-bottom: 8px;
    }

        .option-wrapper input {
            margin-right: 12px;
            flex: 1;
            border: 1.5px solid var(--border-color);
            border-radius: var(--radius-sm);
            padding: 8px 12px;
        }

        .option-wrapper button {
            margin-left: 8px;
        }

    .editor-block {
        height: 100vh;
        overflow-y: auto;
        padding: 3px;
    }

    .cdx-inline-tool-button {
        display: inline-flex;
        align-items: center;
    }

        .cdx-inline-tool-button select {
            margin-left: 8px;
        }

    /* ========================================
           Table Styling
           ======================================== */
    .table-container {
        overflow-x: auto;
        width: 100%;
        padding: 0;
        margin: 0;
        border-radius: 0;
    }

    .custom-table {
        width: 100%;
        table-layout: fixed;
        border-collapse: collapse;
    }

        .custom-table th,
        .custom-table td {
            border: 1px solid var(--border-color);
            padding: 12px;
            word-wrap: break-word;
            overflow-wrap: break-word;
            white-space: normal;
        }

        .custom-table th {
            font-weight: 600;
            background-color: var(--bg-section);
            color: var(--text-primary);
        }

        .custom-table td,
        .custom-table th {
            min-width: 100px;
            text-align: left !important;
        }

            .custom-table td[contenteditable="true"]:focus {
                background-color: rgba(16, 185, 129, 0.1);
                outline: 2px solid var(--primary-green);
            }

    .form-box {
        border: 1px solid var(--border-color);
        border-radius: var(--radius-md);
        padding: 12px;
        display: flex;
        justify-content: center;
        align-items: center;
        text-align: center;
    }

    .Common {
        background: none;
    }

    .Standard {
        background: var(--primary-green-light);
    }

    .button-content {
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        width: 100%;
    }

    /* ========================================
           Dropzone Styling
           ======================================== */
    .dropzone {
        border: 2px dashed var(--primary-green);
        border-radius: var(--radius-md);
        padding: 20px;
        text-align: center;
        cursor: pointer;
        margin-bottom: 20px;
        height: 80px;
        background-color: rgba(16, 185, 129, 0.05);
        color: var(--text-muted);
        transition: all var(--transition-base);
    }

        .dropzone:hover {
            background-color: rgba(16, 185, 129, 0.1);
            border-color: var(--primary-green-dark);
        }

        .dropzone p {
            margin: 0;
            font-size: 16px;
            color: var(--text-secondary);
        }

    /* ========================================
           Button Styling
           ======================================== */
    #save, #fill {
        background: linear-gradient(135deg, var(--primary-green) 0%, var(--primary-green-dark) 100%);
        color: white;
        padding: 0.5rem 1rem;
        border: none;
        border-radius: var(--radius-md);
        font-size: 0.9375rem;
        font-weight: 600;
        cursor: pointer;
        width: auto;
        min-width: 160px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        white-space: nowrap;
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3) !important;
        transition: all var(--transition-smooth);
        gap: 10px;
    }

        #save:hover, #fill:hover {
            background: linear-gradient(135deg, var(--primary-green-dark), #047857);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(16, 185, 129, 0.4) !important;
        }

    /* ========================================
           Radio & Form Elements
           ======================================== */
    .radio-block {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
    }

    .radio-label {
        margin-right: 12px;
        font-size: 16px;
        color: var(--text-primary);
    }

    .radio-options {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .radio-option {
        flex: 0 1 auto;
    }

    /* ========================================
           Navbar Styling
           ======================================== */
    .navbar {
        height: 60px;
        font-size: 15px;
        padding: 6px 10px;
        background-color: var(--bg-card) !important;
        padding-right: 10px;
        padding-left: 0px;
        color: var(--text-secondary);
        box-shadow: var(--shadow-sm);
        border: none;
        border-radius: 0;
        z-index: 1000;
    }

    .MuiAvatar-root {
        justify-content: unset !important;
    }

    .dropdown-menu {
        left: auto;
        right: 0px;
        min-width: 256px;
        height: max-content;
        position: absolute;
        z-index: 1000;
        display: none;
        float: left;
        list-style: none;
        text-shadow: none;
        padding: 20px;
        margin-top: 6px;
        background-color: var(--bg-card);
        font-family: var(--font-family);
        font-size: 15px;
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-lg);
        border: 1px solid var(--border-color);
    }

    .codex-editor__redactor {
        padding-bottom: 30px !important;
    }

    tbody tr td:first-child {
        text-align: center !important;
    }

    .dropdown-toggle::after {
        display: none;
    }

    /* ========================================
           Preview Container Layout
           ======================================== */
    .preview-container {
        border: 1px solid var(--border-color) !important;
        border-radius: var(--radius-md);
        overflow: hidden;
    }

    /* ========================================
           Responsive Adjustments
           ======================================== */
    @@media (max-width: 768px) {
        .card-body {
            padding: 1rem;
        }

        .well.form-box h4 {
            font-size: 1.1rem;
        }

        .preview-container {
            border-radius: 0;
        }

        .card.background-image {
            padding: 0 !important;
        }

        .well.form-box {
            padding: 0.75rem 1rem;
        }

        .well.form-box h4 {
            margin-left: 0 !important;
            font-size: 1rem;
        }

        #pdf-container {
            padding: 0.5rem;
        }

        .codex-editor__redactor {
            padding-bottom: 20px !important;
        }
    }

    @@media (max-width: 480px) {
        .card-body {
            padding: 0.5rem;
        }

        .well.form-box h4 {
            font-size: 0.9rem;
        }

        #pdf-container {
            padding: 0.25rem;
        }

        .ce-block__content {
            max-width: 100% !important;
        }
    }
</style>
<div class="row m-0">
    <div class="col-md-12 p-0" style="height:100vh">
        <div class="card background-image p-0 p-md-3 p-lg-4" style="height:100%">



            <div class="card-body" style="padding-top:0;height:100%">
                <div class="preview-container" style="padding:0;height:100%">

                    <div class="well form-box" style='display:flex; flex-flow:wrap;justify-content:space-between;width:100%;'>
                        <h4 style="margin-left:3%;margin-top:auto;margin-bottom:auto"><b>Preview</b></h4>
                    </div>


                    <div class="row" id="pdf-container" style="overflow-y:auto; height:92%;width:100%;margin-left:auto;margin-right:auto;justify-content:center;background:var(--bg-page)">
                    </div>
                </div>



            </div>




        </div>
    </div>


    <input type="hidden" id="pdfschema" name="pdfschema" value="@Model.htmlschma" />

</div>
</>
<script src="/local-cdns/Shared/editorjs/latest/editorjs.umd.min.js"></script>
<script src="/local-cdns/Shared/editorjs-header/latest/header.umd.min.js"></script>
<script src="/local-cdns/Shared/editorjs-list/latest/list.umd.min.js"></script>
<script src="/local-cdns/Shared/editorjs-checklist/latest/checklist.umd.min.js"></script>
<script src="/local-cdns/Shared/editorjs-image/latest/image.umd.min.js"></script>
<script src="/local-cdns/Shared/editorjs-paragraph/latest/paragraph.umd.min.js"></script>

<script src="/local-cdns/Shared/html2pdf/latest/html2pdf.bundle.min.js"></script>
<script src="/local-cdns/Shared/popper/1.14.7/popper.min.js"></script>
<script src="/local-cdns/Shared/bootstrap/4.3.1/js/bootstrap.min.js"></script>
<script src="/local-cdns/Shared/editorjs-drag-drop/latest/bundle.js"></script>
<script src="/local-cdns/Shared/editorjs-html/3.4.0/edjsHTML.js"></script>

@if (Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Development")
{
    <script src="~/js/FormRequests/WebPreview.js" type="text/javascript" asp-append-version="true" defer></script>
}
else
{
    <script src="~/dist/FormRequests/WebPreview.min.js" type="text/javascript" asp-append-version="true" defer></script>
}

