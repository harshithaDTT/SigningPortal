@model SigningPortal.Web.ViewModels.Templates.CreateTemplateViewModel
@inject IConfiguration Configuration
@using Newtonsoft.Json
@using System.Security.Claims;

@{
	var signData = "data:image/png;base64," + Model.Templates.FirstOrDefault(x => x.Id == 1).SamplePreview;
	var esealData = "data:image/png;base64," + Model.Templates.FirstOrDefault(x => x.Id == 5).SamplePreview;
}
@{
	await Html.RenderPartialAsync("_AlertBox");
}

@{

	var userEmail = User.FindFirst(ClaimTypes.Email).Value;
	var AccountType = User.FindFirst("AccountType").Value;
	var OrganizationName = "";
	var OrganizationUid = "";
	if (AccountType != "Self")
	{
		OrganizationName = User.FindFirst("OrganizationName").Value;
		OrganizationUid = User.FindFirst("OrganizationUid").Value;
	}
}


