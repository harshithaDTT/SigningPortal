									<option data-preview="@item.SamplePreview" value="@item.Id">@item.TemplateId</option>
								}
							</select>
							<i class="fa fa-chevron-down select-icon"></i>
						</div>
						<button type="button" id="SecondinnerModel" class="template-preview-btn" style="display:none;">
							<i class="fa fa-eye"></i>
						</button>
					</div>
				</div>

				@* Second Dropdown Slection For Eseal *@
