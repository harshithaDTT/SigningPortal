		.modern-modal__footer,
		.MuiDialog-paper .modal-footer {
			padding: 0.75rem 1.25rem;
			border-top: 1px solid var(--border-color);
			display: flex;
			justify-content: flex-end;
			gap: 12px;
		}

	.draggable {
		position: absolute;
		padding: 0.48%;
		cursor: move;
		background: rgba(0, 0, 0, 0);
	}

	.edit-icon {
		position: absolute;
		top: -18px;
		right: -18px;
		opacity: 0;
		transition: opacity 0.3s ease;
	}

		.edit-icon:hover {
			cursor: pointer !important;
		}

	.draggable:hover .edit-icon,
	.draggable:focus .edit-icon,
	.draggable.active .edit-icon {
		opacity: 1;
	}

	.resize-handle {
		position: absolute;
		width: 10px;
		height: 10px;
		border-radius: 10px;
		background-color: #4a90e2;
		z-index: 1000;
	}

	.bottom-right {
		bottom: -3px;
		right: -3px;
		cursor: nw-resize;
	}

	.top-right {
		top: -3px;
		right: -3px;
		cursor: ne-resize;
	}

	.bottom-left {
		bottom: -3px;
		left: -3px;
		cursor: ne-resize;
	}

	.top-left {
		top: -3px;
		left: -3px;
		cursor: nw-resize;
	}

	.classshide {
		display: none !important;
	}

	@@media (max-width: 991px) {
		.viewer-toolbar {
			flex-direction: column;
			align-items: stretch;
			padding: 10px 14px;
		}

		.toolbar-actions {
			width: 100%;
