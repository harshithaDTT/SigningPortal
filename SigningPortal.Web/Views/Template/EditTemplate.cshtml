	/* ============================================================
		   EDIT TEMPLATE SPECIFIC - Bulk List & Checkbox Overrides
		   ============================================================ */
	.signatory-cards-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 16px;
		padding: 4px;
	}

	@@media (max-width: 1200px) {
		.signatory-cards-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	@@media (max-width: 900px) {
		.signatory-cards-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@@media (max-width: 600px) {
		.signatory-cards-grid {
			grid-template-columns: 1fr;
		}
	}

	/* Handle ≤3 items - center them nicely */
	.signatory-cards-grid.few-items {
		grid-template-columns: repeat(auto-fit, minmax(240px, 300px));
		justify-content: center;
	}

	/* Individual Signatory Card - Horizontal Layout */
	.signer-card {
		position: relative;
		display: flex;
		flex-direction: row;
		align-items: center;
		padding: 12px 40px 12px 12px;
		background: var(--bg-card);
		border: 1px solid var(--border-color);
		border-radius: var(--radius-md);
		cursor: pointer;
		transition: all 0.2s ease;
		box-shadow: none;
		text-align: left;
		min-height: auto;
		gap: 12px;
		max-width: 300px;
	}

		.signer-card:hover {
			transform: translateY(-2px);
		}

		.signer-card.selected {
			background: #E2EFEB;
			border: 0.5px solid #cccccc;
			box-shadow: 0 2px 6px rgba(0,0,0,0.04);
		}
	/* Checkbox Indicator - Top Right */
	.signer-card__checkbox {
		position: absolute;
		top: 10px;
		right: 10px;
		width: 18px;
		height: 18px;
		border-radius: 50%;
		border: 2px solid #cccccc;
		background: #fff;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.2s ease;
	}

	.signer-card.selected .signer-card__checkbox {
		border-color: #0D7F5C;
	}

		.signer-card.selected .signer-card__checkbox::after {
			content: '';
			width: 10px;
			height: 10px;
			border-radius: 50%;
			background: #0a7d5c;
		}



	/* Hidden Checkbox Input */
	.signer-card input[type="checkbox"] {
		position: absolute;
		opacity: 0;
		width: 0;
		height: 0;
	}

	/* Profile Avatar - 40px circular */
	.signer-card__avatar {
		width: 40px;
		height: 40px;
		border-radius: 50%;
		position: relative;
		flex-shrink: 0;
	}

	.signer-card__avatar-img {
		width: 100%;
		height: 100%;
		border-radius: 50%;
		border: 2px solid #e0e7ff;
		background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
		display: none;
		object-fit: cover;
	}

	.signer-card.selected .signer-card__avatar-img {
		border-color: #0D7F5C;
	}

	.signer-card__avatar-loader {
		width: 100%;
		height: 100%;
		border-radius: 50%;
		border: 2px solid #f3f3f3;
		border-top: 2px solid #3b82f6;
		animation: spin 1s linear infinite;
	}

	.signer-card__avatar-fallback {
		width: 100%;
		height: 100%;
		border-radius: 50%;
		background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);
		border: 2px solid #e0e7ff;
		display: none;
		align-items: center;
		justify-content: center;
		font-weight: 600;
		font-size: 0.875rem;
		color: #6366f1;
		text-transform: uppercase;
	}

	.signer-card.selected .signer-card__avatar-fallback {
		border-color: #93c5fd;
		background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
	}

	@@keyframes spin {
		0% {
			transform: rotate(0deg);
		}

		100% {
			transform: rotate(360deg);
		}
	}

	/* Info Container - Stacked Name & Email */
	.signer-card__info {
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
		flex: 1;
	}

	/* Name & Email */
	.signer-card__name {
		font-size: 0.75rem;
		font-weight: 600;
		color: #0F172A;
		line-height: 1.3;
		max-width: 100%;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.signer-card.selected .signer-card__name {
		color: #0F172A;
		font-weight: 600;
	}

	.signer-card__email {
		font-size: 0.75rem;
		color: #64748B;
		max-width: 100%;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	/* Hide legacy bulk elements */
	.bulk-list {
		display: none;
	}

	.card-content {
		overflow-y: auto;
	}

	#thumbnail img {
		height: 138px;
		width: 138px;
	}

	.recp {
		margin-bottom: 20px;
	}

	.drag-ghost {
		width: 120px;
		height: 60px;
		background-color: #d8d7d78a;
		border: 2px dashed thick;
		border-color: #44aad1;
		display: none;
		color: #44aad1;
		position: absolute;
		font-size: 12px;
		text-align: center;
	}

	#fieldsRecpRpw {
		display: none !important;
	}

	#emailList {
		display: none !important;
	}

	@@media screen and (min-width:992px) {
		#sidebarCollapse1 {
			display: none !important;
		}

		#sidebarCollapsefield {
			display: block !important;
		}

		#sidebarCollapse2 {
			display: none !important;
		}

		#sidebarCollapseSignatories {
			display: block !important;
		}

		#fieldsRecpRpw {
			display: flex !important;
		}

		#emailList {
			display: block !important;
		}
	}
</style>



<div class="page-container" id="create">
	@Html.AntiForgeryToken()
	<div class="page-header">
		<div class="page-header-content">
			<h1 class="page-title">Edit Template</h1>
			<p class="page-subtitle">Update your document template configuration and BulkSign recipients.</p>
		</div>
		<div class="step-indicator">
			<span class="step-indicator__current">1</span>
			<span class="step-indicator__text">Step 1</span>
			<span class="step-indicator__total">of 2</span>
			<span class="step-indicator__divider"></span>
			<span class="step-indicator__label">Configure</span>
		</div>
	</div>

	<div class="template-layout">
		<div class="details-card" id="detailsStepCard">

			<!-- Template Details Section - Flat form layout -->
			<div class="form-section">
				<div class="section-header">
					<i class="fa fa-clipboard-list"></i>
					Template Details
				</div>
				<div class="form-grid">
					<div class="form-group">
						<label asp-for="TemplateName" class="form-label">Template Name <span class="required">*</span></label>
						<input asp-for="TemplateName" class="form-control" readonly placeholder="Enter a descriptive template name" />
					</div>
					<div class="form-group">
						<label asp-for="DocumentName" class="form-label">Document Name <span class="required">*</span></label>
						<input asp-for="DocumentName" class="form-control" readonly placeholder="Auto-populated from uploaded file" />
					</div>
				</div>

			</div>

			<!-- Document Preview Section (PDF already uploaded - not editable) -->
			<div class="form-section">
				<div class="section-header">
					<i class="fa fa-file-alt"></i>
					Document Preview
				</div>
				<div id="thumbnail" style="display: flex; align-items: center; gap: 12px; padding: 12px; border: 1px solid var(--border-color); border-radius: var(--radius-md); background: var(--bg-section);">
					<img src='@Url.Content("~/img/icon/document-signature.png")' asp-append-version="true" style="height: 64px; width: 64px;">
					<div>
						<p style="margin: 0; font-weight: 500; color: var(--text-primary);">@Model.DocumentName</p>
						<p style="margin: 0; font-size: 0.8125rem; color: var(--text-secondary);">Document already uploaded (read-only)</p>
					</div>
				</div>
			</div>

			<!-- BulkSign Signatories Section -->
			<div class="bulk-panel">
				<div class="bulk-panel__header">
					<span class="panel-title">
						<i class="fa fa-users"></i>
						BulkSign Signatories
					</span>
					<span class="selection-hint">Select one signatory</span>
					<span class="required" style="color:#ef4444">*</span>
				</div>

				@if (Model.bulkSignerEmails == null || Model.bulkSignerEmails.bulkSignerList.Count == 0)
				{
					<div class="bulk-empty">
						<i class="fa fa-user-slash"></i>
						<p>No signatories available</p>
					</div>
				}
				else
				{
					var emailCount = Model.bulkSignerEmails.bulkSignerList.Count;
					<div class="signatory-cards-grid @(emailCount <= 3 ? "few-items" : "")" id="signatoryCardsContainer">
						@foreach (var email in Model.bulkSignerEmails.bulkSignerList)
						{
							var initials = email.Length >= 2 ? email.Substring(0, 2).ToUpper() : email.Substring(0, 1).ToUpper();
							<label class="signer-card" data-email="@email">
								<input type="checkbox" name="selectedSignatories" class="select-checkbox" data-email="@email" value="@email" />
								<span class="signer-card__checkbox"></span>
								<div class="signer-card__avatar" data-email="@email">
									<div class="signer-card__avatar-loader" data-loader="@email"></div>
									<img class="signer-card__avatar-img" data-img="@email" alt="Profile" />
									<div class="signer-card__avatar-fallback" data-fallback="@email">@initials</div>
								</div>
								<div class="signer-card__info">
									<span class="signer-card__name" data-name="@email">@email</span>
									<span class="signer-card__email" title="@email">@email</span>
								</div>
							</label>
						}
					</div>
				}
			</div>

			<!-- Advanced Settings Card Section (matching CreateTemplateNew) -->
			<div class="settings-section" id="settingsCardsSection">
				<div class="settings-card">
					<div class="settings-card__header">
						<h3 class="settings-card__title">
							<i class="fa fa-sliders-h"></i>
							Advanced Settings
						</h3>
					</div>

					<div class="settings-card__body">
						<!-- E-Seal Toggle -->
						<div class="settings-field-group">
							<label class="settings-field-label">E-Seal Option</label>
							<div class="settings-toggle-row">
								<label class="settings-toggle-label">Enable E-Seal</label>
								<button type="button" class="toggle-switch" id="esealToggle">
									<span class="toggle-switch__thumb"></span>
								</button>
							</div>
						</div>

						<!-- Signature Templates -->
						<div class="settings-field-group">
							<label class="settings-field-label">Signature Templates <span class="label-hint">(Optional)</span></label>
							<div class="template-select-container">
								<div class="select-wrapper">
									<select id="templateSelect" name="TemplateName" class="form-select" aria-label="Select signature template">
										<option value="0">Choose Template</option>
										@foreach (var item in Model.Templates.Where(x => x.Type.ToLower() == "sign"))
										{
											<option data-preview="@item.SamplePreview" value="@item.Id">@item.DisplayName</option>
										}
									</select>
									<i class="fa fa-chevron-down select-icon"></i>
								</div>
								<button type="button" id="templatePreviewBtn" class="template-preview-btn" style="display:none">
									<i class="fa fa-eye"></i>
								</button>
							</div>
						</div>

						<!-- E-Seal Templates (shown when E-Seal is enabled) -->
						<div class="settings-field-group" id="esealTemplatesGroup" style="display: none;">
							<label class="settings-field-label">E-Seal Templates <span class="label-hint">(Optional)</span></label>
							<div class="template-select-container">
								<div class="select-wrapper">
									<select id="EsealtemplateSelect" name="EsealTemplateName" class="form-select" aria-label="Select e-seal template">
										<option value="0">Choose Template</option>
										@foreach (var item in Model.Templates.Where(x => x.Type.ToLower() == "eseal"))
										{
											<option data-preview="@item.SamplePreview" value="@item.Id">@item.DisplayName</option>
										}
									</select>
									<i class="fa fa-chevron-down select-icon"></i>
								</div>
								<button type="button" id="esealTemplatePreviewBtn" class="template-preview-btn" style="display:none">
									<i class="fa fa-eye"></i>
								</button>
							</div>
						</div>

						<!-- QR Code Option -->
						<div class="settings-field-group d-none">
							<div class="settings-toggle-row">
								<label class="settings-toggle-label">QR Code Required</label>
								<button type="button" class="toggle-switch" id="qrcodeToggle">
									<span class="toggle-switch__thumb"></span>
								</button>
							</div>
						</div>
					</div>
				</div>
			</div>

			<div class="action-footer card-actions">
				<button type="button" id="Continue" class="btn-success-dark">Continue</button>
			</div>
		</div>
	</div>

	<div id="recplist" style="display:none;">
		<div class="row">
			<div class="col-md-4" style="visibility: hidden;"><label><span>Selected Email</span></label></div>
			<div class="col-md-1" style="margin:0px;  visibility: hidden;"><label><span>Eseal</span></label></div>
			<div class="col-md-1" style="margin:0px;  visibility: hidden;"><label><span>QrCode</span></label></div>
		</div>
		<div class="row recp" id="0">
			<div class="col-md-12">
				<div class="row">
					<div class="col-md-4 margin" style="visibility: hidden;">
						<input class="form-control email" type="text" data-val="true" data-val-regex="Please enter valid email" data-val-required="The Email field is required." id="RecpientList_0__Email" name="RecpientList[0].Email" value="" autocomplete="off">
						<span class="text-danger classshide">Please enter valid E-Mail address</span>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<!-- WebViewer part -->
<div class="viewer-shell classshide" id="viwer">
	<div class="viewer-flex-container">
		<div class="viewer-left" id="viewerdivtag">
			<div class="viewer-toolbar" id="viewerToolbar">
				<div class="toolbar-info">
					<i class="fa fa-arrows-alt"></i>
					Drag, drop, and resize annotations directly on the document pages.
				</div>
				<div class="toolbar-actions">
					<div class="zoom-controls">
						<button type="button" class="toolbar-btn" id="zoomOutBtn">
							<i class="fa fa-search-minus"></i>
						</button>
						<span id="zoomDisplay">100%</span>
						<button type="button" class="toolbar-btn" id="zoomInBtn">
							<i class="fa fa-search-plus"></i>
						</button>
						<button type="button" class="toolbar-btn" id="resetZoomBtn">Reset</button>
					</div>

					<div class="page-controls">
						<button type="button" class="toolbar-btn" id="pagePrevBtn">
							<i class="fa fa-chevron-up"></i>
						</button>
						<span id="pageIndicator">Page 0 / 0</span>
						<button type="button" class="toolbar-btn" id="pageNextBtn">
							<i class="fa fa-chevron-down"></i>
						</button>
					</div>
				</div>
			</div>
			<div id="scrollContainer">
				<div id="pdf-container"></div>
			</div>
