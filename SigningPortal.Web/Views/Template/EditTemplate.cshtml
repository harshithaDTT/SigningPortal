					</div>
				</div>

				@* Dropdown Selection For Signature *@
				<div class="form-group" id="SignatureTemp" style="display:none">
					<label class="form-label">Signature Templates</label>
					<div class="template-select-row">
						<div class="select-wrapper">
							<select name="TemplateName" id="signaturetemplateSelect" class="form-select" aria-label="Select signature template">
								<option value="0">Choose Template</option>
								@foreach (var item in Model.Templates.Where(x => x.Type.ToLower() == "sign"))
								{
									<option data-preview="@item.SamplePreview" value="@item.Id">@item.DisplayName</option>
								}
							</select>
							<i class="fa fa-chevron-down select-icon"></i>
						</div>
						<button type="button" id="innerModel" class="template-preview-btn" style="display:none;">
							<i class="fa fa-eye"></i>
						</button>
					</div>
				</div>

				@* Dropdown Slection For Eseal *@
				<div class="form-group my-1" id="esealTemplates" style="display:none;">
					<label class="form-label">Eseal Templates</label>
					<div class="template-select-row">
						<div class="select-wrapper">
							<select name="EsealTemplateName" id="EsealtemplateSelect" class="form-select" aria-label="Select eseal template">
								<option value="0">Choose Template</option>
								@foreach (var item in Model.Templates.Where(x => x.Type.ToLower() == "eseal"))
								{
									<option data-preview="@item.SamplePreview" value="@item.Id">@item.DisplayName</option>
								}
							</select>
							<i class="fa fa-chevron-down select-icon"></i>
						</div>
						<button type="button" id="EsealInnerModel" class="template-preview-btn" style="display:none;">
							<i class="fa fa-eye"></i>
						</button>
					</div>
				</div>

				@* Second Dropdown Slection For Signature *@
				<div class="form-group" id="SecondSignatureTemp" style="display:none">
					<label class="form-label">Signature Templates</label>
					<div class="template-select-row">
						<div class="select-wrapper">
							<select name="TemplateName" id="SecndsignaturetemplateSelect" class="form-select" aria-label="Select signature template">
								<option value="0">Choose Template</option>
