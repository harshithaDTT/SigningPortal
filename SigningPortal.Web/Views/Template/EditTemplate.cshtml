						<button type="button" id="SecondEsealInnerModel" class="template-preview-btn" style="display:none;">
							<i class="fa fa-eye"></i>
						</button>
					</div>
				</div>
			</div>

			<div class="modern-modal__footer">
				<button type="button" id="clearbutton" class="btn-outline" style="border-color:#dc2626;color:#dc2626;">Clear</button>
				<button type="button" id="OKbutton" class="btn-success-dark" style="padding:10px 22px;">OK</button>
			</div>
		</div>
	</div>
</div>


