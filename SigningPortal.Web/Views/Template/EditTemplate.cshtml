@using Newtonsoft.Json
@model SigningPortal.Web.ViewModels.Templates.EditTemplateViewModel
@inject IConfiguration Configuration
@using System.Security.Claims;

@{
	var signData = "0";
	var esealData = "0";
	if (Model.SignatureTemplate != 0)
	{
		signData = "data:image/png;base64," + Model.Templates.FirstOrDefault(x => x.Id == Model.SignatureTemplate).SamplePreview;

	}
	if (Model.EsealSignatureTemplate != 0)
	{
		esealData = "data:image/png;base64," + Model.Templates.FirstOrDefault(x => x.Id == Model.EsealSignatureTemplate).SamplePreview;
	}

}

@{
	var signImage = "data:image/png;base64," + Model.Templates.FirstOrDefault(x => x.Id == 1).SamplePreview;
	var esealImage = "data:image/png;base64," + Model.Templates.FirstOrDefault(x => x.Id == 5).SamplePreview;
}
@{

	var userEmail = User.FindFirst(ClaimTypes.Email).Value;
	var AccountType = User.FindFirst("AccountType").Value;
	var OrganizationName = "";
	var OrganizationUid = "";
	if (AccountType != "Self")
	{
		OrganizationName = User.FindFirst("OrganizationName").Value;
		OrganizationUid = User.FindFirst("OrganizationUid").Value;
	}
}

@{
	await Html.RenderPartialAsync("_AlertBox");
}

<style>
	:root {
		--font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
		--primary-blue: #2563eb;
		--primary-purple: #7c3aed;
		--accent-green: #10b981;
		--dark-green: #16a34a;
		--text-primary: #0f172a;
		--text-secondary: #64748b;
		--text-muted: #94a3b8;
		/* Refined surface colors for better hierarchy - matching CreateDocumentsNew */
		--bg-page: #f5f7fa;
		--bg-page-alt: #eef1f6;
		--bg-card: #ffffff;
		--bg-section: #fafbfc;
		--bg-section-alt: #f8f9fb;
		--bg-light-blue: #f0f9ff;
		--bg-light-green: #ecfdf3;
		--bg-muted: #f1f3f7;
		--border-color: #e2e8f0;
		--border-light: #edf0f4;
		--border-section: #dfe3e8;
		--shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.04);
		--shadow-md: 0 4px 12px -2px rgba(0, 0, 0, 0.08);
		--shadow-lg: 0 8px 24px -4px rgba(0, 0, 0, 0.1);
		--shadow-xl: 0 16px 40px -8px rgba(0, 0, 0, 0.12);
		--shadow-section: 0 1px 3px rgba(0, 0, 0, 0.04), 0 1px 2px rgba(0, 0, 0, 0.02);
		--radius-sm: 8px;
		--radius-md: 12px;
		--radius-lg: 16px;
		--radius-xl: 20px;
		--template-shell-vh: 100vh;
	}

	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	body {
		font-family: var(--font-family);
		background: var(--bg-page);
		color: var(--text-primary);
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	.page-container {
		margin: 0;
		padding: clamp(0.75rem, 2vh, 1.5rem) 1rem;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		gap: clamp(1rem, 2vh, 1.5rem);
		background: #f1f5f9;
	}

	.page-header {
		text-align: left;
		flex-shrink: 0;
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 16px;
		flex-wrap: wrap;
		margin-bottom: 0.5rem;
	}

	.page-header-content {
		flex: 1;
		min-width: 0;
	}

	.page-title {
		font-size: 1.75rem;
		font-weight: 700;
		color: var(--text-primary);
		margin-bottom: 6px;
		letter-spacing: -0.025em;
		line-height: 1.2;
	}

	.page-subtitle {
		font-size: 0.9375rem;
		color: var(--text-secondary);
		line-height: 1.5;
		margin-top: 0;
	}

	.step-indicator {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 8px 16px;
		background: var(--bg-section);
		border: 1px solid var(--border-light);
		border-radius: var(--radius-md);
		font-size: 0.8125rem;
		font-weight: 500;
		color: var(--text-secondary);
		flex-shrink: 0;
		box-shadow: var(--shadow-sm);
	}

	.step-indicator__current {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 24px;
		height: 24px;
		background: linear-gradient(135deg, var(--primary-blue) 0%, var(--primary-purple) 100%);
		color: #ffffff;
		border-radius: 50%;
		font-weight: 600;
		font-size: 0.75rem;
	}

	.step-indicator__text {
		color: var(--text-primary);
		font-weight: 600;
	}

	.step-indicator__total {
		color: var(--text-muted);
	}

	.step-indicator__divider {
		width: 1px;
		height: 16px;
		background: var(--border-color);
		margin: 0 4px;
	}

	.step-indicator__label {
		color: var(--text-secondary);
		font-weight: 500;
	}

	.viewer-step-indicator {
		justify-content: center;
		margin-bottom: 12px;
		border: 1px solid #e5e7eb;
	}

	.template-layout {
		display: flex;
		flex-direction: column;
		gap: 0;
		min-height: calc(var(--template-shell-vh) - 260px);
	}

	.template-upload-screen {
		max-width: 860px;
		margin-left: 1rem;
	}

	.template-prepare-screen {
		margin-top: 0;
	}

	.disabled-blur {
		opacity: 0.6;
		cursor: not-allowed;
	}

		.disabled-blur:disabled {
			cursor: not-allowed;
		}

	/* Storage card for upload screen only */
	.storage-card {
		background: var(--bg-card);
		border: 1px solid var(--border-section);
		border-radius: var(--radius-xl);
		padding: clamp(1.5rem, 2.5vh, 1.75rem);
		box-shadow: var(--shadow-md);
		display: flex;
		flex-direction: column;
		min-height: calc(100vh - 220px);
		height: 100%;
		overflow: visible;
	}

	/* Details card is the main form container - flatter, section-based design */
	.details-card {
		background: transparent;
		border: none;
		border-radius: 0;
		box-shadow: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		min-height: auto;
		height: auto;
	}

	/* Section container for form areas */
	.form-section {
		background: var(--bg-card);
		border: 1px solid var(--border-section);
		border-radius: var(--radius-lg);
		padding: 20px 24px;
		box-shadow: var(--shadow-section);
	}

	.card-header {
		display: flex;
		align-items: flex-start;
		gap: clamp(0.75rem, 1.5vw, 1rem);
		margin-bottom: clamp(1rem, 2vh, 1.25rem);
		flex-shrink: 0;
	}

	.card-icon {
		width: 44px;
		height: 44px;
		background: linear-gradient(135deg, #dbeafe 0%, #e0e7ff 100%);
		border-radius: var(--radius-md);
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		color: var(--primary-blue);
		font-size: 20px;
	}

		.card-icon i {
			font-size: 22px;
			color: var(--primary-blue);
		}

	.card-title {
		font-size: 1.125rem;
		font-weight: 600;
		color: var(--text-primary);
		line-height: 1.3;
		margin-bottom: 4px;
	}

	.card-description {
		font-size: 0.8125rem;
		color: var(--text-secondary);
		line-height: 1.5;
		margin-top: 0;
	}

	.dropzone {
		border: 2px dashed var(--border-color);
		border-radius: var(--radius-lg);
		padding: clamp(1.5rem, 4vh, 2.5rem) clamp(1rem, 3vw, 2rem);
		text-align: center;
		background: var(--bg-section);
		cursor: pointer;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.02);
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 16px;
		justify-content: center;
		min-height: 0;
		overflow: visible;
	}

		.dropzone:hover,
		.dropzone.dragover {
			border-color: var(--primary-blue);
			background: #f8fbff;
			box-shadow: inset 0 0 0 1px rgba(59, 130, 246, 0.1), 0 4px 12px rgba(59, 130, 246, 0.08);
		}

	.dropzone-icon {
		width: clamp(64px, 10vh, 84px);
		height: clamp(64px, 10vh, 84px);
		border-radius: 50%;
		background: linear-gradient(135deg, #DBEAFE 0%, #E0E7FF 100%);
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--primary-blue);
		font-size: 34px;
		box-shadow: 0 6px 24px rgba(37, 99, 235, 0.2);
		flex-shrink: 0;
	}

	.dropzone-title {
		font-size: 1.15rem;
		font-weight: 600;
		color: var(--text-primary);
		letter-spacing: -0.01em;
	}

	.dropzone-subtitle {
		color: var(--text-secondary);
		font-size: 0.9375rem;
		line-height: 1.5;
	}

	.btn-primary {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 13px 26px;
		background: linear-gradient(90deg, #3B82F6 0%, #8B5CF6 100%);
		color: white;
		border: none;
		border-radius: var(--radius-md);
		font-size: 0.9375rem;
		font-weight: 600;
		cursor: pointer;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		box-shadow: 0 4px 14px rgba(59, 130, 246, 0.3);
	}

		.btn-primary:hover {
			transform: translateY(-2px);
			box-shadow: 0 6px 20px rgba(59, 130, 246, 0.4);
		}

		.btn-primary:active {
			transform: translateY(0);
		}

	.file-support-text {
		font-size: 0.8125rem;
		color: var(--text-muted);
		margin-top: 8px;
	}

		.file-support-text strong {
			color: var(--text-secondary);
		}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		border: 0;
	}

	.section-toggle {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 16px;
		flex-wrap: wrap;
		flex: 1;
	}

	@@media (min-width: 768px) {
		.section-toggle {
			align-items: center;
			flex-wrap: nowrap;
		}
	}

	.change-document-btn {
		border: 1px solid #d1d5db;
		background: #ffffff;
		color: #2563eb;
		padding: 8px 16px;
		border-radius: 8px;
		font-weight: 600;
		font-size: 0.8125rem;
		cursor: pointer;
		transition: all 0.15s ease;
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
		display: inline-flex;
		align-items: center;
		gap: 6px;
		white-space: nowrap;
	}

		.change-document-btn:hover {
			border-color: #3b82f6;
			color: #1d4ed8;
			background: #eff6ff;
			box-shadow: 0 2px 4px rgba(59, 130, 246, 0.1);
			transform: translateY(-1px);
		}

		.change-document-btn:active {
			transform: translateY(0);
		}

	@@media (max-width: 991px) {
		.template-layout {
			grid-auto-rows: auto;
			min-height: auto;
		}

		.storage-card {
			height: auto;
		}
	}

	.btn-remove {
		padding: 10px 22px;
		border-radius: 999px;
		border: 1px solid #dc2626;
		background: rgba(220, 38, 38, 0.1);
		color: #b91c1c;
		font-weight: 600;
		cursor: pointer;
		transition: all 0.2s ease;
	}

		.btn-remove:hover {
			background: #fee2e2;
			box-shadow: 0 6px 16px rgba(220, 38, 38, 0.2);
		}

	/* Form Section Header - flatter design matching CreateDocumentsNew */
	.section-header {
		display: flex;
		align-items: center;
		gap: 10px;
		font-size: 0.9375rem;
		font-weight: 700;
		color: var(--text-primary);
		margin-bottom: 16px;
		padding-bottom: 12px;
		border-bottom: 1px solid var(--border-light);
	}

		.section-header i {
			color: #6366F1;
			font-size: 14px;
		}

	.form-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 20px;
		background: var(--bg-card);
		border: none;
		padding: 0px;
		box-shadow: none;
	}

	@@media (max-width: 768px) {
		.form-grid {
			grid-template-columns: 1fr;
			padding: 0;
		}
	}

	.form-group {
		display: flex;
		flex-direction: column;
		gap: 8px;
		margin-bottom: 0;
	}

	.form-label,
	.col-form-label {
		display: block;
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--text-primary);
		margin-bottom: 0;
		letter-spacing: 0.01em;
	}

		.form-label .required {
			color: #ef4444;
			margin-left: 3px;
			font-weight: 500;
		}

	.form-control,
	.form-input {
		width: 100%;
		padding: 12px 16px;
		background: var(--bg-card);
		border: 1px solid var(--border-color);
		border-radius: var(--radius-sm);
		font-size: 0.9375rem;
		color: var(--text-primary);
		transition: all 0.3s ease;
		box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.04);
	}

		.form-control:focus,
		.form-input:focus {
			outline: none;
			border-color: var(--primary-blue);
			box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
			background: #ffffff;
		}

		.form-control:read-only,
		.form-input:read-only {
			background: var(--bg-section);
			color: var(--text-secondary);
			cursor: not-allowed;
		}

		.form-control::placeholder,
		.form-input::placeholder {
			color: var(--text-muted);
		}

	.text-danger {
		font-size: 0.8rem;
	}

	/* ========================================
					   BULK SIGNATORIES SECTION - Modern Card Grid
					   ======================================== */
	.bulk-panel {
		background: var(--bg-card);
		border: 1px solid var(--border-section);
		border-radius: var(--radius-lg);
		padding: 20px 24px;
		display: flex;
		flex-direction: column;
		gap: 16px;
		box-shadow: var(--shadow-section);
	}

	.bulk-panel__header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		padding-bottom: 12px;
		border-bottom: 1px solid var(--border-light);
		flex-wrap: wrap;
	}

	.panel-title {
		display: flex;
		align-items: center;
		gap: 10px;
		font-size: 0.9375rem;
		font-weight: 700;
		color: var(--text-primary);
		margin: 0;
	}

		.panel-title i {
			color: #6366F1;
			font-size: 14px;
		}

	.required-pill {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		padding: 5px 12px;
		border-radius: 999px;
		background: rgba(239, 68, 68, 0.12);
		color: #b91c1c;
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.selection-hint {
		font-size: 0.8125rem;
		color: var(--text-muted);
		font-weight: 400;
		margin-left: auto;
	}

	.bulk-empty {
		padding: 40px 20px;
		border-radius: 14px;
		background: var(--bg-section);
		text-align: center;
		color: var(--text-secondary);
		font-weight: 500;
		border: 1px dashed var(--border-color);
	}

		.bulk-empty i {
			font-size: 2.5rem;
			color: var(--text-muted);
			margin-bottom: 12px;
			display: block;
		}

		.bulk-empty p {
			margin: 0;
			font-size: 0.9375rem;
		}

	/* ========================================
					   SIGNATORY CARDS GRID - Compact Horizontal Layout
					   ======================================== */
	.signatory-cards-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 16px;
		padding: 4px;
	}

	@@media (max-width: 1200px) {
		.signatory-cards-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	@@media (max-width: 900px) {
		.signatory-cards-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@@media (max-width: 600px) {
		.signatory-cards-grid {
			grid-template-columns: 1fr;
		}
	}

	/* Handle ≤3 items - center them nicely */
	.signatory-cards-grid.few-items {
		grid-template-columns: repeat(auto-fit, minmax(240px, 300px));
		justify-content: center;
	}

	/* Individual Signatory Card - Horizontal Layout */
	.signer-card {
		position: relative;
		display: flex;
		flex-direction: row;
		align-items: center;
		padding: 12px 40px 12px 12px;
		background: var(--bg-card);
		border: 1px solid var(--border-color);
		border-radius: var(--radius-md);
		cursor: pointer;
		transition: all 0.2s ease;
		box-shadow: none;
		text-align: left;
		min-height: auto;
		gap: 12px;
		max-width: 300px;
	}

		.signer-card:hover {
			transform: translateY(-2px);
		}

		.signer-card.selected {
			background: #E2EFEB;
			border: 0.5px solid #cccccc;
			box-shadow: 0 2px 6px rgba(0,0,0,0.04);
		}

	/* Profile Avatar - 40px circular */
	.signer-card__avatar {
		width: 40px;
		height: 40px;
		border-radius: 50%;
		position: relative;
		flex-shrink: 0;
	}

	.signer-card__avatar-img {
		width: 100%;
		height: 100%;
		border-radius: 50%;
		border: 2px solid #e0e7ff;
		background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
		display: none;
		object-fit: cover;
	}

	.signer-card.selected .signer-card__avatar-img {
		border-color: #0D7F5C;
	}

	.signer-card__avatar-loader {
		width: 100%;
		height: 100%;
		border-radius: 50%;
		border: 2px solid #f3f3f3;
		border-top: 2px solid #3b82f6;
		animation: spin 1s linear infinite;
	}

	.signer-card__avatar-fallback {
		width: 100%;
		height: 100%;
		border-radius: 50%;
		background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);
		border: 2px solid #e0e7ff;
		display: none;
		align-items: center;
		justify-content: center;
		font-weight: 600;
		font-size: 0.875rem;
		color: #6366f1;
		text-transform: uppercase;
	}

	.signer-card.selected .signer-card__avatar-fallback {
		border-color: #93c5fd;
		background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
	}

	@@keyframes spin {
		0% {
			transform: rotate(0deg);
		}

		100% {
			transform: rotate(360deg);
		}
	}

	/* Info Container - Stacked Name & Email */
	.signer-card__info {
		display: flex;
		flex-direction: column;
		gap: 2px;
		min-width: 0;
		flex: 1;
	}

	/* Name & Email */
	.signer-card__name {
		font-size: 0.75rem;
		font-weight: 600;
		color: #0F172A;
		line-height: 1.3;
		max-width: 100%;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.signer-card.selected .signer-card__name {
		color: #0F172A;
		font-weight: 600;
	}

	.signer-card__email {
		font-size: 0.75rem;
		color: #64748B;
		max-width: 100%;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	/* Hide signer label completely */
	.signer-card__label {
		display: none;
	}

	/* Legacy bulk-list for backward compatibility */
	.bulk-list {
		display: none;
	}

	/* Legacy signatory-tiles hidden */
	.signatory-tiles {
		display: none;
	}

	/* Template Select Row */
	.template-select-row {
		display: flex;
		align-items: center;
		gap: 12px;
	}

		.template-select-row .select-wrapper {
			position: relative;
			flex: 1;
			background: #fff;
			border: 1px solid var(--border-color);
			border-radius: 12px;
			height: 44px;
			overflow: hidden;
			transition: all 0.2s ease;
			box-shadow: var(--shadow-sm);
		}

			.template-select-row .select-wrapper:focus-within {
				border-color: var(--primary-blue);
				box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
			}

		.template-select-row .form-select {
			appearance: none;
