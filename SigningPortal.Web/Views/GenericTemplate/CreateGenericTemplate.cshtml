                    // Update organization dropdown ID
                    $("#organizationDropdown_" + id).attr("id", "organizationDropdown_" + newId);

                    // Update eseal checkbox ID and name
                    $("#RecpientList_" + id + "__Eseal").attr("id", "RecpientList_" + newId + "__Eseal").attr("name", "RecpientList[" + newId + "].Eseal");

                    // Update initial checkbox ID and name
                    $("#RecpientList_" + id + "__Initial").attr("id", "RecpientList_" + newId + "__Initial").attr("name", "RecpientList[" + newId + "].Initial");

                    // Update settings button ID and onclick event
                    $("#settings_" + id).attr("id", "settings_" + newId).attr("onclick", "showSettingsModal(" + (newId + 1) + ")");

                    // Update remove button ID and onclick event
                    $("#btnRemove_" + id).attr("id", "btnRemove_" + newId).attr("onclick", "deleteRecipient(this)");

                    // Update add button ID and onclick event
                    $("#btnadd_" + id).attr("id", "btnadd_" + newId).attr("onclick", "addRecipient(this)");
                }
