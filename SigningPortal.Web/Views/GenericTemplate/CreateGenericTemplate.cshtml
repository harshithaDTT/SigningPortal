            }

            PerpareDocumentContext.receipientEmails = [];
            PerpareDocumentContext.receipientEmailsList = [];

            var currid = parseInt($(event).attr("id").split("_")[1]);
            var previd = currid - 1;

            // Remove the current recipient
            $("#" + currid).remove();
            userDataResponses.splice(currid, 1);

            // Recalculate the IDs and orders for all remaining recipients
            $(".recp").each(function (index) {
                var id = parseInt($(this).attr("id"));

                if (id > currid) {
                    // Adjust the new ID
                    var newId = id - 1;

                    // Update the recipient row ID
                    $(this).attr("id", newId);

                    // Update order value
                    $("#RecpientList_" + id + "__Order").val(index + 1).attr("id", "RecpientList_" + newId + "__Order").attr("name", "RecpientList[" + newId + "].Order");

                    // Update email input ID and name
