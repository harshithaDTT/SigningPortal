        function validateEmail(email) {
            var emailReg = /^([\w\.\-]+)@@([\w\-]+)((\.(\w){1,15})+)$/;
            if (!emailReg.test(email.value)) {
                $(email).next("span").removeClass("classshide")
                return false
            } else {
                $(email).next("span").addClass("classshide")
                return true;
            }
        }

