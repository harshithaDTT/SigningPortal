        function findDuplicates(emailList) {
            const seen = {};
            const duplicates = [];

            emailList.forEach(email => {
                if (seen[email]) {
                    if (!duplicates.includes(email)) {
                        duplicates.push(email);
                    }
                } else {
                    seen[email] = true;
                }
            });

            return duplicates;
        }

