                    textAnnot.StrokeColor = new Annotations.Color(0, 165, 228);
                    textAnnot.TextAlign = "center";
                    //textAnnot.Locked = false;


                    textAnnot.Author = annotManager.getCurrentUser();
                    annotManager.deselectAllAnnotations();
                    annotManager.addAnnotation(textAnnot, true);
                    annotManager.redrawAnnotation(textAnnot);
                    annotManager.selectAnnotation(textAnnot);

                }

            }
        }


        const appendstampannotations = async (type, point = {}, name = "", value = "", flag = {}) => {

            // textAnnot.Rotation = rotation;
            const { docViewer, Annotations } = webviwerInstance;
            const annotManager = docViewer.getAnnotationManager();
            const doc = docViewer.getDocument();
            const displayMode = docViewer.getDisplayModeManager().getDisplayMode();
            const zoom = docViewer.getZoomLevel();
            // annotManager.setCurrentUser(user.name);
            const annotationsList = annotManager.getAnnotationsList();
            console.log(annotationsList)

            const currentuser = JSON.parse(localStorage.getItem("user"));
            const annotationsTodelete = []
            const annotationsTodraw = []
            annotationsList.forEach((annotation) => {
                if (annotation.getCustomData("type") === "INITIAL") {
                    const stampAnnot = new Annotations.StampAnnotation();
                    stampAnnot.NoResize = false;
                    stampAnnot.PageNumber = annotation.getPageNumber()
                    stampAnnot.Rotation = annotation.rotation;

                    const customName = `${"INITIAL"}_STAMP`;
                    var imgdata = 'data:image/png;base64,' + annotation.getCustomData("initial_imag");

                    stampAnnot.setImageData(imgdata);
                    stampAnnot.Width = annotation.getWidth()
                    stampAnnot.Height = annotation.getHeight()

                    stampAnnot.X = annotation.getX()
                    stampAnnot.Y = annotation.getY()
                    stampAnnot.custom = {
                        type,
                        value,
                        flag,
                        name: `${type}_${PerpareDocumentContext.selectuser}_`,
                    };
                    stampAnnot.setCustomData("type", annotation.getCustomData("type"));
                    stampAnnot.setCustomData("value", annotation.getCustomData("value"));
                    stampAnnot.setCustomData("flag", annotation.getCustomData("flag"));
                    // stampAnnot.setCustomData("name", annotation.getCustomData("name"));
                    stampAnnot.setCustomData("name", customName);
                    stampAnnot.setCustomData("custom_subject", "StampAnnot");
                    stampAnnot.setCustomData("recepient", annotation.getCustomData("recepient"));
                    stampAnnot.setContents("");
                    stampAnnot.FontSize = "" + 12.0 / zoom + "px";
                    stampAnnot.FillColor = new Annotations.Color(211, 211, 211, 0.5);
                    stampAnnot.TextColor = new Annotations.Color(0, 165, 228);
                    stampAnnot.StrokeThickness = 1;
                    stampAnnot.StrokeColor = new Annotations.Color(0, 165, 228);
                    stampAnnot.TextAlign = "center";
                    stampAnnot.Author = annotManager.getCurrentUser();
                    annotationsTodraw.push(stampAnnot)
                    // annotationsTodelete.push(annotation)
                    annotation.setContents("")
                    annotation.Hidden = true
                    stampAnnot.Locked = true
                    stampAnnot.ReadOnly = true;
                    stampAnnot.LockContents = true;
                    annotManager.deselectAllAnnotations();
                    annotManager.addAnnotation(stampAnnot, true);
                    // annotManager.redrawAnnotation(stampAnnot);
                    // annotManager.selectAnnotation(stampAnnot);

                }


            })
            // annotManager.deleteAnnotations(annotationsTodelete, null, true);
            // annotManager.drawAnnotationsFromList(annotationsTodraw, null, true);



        };
