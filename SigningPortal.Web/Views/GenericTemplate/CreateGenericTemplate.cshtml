        function fileSelect(e) {
            $('#overlay').show();
            let file = e.target.files[0];
            let extn = file.name.substring(file.name.lastIndexOf(".") + 1).toLowerCase();
            let BasePath = @Json.Serialize(@Configuration.GetSection("WebViwerBasePath").Value);

            if (!webviwerInstance) {
                console.log('webviwerInstance or its properties are not loaded properly');
                e.target.value = ""; // Reset file input
                $('#overlay').hide();
                return false;
            }

            const { PDFNet, CoreControls } = webviwerInstance;

            if (isFileUploaded) {
                toastr.error(`File already uploaded.`);
                e.target.value = ""; // Reset file input
                $('#overlay').hide();
                return false;
            }

            if (file.size > 15 * 1024 * 1024) {
                toastr.error(`File size should be 15 MB or below.`);
                e.target.value = ""; // Reset file input
                $('#overlay').hide();
                return false;
            }

            const validTypes = [
                "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                "application/pdf"
            ];

            if (!validTypes.includes(file.type)) {
                toastr.error(`Only PDFs, Word documents, and Excel sheets are supported.`);
                e.target.value = ""; // Reset file input
                $('#overlay').hide();
                return false;
            }

            if (file.name.length > 50) {
                toastr.error(`File name should be less than 50 characters.`);
                e.target.value = ""; // Reset file input
                $('#overlay').hide();
                return false;
            }

            var reader = new FileReader();

            reader.onloadend = async function (e) {
                let result = e.target.result;
                if (extn === "pdf") {
                    let buff = new Uint8Array(result);
                    await PrintSignaturesInfo(buff);
                } else if (extn === "docx" || extn === "xlsx") {
                    let blob = new Blob([result], { type: file.type });
                    handleNonPDF(blob, file);
                }
            };

            const PrintSignaturesInfo = async (in_docbuffer) => {
                const licenseKey = "DigitalTrust Technologies Pvt Ltd:OEM:Digital Signature Services Portal::B+:AMS(20270629):3CA5587D04B7080AC360B13AC982536160617FD5F900ED4BF50419D44A60189E528AB6F5C7";
                CoreControls.setWorkerPath(BasePath);
                await PDFNet.initialize(licenseKey);

                const doc = await PDFNet.PDFDoc.createFromBuffer(in_docbuffer);
                doc.lock();

                if (!(await doc.initSecurityHandler())) {
                    swal({
                        type: 'info',
                        title: 'Info',
                        text: "Password-protected documents are not allowed."
                    });
                    e.target.value = ""; // Reset file input
                    $('#overlay').hide();
                    return false;
                } else if (await doc.hasSignatures()) {
                    swal({
                        type: 'info',
                        title: 'Info',
                        text: "Invalid Document, Document has already been signed."
                    });
                    e.target.value = ""; // Reset file input
                    $('#overlay').hide();
                    return false;
                } else {
                    let blob = new Blob([in_docbuffer], { type: 'application/pdf' });
                    let url = URL.createObjectURL(blob);
                    webviwerInstance.loadDocument(url, { filename: file.name });
                    webviwerInstance.disableElements([

                        "header",
                        "toolsHeader",
                    ]);
                    $('#uploadSection').addClass("classshide");
                    $('#previewDocu').removeClass("classshide");
                    renderPDF(in_docbuffer);  // Render PDF here

                    $("#DocumentName").val(file.name);
                    PerpareDocumentContext.fileName = file.name.split(".").slice(0, -1).join(".");
                    PerpareDocumentContext.docName = file.name;
                    $("#thumbnail").removeClass('classshide');
                    $('#Continue').removeAttr('disabled').removeClass('disabled-blur');
                    $('#quickSign').removeAttr('disabled').removeClass('disabled-blur');
                    isFileUploaded = true;
                    $("#myModal").addClass('classshide');
                    globalFile = file;
                }
                e.target.value = ""; // Reset file input
                $('#overlay').hide();
            };

            const handleNonPDF = (blob, file) => {
                let url = URL.createObjectURL(blob);
                webviwerInstance.loadDocument(url, { filename: file.name });
                $('#uploadSection').addClass("classshide");
                $('#previewDocu').removeClass("classshide");
                renderPDF(blob);

                $("#DocumentName").val(file.name);
                PerpareDocumentContext.fileName = file.name.split(".").slice(0, -1).join(".");
                PerpareDocumentContext.docName = file.name;
                $("#thumbnail").removeClass('classshide');
                $('#Continue').removeAttr('disabled').removeClass('disabled-blur');
                $('#quickSign').removeAttr('disabled').removeClass('disabled-blur');
                isFileUploaded = true;
                $("#myModal").addClass('classshide');
                globalFile = file;
                e.target.value = ""; // Reset file input
                $('#overlay').hide();
            };

            reader.readAsArrayBuffer(file);

        }

        async function renderPDF(pdfBuffer) {
            const pdfContainer = document.getElementById('pdfContainer'); // Use a div container
            pdfContainer.innerHTML = ''; // Clear any existing content before rendering new pages

            // Load the PDF using PDF.js
            const loadingTask = pdfjsLib.getDocument({ data: pdfBuffer });
            const pdf = await loadingTask.promise;

            const totalPages = pdf.numPages; // Get total number of pages

            // Loop through all the pages in the PDF
            for (let pageNum = 1; pageNum <= totalPages; pageNum++) {
                const page = await pdf.getPage(pageNum);

                // Create a new canvas for each page
                const canvas = document.createElement('canvas');
                const context = canvas.getContext('2d');
                const viewport = page.getViewport({ scale: 0.9 }); // Adjust scale as necessary

                // Set canvas dimensions to match the PDF page
                canvas.height = viewport.height;
                canvas.width = viewport.width;

                // Render the PDF page onto the canvas
                const renderContext = {
                    canvasContext: context,
                    viewport: viewport
                };

                await page.render(renderContext).promise;

                // Append the canvas to the PDF container
                pdfContainer.appendChild(canvas);
            }
        }



