                        noneseal_organizations.push(selectedorderobj.orgList[j]);
                    }
                };

                var $organizationDropdown = $('#organizationDropdown_' + id);
                if (checkbox.checked === true) {
                    if (selectedorderobj.selectedorgList[0].has_eseal_permission === false) {
