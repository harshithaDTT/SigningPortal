@using System.Security.Claims;
@using Microsoft.Extensions.Configuration;
@using Newtonsoft.Json;
@using SigningPortal.Core.DTOs;
@inject IConfiguration Configuration;
@{
    var rawName = User.FindFirst(ClaimTypes.Name)?.Value ?? User.Identity?.Name ?? string.Empty;
    var firstWord = (rawName ?? string.Empty).Split(' ').FirstOrDefault() ?? string.Empty;
    var sanitizedFirstWord = firstWord?.Trim() ?? string.Empty;
    var initials = "--";
    var initialsSource = !string.IsNullOrWhiteSpace(sanitizedFirstWord)
        ? sanitizedFirstWord
        : (rawName?.Trim() ?? string.Empty);
    if (!string.IsNullOrWhiteSpace(initialsSource))
    {
        initials = initialsSource.Substring(0, System.Math.Min(2, initialsSource.Length));
    }

    var email = User.FindFirst(ClaimTypes.Email)?.Value ?? string.Empty;
    var accountType = User.FindFirst("AccountType")?.Value ?? "Self";
    var isSelfAccount = string.Equals(accountType ?? "Self", "Self", System.StringComparison.OrdinalIgnoreCase);
    var organizationName = isSelfAccount ? string.Empty : (User.FindFirst("OrganizationName")?.Value ?? string.Empty);
    var organizationLabel = string.IsNullOrWhiteSpace(organizationName) ? "Not set" : organizationName;
    var suid = User.FindFirst(ClaimTypes.UserData)?.Value ?? string.Empty;
    var displayName = string.IsNullOrWhiteSpace(rawName) ? email : rawName;
    var accountTypeLabel = string.IsNullOrWhiteSpace(accountType) ? "Self" : accountType;
    var selfEmails = User.FindFirst("SelfEmails").Value;
    var IdpToken = User.FindFirst("ID_Token").Value;

    var userClaim = User.FindFirst("user")?.Value;
    UserDTO userDto = null;
    if (!string.IsNullOrEmpty(userClaim))
    {
        userDto = JsonConvert.DeserializeObject<UserDTO>(userClaim);
    }
    var organizationId = User.FindFirst("OrganizationUid")?.Value ?? "";
}
