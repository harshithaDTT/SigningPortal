@if (TempData["Alert"] != null)
{
    var alertBox = TempData["Alert"];

    <script>
        $(document).ready(function () {
            $('#networkOverlay').hide();
            document.getElementById("navigationNetworkOverlay").style.display = "none";
            let alertObj = @Html.Raw(@alertBox);

            if (alertObj.IsSuccess) {
                sweetAlert({ title: "Success", text: alertObj.Message, type: "success", confirmButtonText: "Ok", customClass: '' });

            } else {
                if (alertObj.Type == 'info') {
                    sweetAlert({ title: "Info", text: alertObj.Message, type: "info", confirmButtonText: "Dismiss", customClass: '' });
                }
                else {
                    sweetAlert({ title: "Failed", text: alertObj.Message, type: "error", confirmButtonText: "Dismiss", customClass: '' });
                }

            }
        });
    </script>
}