    .scrolling {
        animation: scroll-up 10s linear infinite;
    }

    @@keyframes scroll-up {
        0% {
            transform: translateY(0);
        }

        100% {
            transform: translateY(-100%);
        }
    }

    /* Default state: scrollbar hidden */
    /* Simulated hidden scrollbar */
    #docs-container.hide-scrollbar {
        scrollbar-width: none; /* Firefox */
        -ms-overflow-style: none; /* IE 10+ */
    }

        #docs-container.hide-scrollbar::-webkit-scrollbar {
            visibility: hidden; /* Chrome, Safari */
        }

    /* On hover: scrollbar visible again */
    #docs-container.show-scrollbar {
        scrollbar-width: thin;
    }

        #docs-container.show-scrollbar::-webkit-scrollbar {
            width: 6px;
        }

        #docs-container.show-scrollbar::-webkit-scrollbar-thumb {
            background-color: #bbb;
            border-radius: 3px;
        }

    #docs-container.hide-scrollbar {
