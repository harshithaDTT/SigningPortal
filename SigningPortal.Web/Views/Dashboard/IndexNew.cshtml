    function renderRecentActivity(data) {

        let html = '';

        data.forEach(item => {

            /* ---------- STATUS ---------- */
            let badgeClass = 'recent-in-progress';
            let badgeIcon = '<i class="fa-regular fa-clock"></i>';

            if (item.status === 'Expired') {
                badgeClass = 'recent-draft';
                badgeIcon = '<i class="fa-regular fa-file"></i>';
            }
            else if (item.status === 'Completed') {
                badgeClass = 'recent-completed';
                badgeIcon = '<i class="fa-regular fa-circle-check"></i>';
            }
            else if (item.status === 'Declined') {
                badgeClass = 'recent-declined';
                badgeIcon = '<i class="fa-regular fa-circle-xmark"></i>';
            }

            /* ---------- DOCUMENT NAME ---------- */
            let documentName = cropFileNames(item.documentName);

            /* ---------- DATE ---------- */
            let date = new Date(item.createdAt)
                .toLocaleDateString('en-IN', {
                    day: '2-digit',
                    month: 'short',
                    year: 'numeric'
                });

            /* ---------- CATEGORY ---------- */
            let category = item.source || 'Document';
            if (category === "Sent Documents") {

                let completedEmails = (item.completeSignList || [])
                    .map(x => x.email || x);

                let pendingEmails = (item.pendingSignList || [])
                    .map(x => x.email || x);

                let allEmails = [...new Set([...completedEmails, ...pendingEmails])];

                if (allEmails.length > 0) {

                    let fullEmailList = allEmails.join(', '); // For hover tooltip

                    let visibleText = '';

                    if (allEmails.length === 1) {
                        // Only one email → show fully
                        visibleText = allEmails[0];
                    }
                    else {
                        // First email full
                        let firstEmail = allEmails[0];

                        // Second email first 5 letters only
                        let secondEmailShort = allEmails[1].substring(0, 5) + '...';

                        visibleText = `${firstEmail}, ${secondEmailShort}`;
                    }

                    categoryText = `
                <span title="${fullEmailList}">
                    Sent To: ${visibleText}
                </span>
            `;
                }
                else {
                    categoryText = `Sent`;
                }
            }

            else if (category === "Received Documents") {

                categoryText = `Received From: ${item.ownerEmail || '-'}`;

            }
            else {

                categoryText = "You initiated a document for signing";

            }

            /* ---------- SIGNED INFO ---------- */
            let signedText = ` ${item.completeSignList.length}/ ${item.recepients.length} Signed`;
            html += `
                                        <div class="recent-row">
                                            <div class="recent-left">
                                                            <div class="sidebar-icon-wrapper">
                                                        <i class="fa-regular fa-file-lines sidebar-icon"></i>
                                                </div>

                                                    <div class="recent-doc-info">
                                                        <div class="recent-doc-name"
                                                         title="${item.documentName}">
                                                        ${documentName}
                                                    </div>

                                                        <div class="recent-doc-meta">
                                                            ${categoryText} &nbsp;•&nbsp; ${date}
                                                        ${signedText ? '&nbsp;•&nbsp; ' + signedText : ''}
                                                    </div>
                                                </div>
                                            </div>

                                                  <div class="recent-right">
                                                    <div class="status-badge ${badgeClass}">
                                                        ${badgeIcon} ${item.status}
                                                    </div>

                                                    <button class="view-btn"
                                                            title="View details"
                                                            onclick="redirectToDocumentDetails('${item.id}','${category}')">
                                                                <i class="fa fa-eye" style="width:20px;" ></i>
                                                    </button>
                                                </div>

                                        </div>
                                    `;
        });

        $('#recentActivityList').html(html);
    }
