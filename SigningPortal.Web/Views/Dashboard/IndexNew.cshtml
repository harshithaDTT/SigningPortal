            border-radius: 6px;
            animation: shimmer 1.2s infinite;
            color: transparent !important;
        }

    /* Shimmer animation */
    @@keyframes shimmer {
        0% {
            background-position: -100px 0;
        }

        100% {
            background-position: 100px 0;
        }
    }

