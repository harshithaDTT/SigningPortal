@model SigningPortal.Web.ViewModels.BulkSign.BulkSignDetailsViewModel
@{
    var totalFileCount = 0;
    var failedFileCount = 0;
    var successFileCount = 0;
    var pendingCount = 0;
    var filesCount = 0;
    if (Model.Result != null)
    {
        totalFileCount = Model.Result.TotalFileCount;
        failedFileCount = Model.Result.FailedFileCount;
        successFileCount = Model.Result.SuccessFileCount;
        pendingCount = totalFileCount - failedFileCount - successFileCount;
        filesCount = Model.Result.FileArray.Count();
    }

    var correlationId = Model.CorelationId;
    var destination = Model.SignedPath;
    var Status = Model.Status;
}

<style>
