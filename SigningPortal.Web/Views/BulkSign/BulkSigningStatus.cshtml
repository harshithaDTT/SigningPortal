                                <li onclick="handleFilter('all')">
                                    <img src='@Url.Content("~/img/allicon.png")' width="18">
                                    All
                                </li>

                                <li onclick="handleFilter('complete')">
                                    <img src='@Url.Content("~/img/completeicon.png")' width="15">
                                    Completed
                                </li>

                                <li onclick="handleFilter('notstarted')">
                                    <img src='@Url.Content("~/img/inprogressicon.png")' width="15">
                                    Not Started
                                </li>

                                <li onclick="handleFilter('fail')">
                                    <img src='@Url.Content("~/img/failicon.png")' width="15">
                                    Failed
                                </li>
                            </ul>
                        </div>

