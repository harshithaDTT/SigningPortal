</style>
<div class="container-fluid" style="background:#F6F7FB; min-height:100vh;padding:2rem !important">
    @Html.AntiForgeryToken()
    <div class="dg-stat-grid">
        <div class="dg-stat-card dg-total">
            <div>
                <div class="dg-stat-title">Total</div>
                <div class="dg-stat-value" id="totalcount">3</div>
            </div>
            <div class="dg-stat-icon dg-total-icon">
                <span class="material-symbols-outlined">
                    <i class="bi bi-files"></i>
                </span>
            </div>
        </div>
        <div class="dg-stat-card dg-pending">
            <div>
                <div class="dg-stat-title">Pending</div>
                <div class="dg-stat-value" id="pendingcount">0</div>
            </div>
            <div class="dg-stat-icon dg-pending-icon">
                <span class="material-symbols-outlined">  <i class="bi bi-clipboard-check"></i></span>
            </div>
        </div>

        <div class="dg-stat-card dg-signed">
            <div>
                <div class="dg-stat-title">Signed</div>
                <div class="dg-stat-value" id="signedcount">3</div>
            </div>
            <div class="dg-stat-icon dg-signed-icon">
                <span class="material-symbols-outlined"><i class="bi bi-patch-check-fill"></i></span>
            </div>
        </div>

        <div class="dg-stat-card dg-failed">
            <div>
                <div class="dg-stat-title">Failed</div>
                <div class="dg-stat-value" id="failedcount">0</div>
            </div>
            <div class="dg-stat-icon dg-failed-icon">
                <span class="material-symbols-outlined"> <i class="bi bi-exclamation-circle-fill"></i></span>
            </div>
        </div>

    </div>


    <div class="dg-dashboard-row">

        <!-- LEFT : TABLE -->
        <div class="dg-left-panel">
            <div class="dg-table-card border">

                <!-- Header -->
                <div class="dg-table-header-pro">

                    <!-- LEFT : TITLE -->
                    <div class="dg-title">
                        Document Status
                    </div>

                    <!-- CENTER : SEARCH -->
                    <div class="dg-search-wrap">
                        <span class="material-symbols-outlined dg-search-ic"><i class="fa fa-search"></i></span>
                        <input type="text" id="docSearchInput" placeholder="Quick search documents..." />

                    </div>

                    <!-- RIGHT : ACTIONS -->
                    <div class="dg-actions position-relative">

