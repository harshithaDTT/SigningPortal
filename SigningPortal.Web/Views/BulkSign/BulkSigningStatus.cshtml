    /* shimmer animation */
    @@keyframes shimmer {
        0% {
            background-position: -400px 0;
        }

        100% {
            background-position: 400px 0;
        }
    }

    .dg-shimmer-row td {
        padding: 18px 14px;
    }

    .dg-shimmer-cell {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .dg-shimmer-avatar {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: #eee;
        background-image: linear-gradient( to right, #eee 0%, #f5f5f5 20%, #eee 40%, #eee 100% );
        background-size: 800px 100%;
        animation: shimmer 1.4s infinite linear;
    }

    .dg-shimmer-lines {
        flex: 1;
    }

        .dg-shimmer-lines .line {
            height: 10px;
            border-radius: 6px;
