                                    <div class="dg-shimmer-pill"></div>
                                </td>
                                <td class="center">
                                    <div class="dg-shimmer-pill"></div>
                                </td>
                            </tr>

                        </tbody>


                        <tbody id="realTableBody"></tbody>
                    </table>
                </div>

                <!-- Empty State -->
                <div id="emptyState" class="dg-empty-state" style="display:none;">
                    <div class="dg-empty-icon">
                        <i class="fa-solid fa-folder-open"></i>
                    </div>
                    <div class="dg-empty-title">No documents found</div>
                    <div class="dg-empty-sub">
                        filtered documents will appear here.
                    </div>
                </div>

                <!-- Footer / Pagination -->
                <div class="dg-table-footer">
                    <div class="dg-page-text" id="pageInfo"></div>
                    <div class="dg-pagination" id="paginationpart">
                        <button class="dg-btn prevbutton" id="prevBtn">Prev</button>
                        <button class="dg-btn nextbutton" id="nextBtn">
                            Next
                        </button>
                    </div>
                </div>

            </div>
        </div>

        <!-- RIGHT : PIE CHART -->
        <div class="dg-right-panel">
            <div class="dg-chart-card border">

                <div class="dg-chart-title">Pictorial Representation</div>


                <div style="margin:15% auto">
                    <!-- Centering the canvas -->
                    <div style="display: flex; justify-content: center;">
                        <canvas id="myChart" width="277" height="277"></canvas>
                    </div>
                </div>

            </div>
        </div>

    </div>

</div>

@section scripts {
    <script>
        let allFiles = [];
        let filteredFiles = [];
        let currentPage = 1;
        let rowsPerPage = 4;

        var myChart;
        var intervalId;
        var totalCount1 = '@totalFileCount';
        var pendingCount1 = @pendingCount;
        var failedFileCount1 = @failedFileCount;
        var successFileCount1 = @successFileCount;
        var CorelationId = '@correlationId';
        var SignedPath = '@destination';
        var statusvalue = '@Status';
        var filesCount = @filesCount;
        var filelist;
        var allfilelist;
        var completefilelist;
        var failfilelist;
        var pendingfilelist;
        var pending = `<span class="material-symbols-outlined">  <i class="bi bi-clipboard-check" style="font-size: 1.25rem;color: #f39c12;"></i></span>`;
        var success = `<span class="material-symbols-outlined"><i class="bi bi-patch-check-fill" style="font-size: 1.25rem;color: #0ea66b;"></i></span>`;
        var fail = `<span class="material-symbols-outlined"> <i class="bi bi-exclamation-circle-fill" style="font-size: 1.25rem;color: #ef4444;"></i></span>`;
        var yValues = [successFileCount1, pendingCount1, failedFileCount1];
        var xValues = ["Signed", "Pending", "Failed"];
        var barColors = [
            "#0ea66b",
            "#f39c12",
            "#ef4444"
        ];
        $(document).ready(function () {
            loadpiechart();
            if (statusvalue !== "Completed") {

                intervalId = setInterval(checkstatus, 3000);
                updatestatus();
            }
            else {
                UpdateDetails();
            }

        });
        $("#docSearchInput").on("keyup", function () {
            let val = $(this).val().toLowerCase();

            filteredFiles = allFiles.filter(x =>
                x.fileName.toLowerCase().includes(val)
            );

            currentPage = 1;
            renderTable();
        });
        $("#prevBtn").on("click", function () {
            if (currentPage > 1) {
                currentPage--;
                renderTable();
            }
        });
        const filterToggle = document.getElementById("filterToggle");
        const filterDropdown = document.getElementById("filterDropdown");

        filterToggle.addEventListener("click", function (e) {
            e.stopPropagation();
            filterDropdown.classList.toggle("show");
        });

        // Close when clicking outside
        document.addEventListener("click", function (e) {
            if (!filterDropdown.contains(e.target)) {
                filterDropdown.classList.remove("show");
            }
        });


        $("#nextBtn").on("click", function () {
            let totalPages = Math.ceil(filteredFiles.length / rowsPerPage);
            if (currentPage < totalPages) {
                currentPage++;
                renderTable();
            }
        });
        function loadpiechart() {

            if (myChart) {
                // ✅ Just update data & colors
                myChart.data.labels = xValues;
                myChart.data.datasets[0].data = yValues;
                myChart.data.datasets[0].backgroundColor = barColors;

                myChart.update();   // Only updates what changed
                return;
            }

            // ✅ Create chart only once
            myChart = new Chart("myChart", {
                type: "pie",
                data: {
                    labels: xValues,
                    datasets: [{
                        backgroundColor: barColors,
                        data: yValues
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: true,
                            position: 'bottom',
                            align: 'center',
                            labels: {
                                boxWidth: 14,
                                padding: 20,
                                font: { size: 12 }
                            }
                        }
                    }
                }
            });
        }
        function renderTable() {

            let tableBody = document.getElementById("realTableBody");
            tableBody.innerHTML = "";

            if (!filteredFiles || filteredFiles.length === 0) {
                document.querySelector(".dg-table-wrapper").style.display = "none";

                // Show empty state
                document.getElementById("emptyState").style.display = "flex";

                // Hide pagination
                document.getElementById("paginationpart").style.display = "none";
                document.getElementById("pageInfo").textContent = "";
                return;
            }
            // Show table when data exists
            document.querySelector(".dg-table-wrapper").style.display = "block";
            document.getElementById("emptyState").style.display = "none";

            let start = (currentPage - 1) * rowsPerPage;
            let end = start + rowsPerPage;
            let pageItems = filteredFiles.slice(start, end);
            console.log(pageItems);
            pageItems.forEach(item => {

                let statusIcon = "";
                let downloadHtml = "---";

                if (item.status === "success") {
                    statusIcon = success;
                    downloadHtml = `
                                        <span class="material-symbols-outlined dg-download"
                                              onclick='redirectToPage("${item.fileName}", "${SignedPath}")'>
                                            <i class="fa fa-download"></i>
                                        </span>`;
                }
                else if (item.status === "fail") {
                    statusIcon = fail;
                }
                else {
                    statusIcon = pending;
                }

                let fileName = item.fileName;
                let displayName = fileName.length > 45 ? cropFileNames(fileName) : fileName;

                let row = `
                                    <tr>
                                                <td title="${fileName}" style="display:flex;gap:0.25rem;"><div class="nd-icon">
                                                <i class="fa-solid fa-file-lines"></i>
                                            </div>
                                                    <div style="margin:0.5rem;">${displayName}</div></td>
                                        <td class="center">${statusIcon}</td>
                                        <td class="center">${downloadHtml}</td>
                                    </tr>
                                `;

                tableBody.insertAdjacentHTML("beforeend", row);
            });

            let totalPages = Math.ceil(filteredFiles.length / rowsPerPage);
            document.getElementById("paginationpart").style.display = "block";
            document.getElementById("pageInfo").textContent = `Page ${currentPage} of ${totalPages}`;

            document.getElementById("prevBtn").disabled = currentPage === 1;
            document.getElementById("nextBtn").disabled = currentPage === totalPages;
        }
        function redirectToPage(fileName, destinationPath) {

            var data = {
                fileName: fileName,
                destinationPath: destinationPath
            };
            $.ajax({
                url: '@Url.Action("Download", "BulkSign")',
                method: 'POST',
                headers: {

                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()

                },
                contentType: 'application/json',
                data: JSON.stringify(data),
                beforeSend: function () {
                    $('#overlay').show();
                },
                complete: function () {
                    $('#overlay').hide();
                },

                success: function (data) {
                    if (data.success === false) {
                        swal({ type: 'info', title: "Download file", text: data.message, showCancelButton: false, closeOnConfirm: true }, function (isConfirm) {
                            if (isConfirm) {

                            }
                        });
                    } else {
                        // Extract the Base64 string from data.result.fileContents
                        var base64String = data.result.fileContents; // Assuming data.result.fileContents holds the Base64 string

                        // Decode the Base64 string to get the binary data
                        var byteCharacters = atob(base64String);
                        var byteNumbers = new Array(byteCharacters.length);

                        for (var i = 0; i < byteCharacters.length; i++) {
                            byteNumbers[i] = byteCharacters.charCodeAt(i);
                        }

                        // Convert the binary data to a Blob object
                        var byteArray = new Uint8Array(byteNumbers);
                        var blob = new Blob([byteArray], { type: 'application/octet-stream' });

                        // Create an object URL for the Blob
                        var url = window.URL.createObjectURL(blob);
                        var a = document.createElement('a');
                        a.href = url;

                        var parts = fileName.split('.');

                        // Extract the base name (everything before the last ".")
                        var baseName = parts.slice(0, -1).join('.');

                        // Extract the extension (everything after the last ".")
                        var extension = parts.pop();

                        if (extension !== 'pdf') {
                            var pdfFileName = baseName + '.pdf';
                            fileName = pdfFileName;
                        }

                        a.download = fileName;

                        // Append the link to the body
                        document.body.appendChild(a);

                        // Trigger a click on the link to start the download
                        a.click();

                        // Remove the link from the body
                        document.body.removeChild(a);

                        // Release the object URL
                        window.URL.revokeObjectURL(url);
                    }
                },

                error: ajaxErrorHandler
            });
        }
        function cropFileNames(full) {

            // Adjust crop lengths based on screen width
            let start, end;

            const width = window.innerWidth;

            if (width >= 1300) {
                start = 25;
                end = 25;
            } else if (width >= 768) {
                start = 20;
                end = 20;
            } else if (width >= 460) {
                start = 13;
                end = 13;
            }
            else { // Small screens (mobiles)
                start = 10;
                end = 10;
            }

            if (full && full.length > start + end) {
                return full.slice(0, start) + '...' + full.slice(-end);
            } else {
                return full
            }



        }
        function handleFilter(type) {

            if (type === "all") {
                filteredFiles = allFiles;
            }
            else if (type === "complete") {
                filteredFiles = allFiles.filter(x => x.status === "success");
            }
            else if (type === "fail") {
                filteredFiles = allFiles.filter(x => x.status === "fail");
            }
            else if (type === "notstarted") {
                filteredFiles = allFiles.filter(x => x.status === "pending");
            }
            filterDropdown.classList.remove("show");
            currentPage = 1; // Reset page when filter changes
            renderTable();   // Re-render table with pagination + search
        }
        function updateTable(fileArray) {

            document.getElementById("shimmerBody").style.display = "table-row-group";
            document.getElementById("realTableBody").style.display = "none";

            allFiles = fileArray || [];
            filteredFiles = [...allFiles];
            currentPage = 1;

            setTimeout(() => {
                renderTable();

                document.getElementById("shimmerBody").style.display = "none";
                document.getElementById("realTableBody").style.display = "table-row-group";
            }, 400);
        }


        function UpdateDetails() {
            var corelationid = CorelationId;
            $.ajax({
                url: '@Url.Action("DocumentResultDetails", "BulkSign")',
                method: 'GET',
                data: { correlationId: corelationid },
                success: function (data) {
                    if (data.success) {
                        if (data.result.totalFileCount > 0) {
                            totalCount1 = data.result.totalFileCount;
                            failedFileCount1 = data.result.failedFileCount;
                            successFileCount1 = data.result.successFileCount;
                            pendingCount1 = data.result.totalFileCount - successFileCount1 - failedFileCount1;
                            yValues = [successFileCount1, pendingCount1, failedFileCount1]
                            var fileArray = data.result.fileArray;
                            filelist = fileArray;
                            $('#signedcount').text(successFileCount1);
                            $('#failedcount').text(failedFileCount1);
                            $('#pendingcount').text(pendingCount1);
                            $('#totalcount').text(totalCount1);
                            updateTable(fileArray);
                            loadpiechart();

                        }
                    } else {
                        swal({
                            title: 'Error',
                            text: data.message,
                            type: 'error',
                        }, function (isConfirm) {
                            if (isConfirm) {
                                // window.location.href = '@Url.Action("Index", "Template")';
                            }
                        });
                    }

                },
                error: ajaxErrorHandler
            });
        }


        function updatestatus() {

            var corelationid = CorelationId;
            $.ajax({
                url: '@Url.Action("UpdateBulkSignDocumentDetails", "BulkSign")',
                method: 'GET',
                data: { correlationId: corelationid },
                success: function (data) {
                    if (data.success) {
                        var fileArray = data.result.fileArray;
                        if (fileArray.length == 0) {
                            return;
                        }
                        totalCount1 = data.result.totalFileCount
                        failedFileCount1 = data.result.failedFileCount;
                        successFileCount1 = data.result.successFileCount;
                        pendingCount1 = data.result.totalFileCount - successFileCount1 - failedFileCount1;
                        yValues = [successFileCount1, pendingCount1, failedFileCount1];
                        $('#signedcount').text(successFileCount1);
                        $('#failedcount').text(failedFileCount1);
                        $('#pendingcount').text(pendingCount1);
                        $('#totalcount').text(totalCount1);
                        updateTable(fileArray);
                        filelist = fileArray;
                        loadpiechart();
                    } else {
                        swal({
                            title: 'Error',
                            text: data.message,
                            type: 'error',
                        }, function (isConfirm) {
                            if (isConfirm) {
                                // window.location.href = '@Url.Action("Index", "Template")';
                            }
                        });
                    }

                },
                error: ajaxErrorHandler
            });
        }
        function checkstatus() {
            var corelationid = CorelationId;
            $.ajax({
                url: '@Url.Action("DocumentStatusDetails", "BulkSign")',
                method: 'GET',
                data: { correlationId: corelationid },
                success: function (data) {

                    if (data.success) {
                        if (data.result !== "Completed") {
                            updatestatus();
                        }
                        else {
                            clearInterval(intervalId);
                            UpdateDetails();
                        }
                    } else {
                        swal({
                            title: 'Error',
                            text: data.message,
                            type: 'error',
                        }, function (isConfirm) {
                            if (isConfirm) {
                            }
                        });
                    }

                },
                error: ajaxErrorHandler
            });
        }

    </script>
}




