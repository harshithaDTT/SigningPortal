<script>
    let globalData = [];         // stores active dataset
    let currentIndex = 0;        // pagination index
    const PAGE_SIZE = 5;         // show 6 items
    let filteredData = [];

    let activeListType = "";     // templates | mylist | sent | received
    var viewName = '@(ViewBag.ViewName ?? "templates")';

    var loginOrgId = '@OrganizationUid';
    var loginorgUid = '@OrganizationUid';
    var loginSuid = '@Suid';
    var loginEmail = '@userEmail';

    var bulksignPermisson = '@bulksign';

    // initial render (templates)


    // Tab click handler
    $(document).on("click", ".tab-item", function () {
        $(".tab-item").removeClass("active");
        $(this).addClass("active");

        let tabType = $(this).attr("data-type"); // make sure data-type exists (see HTML fix)
        renderItems(tabType);
    });
    $(document).ready(function () {
        var viewName = '@(ViewBag.ViewName ?? "templates")';

        // Remove active from all
        $(".tab-item").removeClass("active");

        // Find matching tab & activate
        var $activeTab = $('.tab-item[data-type="' + viewName + '"]');

        if ($activeTab.length) {
            $activeTab.addClass("active");
            renderItems(viewName);
        } else {
            // fallback
            $('.tab-item[data-type="templates"]').addClass("active");
            renderItems("templates");
        }
    });

    // renderItems chooses dataset and renders
    function renderItems(type) {
        $("#templatesContainer").show();
        $("#templatecontainercard").show();
        $("#templatesContainer").empty();
        $("#noDataMessageDraft").hide();
        $("#noDataMessageSent").hide();
        $("#noDataMessageReceived").hide();
        let html = "";

        if (type === "templates") {

            getTemplatelist();
        }
        else if (type === "mylist") {
            getBulksignmylist();

        }
        else if (type === "sent") {
            getBulksignsentlist();

        }
        else if (type === "received") {
            getBulksignreceivedlist();
        }


    }

    // dropdown logic (safer)
    $(document).on("click", ".menu-icon", function (e) {
        e.stopPropagation();
        // close other dropdowns
        $(".template-dropdown").addClass("d-none");
        // open the dropdown in the same .template-menu
        $(this).closest(".template-menu").find(".template-dropdown").toggleClass("d-none");
    });

    // don't close when clicking inside dropdown
    $(document).on("click", ".template-dropdown", function (e) {
        e.stopPropagation();
    });

    // close on outside click
    $(document).on("click", function () {
        $(".template-dropdown").addClass("d-none");
    });
    $(document).on("keyup", "#templateSearch", function () {

        let value = $(this).val().toLowerCase().trim();

        // 🔁 RESET SEARCH
        if (value === "") {
            filteredData = [...globalData];
            resetPagination();
            hideAllNoDataMessages();
            return;
        }

        // 🔍 FILTER FULL DATASET
        filteredData = globalData.filter(item => {

            if (activeListType === "templates") {
                return (
                    (item.templateName || "").toLowerCase().includes(value) ||
                    (item.documentName || "").toLowerCase().includes(value) ||
                    (item.emailList?.[0] || "").toLowerCase().includes(value)
                );
            }

            return (
                (item.templateName || "").toLowerCase().includes(value) ||
                (item.transaction || "").toLowerCase().includes(value) ||
                (item.signerEmail || item.ownerEmail || "").toLowerCase().includes(value)
            );
        });
        console.log(filteredData);

        if (filteredData.length === 0) {
            showNoData(activeListType);
        } else {
            hideAllNoDataMessages();
        }
        resetPagination();

    });

    function resetPagination() {
        $("#templatesContainer").empty();
        currentIndex = 0;
        loadMoreItems();
    }

    function togglePaginationButtons() {

        // ❌ No pagination needed at all
        if (filteredData.length <= PAGE_SIZE) {
            $("#showMoreBtn").addClass("d-none");
            $("#showLessBtn").addClass("d-none");
            return;
        }

        // ✅ More items exist
        if (currentIndex >= filteredData.length) {
            $("#showMoreBtn").addClass("d-none");
            $("#showLessBtn").removeClass("d-none");
        } else {
            $("#showMoreBtn").removeClass("d-none");
            $("#showLessBtn").addClass("d-none");
        }
    }


    function hideAllNoDataMessages() {
        $("#noDataMessageTemplate, #noDataMessageDraft, #noDataMessageSent, #noDataMessageReceived").hide();
    }

    function showNoData(type) {
        hideAllNoDataMessages();
        $("#templatesContainer").hide();
        $("#templatecontainercard").hide();
        $("#showMoreBtn, #showLessBtn").addClass("d-none");

        if (type === "templates") $("#noDataMessageTemplate").show();
        if (type === "mylist") $("#noDataMessageDraft").show();
        if (type === "sent") $("#noDataMessageSent").show();
        if (type === "received") $("#noDataMessageReceived").show();
    }

    function handleEditTemplate(templateId) {
        document.getElementById("networkOverlay").style.display = "block";
        window.location.href = '@Url.Action("GetTemplateDetails", "Template")' + `?templateId=${templateId}`;

    }
    function handlePreview(templateId) {
        document.getElementById("networkOverlay").style.display = "block";
        window.location.href = '@Url.Action("Preview", "Template")' + `?templateId=${templateId}`;

    }
    function showLessItems() {
        $("#templatesContainer").empty();
        currentIndex = 0;
        loadMoreItems();

        if (globalData.length > PAGE_SIZE) {
            $("#showMoreBtn").removeClass("d-none");
        }

        $("#showLessBtn").addClass("d-none");
    }
    function formatDateToDDMMYYYY(dateString) {
        if (!dateString) return "";

        const date = new Date(dateString);
        const day = String(date.getDate()).padStart(2, "0");
        const month = String(date.getMonth() + 1).padStart(2, "0"); // Months are 0-based
        const year = date.getFullYear();

        return `${day}/${month}/${year}`;
    }

    function convertToLocalTime(serverTime) {
        // Parse the server-sent time (with offset) into a Date object
        const date = new Date(serverTime);

        // Convert to user's local time
        const localTime = date.toLocaleString("en-US", { timeZone: Intl.DateTimeFormat().resolvedOptions().timeZone });

        return localTime;
    }
    function updateTimestamps() {
