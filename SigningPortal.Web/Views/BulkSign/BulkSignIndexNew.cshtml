    function cropFileNames(full) {

        // Adjust crop lengths based on screen width
        let start, end;

        const width = window.innerWidth;

        if (width >= 1300) {
            start = 15;
            end = 15;
        } else if (width >= 768) {
            start = 7;
            end = 7;
        }
        else if (width >= 460) {
            start = 10;
            end = 10;
        }
        else { // Small screens (mobiles)
            start = 8;
            end = 8;
        }

        if (full && full.length > start + end) {
            return full.slice(0, start) + '...' + full.slice(-end);
        } else {
            return full
        }



    }
