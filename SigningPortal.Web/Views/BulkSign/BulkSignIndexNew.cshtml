        const signCoordinates = btn.dataset.sign
            ? JSON.parse(decodeURIComponent(btn.dataset.sign))
            : null;

        const esealCoordinates = btn.dataset.eseal
            ? JSON.parse(decodeURIComponent(btn.dataset.eseal))
            : null;

        PerformBulkSign(correlationId, signCoordinates, esealCoordinates);
    }

