</style>
<div class="container-fluid p-4" style="background:#F6F7FB; min-height:100vh;">
    @Html.AntiForgeryToken()
    <div class="row d-flex align-items-center flex-wrap mt-2  mb-2">
        <span class="col-12 col-sm-5 col-md-4 col-lg-3 col-xl-3 col-xxl-2">Template Name<span style="color: red;">*</span> :</span>
        <div class="col-12 col-sm-6">
            <div class="form-group" style="max-width: 203px;">
                <select class="form-control" id="DocumentTemplate" name="templates" @(Model.SelectedTemplateId != null ? "disabled" : "")>
                    <option value="">Choose Template</option>
                    @{
                        foreach (var item in Model.TemplateList)
                        {
                                    <option value="@item._id" selected="@(item._id == Model.SelectedTemplateId)">
                                        @item.TemplateName
                                    </option>

                        }
                    }
                </select>
            </div>
        </div>
    </div>

    <div class="row d-flex align-items-center flex-wrap mb-2">
        <span class="col-12 col-sm-5 col-md-4 col-lg-3 col-xl-3 col-xxl-2">Transaction Name<span style="color: red;">*</span>:</span>
        <div class="col-12 col-sm-6">
            <div class="form-group mb-0" style="max-width: 203px;">
                <input class="form-control" type="text" id="inputField1" placeholder="" />
            </div>
        </div>
    </div>

    <br />
    <div id="uploadpart" class="ud-wrapper" style="opacity:0.5;">

        <!-- Header -->
        <div class="ud-header">
            <div>
                <h3 class="ud-title">Upload Documents</h3>
                <p class="ud-subtitle">Select files or folders to upload to your secure vault.</p>
            </div>

            <!-- Toggle -->
            <div class="ud-toggle">
                <button type="button" class="ud-toggle-btn active" id="udFilesBtn">Files</button>
                <button type="button" class="ud-toggle-btn" id="udFolderBtn">Folder</button>

            </div>
        </div>

        <!-- Inputs -->
        <input type="file" id="fileInput" multiple hidden />
        <input type="file" id="folderInput" multiple webkitdirectory hidden />

        <!-- Dropzone -->
        <div class="ud-dropzone" id="udDropzone">

            <div class="ud-dropzone-inner">

                <div class="ud-cloud-circle">
                    <i class="fa fa-cloud-upload"></i>
                </div>

                <!-- MAIN TEXT -->
                <div class="ud-main-text" id="udMainText">
                    Upload files here
                </div>

                <!-- SUB TEXT -->
                <div class="ud-sub-text">
                    or <span class="ud-browse-link" id="udBrowseBtn">click to browse</span>
                </div>

                <div class="ud-format-text" id="udFormatText">
                    PDF, DOCX, XLSX FORMATS
                </div>

            </div>

        </div>

    </div>



    <div style="display:none;margin-top:1rem;" id="fileTableContainer">
        <div class="card shadow-sm">

            <!-- Top Bar -->
            <div class="d-flex justify-content-between align-items-center p-3 border-bottom">
                <div id="fileCountDisplay" class="fw-bold">Recent Uploads (0 files)</div>
                <input type="text" id="searchFiles" class="form-control w-25" placeholder="Search files...">
            </div>

            <!-- Column Headers -->
            <!-- Upload Mode Header (3 columns) -->
            <div class="file-header three-col" id="uploadHeader">
                <div class="col-doc">DOCUMENT NAME</div>
                <div class="col-status">STATUS</div>
                <div class="col-action">ACTION</div>
            </div>

            <!-- Uploaded Mode Header (2 columns) -->
            <div class="file-header two-col" id="uploadedHeader">
                <div class="col-doc">DOCUMENT NAME</div>
                <div class="col-status">STATUS</div>
            </div>


            <!-- File Rows -->
            <div id="fileListContainer"></div>
            <div id="noFilesUI" class="text-center py-4 text-muted" style="display:none;">
                No documents available
            </div>
            <!-- Pagination -->
            <div class="d-flex justify-content-between align-items-center p-3 border-top">
                <div id="pageInfo" class="text-muted small"></div>
                <div>
                    <button class="btn btn-sm btn-light" id="prevPage">Previous</button>
                    <span id="pageNumber" class="mx-2 fw-bold"></span>
                    <button class="btn btn-sm btn-light" id="nextPage">Next</button>
                </div>
            </div>

        </div>

        <!-- Action Buttons -->
        <div class="mt-3 d-flex gap-2" style="justify-content:end;">
            <button type="button" class="upload-button" id="uploadfiles" style="display:none;">Upload</button>
            <button type="button" class="bulksign-button" id="bulksignbutton" style="display:none;">Bulk sign</button>
            <button type="button" class="bulksign-button" id="sendrequest" style="display:none;">Send Request</button>
            <button type="button" class="bulksign-button" id="saverequest" style="display:none;">Save Request</button>
        </div>
    </div>


</div>

<div id="file-list"></div>
<div class="classshide">
    <div id='viewer'></div>
</div>
@section scripts {
    <script type="text/javascript" charset="utf8" src="~/local-cdns/Shared/datatables/1.11.5/jquery.dataTables.js"></script>
    <link rel="stylesheet" type="text/css" href="~/local-cdns/Shared/datatables/1.11.5/jquery.dataTables.css">

    <!-- DataTables Responsive Extension -->
    <link rel="stylesheet" href="~/local-cdns/Shared/datatables-responsive/2.2.9/responsive.dataTables.min.css">
    <script src="~/local-cdns/Shared/datatables-responsive/2.2.9/dataTables.responsive.min.js"></script>


    <!-- Load PDF.js -->
    <script src="~/local-cdns/Shared/pdfjs/2.10.377/pdf.min.js"></script>

    <!-- Load PDF.js worker -->
    <script src="~/local-cdns/Shared/pdfjs/2.10.377/pdf.worker.min.js"></script>


    <script>
        let currentPage = 1;
        const pageSize = 5;   // files per page

        var viewName = "MyDocuments";
        var loginOrgId = '@OrganizationUid';
        var bulksignPermisson = '@bulksign';
        var templateList = [];
        var totalfilessize = 0;
        var templatedata = '@Model.TemplateList'
        var loginEmail = '@userEmail';
        var loginorgUid = '@OrganizationUid';
        var loginSuid = '@Suid';
        if ((Object.keys(templatedata).length != 0)) {
            templateList = @Html.Raw(JsonConvert.SerializeObject(Model.TemplateList));
        }

        var BulkSignIndexUrl = '@Url.Action("Index", "BulkSign")';
        var BulkSignIndexNewurl = '@Url.Action("BulkSignIndexNew", "BulkSign")';
        var BulkSigningStatusUrl = '@Url.Action("BulkSigningStatus", "BulkSign")';
        var GetFileConfigurationUrl = '@Url.Action("GetFileConfiguration", "BulkSign")';
        var UpdateDocumentDetailsUrl = '@Url.Action("UpdateDocumentDetails", "BulkSign")';
        var SendRequestUrl = '@Url.Action("SendRequest", "BulkSign")';
        var GetDelegationbyorgidsuidUrl = '@Url.Action("GetDelegationbyorgidsuid", "Documents")';
        var SendFilesUrl = '@Url.Action("SendFiles", "BulkSign")';
        var GetOrganizationStatusUrl = '@Url.Action("GetOrganizationStatus", "Documents")';
        var BulkSigningUrl = '@Url.Action("BulkSigning", "BulkSign")';
        var PerformBulkSignUrl = '@Url.Action("PerformBulkSign", "BulkSign")';
        var selectedFiles = [];
        var selectedTemplateId = '';
        var worddocCovertedFiles = [];
        var selectedFilesTotallist = [];
        let currentTableData = [];
        let checkuploaded = false;

        const pdfjsLib = window['pdfjs-dist/build/pdf'];

        if (!pdfjsLib) {
            console.error('PDF.js library is not loaded.');
        } else {

            pdfjsLib.GlobalWorkerOptions.workerSrc = '@Url.Content("/local-cdns/Shared/pdfjs/2.10.377/pdf.worker.min.js")';
        }


        $(document).ready(function () {

            let isFolderMode = false;

            $("#udFilesBtn").on("click", function () {
                isFolderMode = false;

                $("#udFilesBtn").addClass("active");
                $("#udFolderBtn").removeClass("active");

                $("#udMainText").text("Upload files here");
                $("#udFormatText").text("PDF, DOCX, XLSX FORMATS");
            });

            $("#udFolderBtn").on("click", function () {
                isFolderMode = true;

                $("#udFolderBtn").addClass("active");
                $("#udFilesBtn").removeClass("active");

                $("#udMainText").text("Upload folder here");
                $("#udFormatText").text("PDF, DOCX, XLSX FORMATS");
            });

            $("#udBrowseBtn, #udDropzone").on("click", function () {
                if (isFolderMode) {
                    chooseFolder();
                } else {
                    chooseFiles();
                }
            });

        });


        $('#DocumentTemplate').change(function () {

            selectedTemplateId = $(this).val();
            if (selectedTemplateId != '') {

                selectedFiles = [];
                totalfilessize = 0;
                var uploadpart = document.getElementById('uploadpart');
                uploadpart.style.opacity = 'unset';
                // document.getElementById('scopesTable').style.display = 'none';
                document.getElementById('fileTableContainer').style.display = 'none';
                document.getElementById('folderInput').value = '';
                document.getElementById('fileInput').value = '';

            }
            else {
                var uploadpart = document.getElementById('uploadpart');
                uploadpart.style.opacity = 0.5;
                // document.getElementById('scopesTable').style.display = 'none';
                document.getElementById('fileTableContainer').style.display = 'none';
                document.getElementById('folderInput').value = '';
                document.getElementById('fileInput').value = '';

            }

        });
        $(document).ready(function () {

            $('#BulkSign').addClass('active');
            if ($('#DocumentTemplate').val() !== "") {
                $('#DocumentTemplate').trigger('change');
            }
            getFileConfiguration();
            $("#udFilesBtn").on("click", function () {
                setUploadToggle("files");
                showFileInput();
            });

            $("#udFolderBtn").on("click", function () {
                setUploadToggle("folder");
                showFolderInput();
            });


            $("#chooseFilesBtn").on("click", function () {
                chooseFiles();
            });

            $("#chooseFolderBtn").on("click", function () {
                chooseFolder();
            });

            $("#removeAllBtn").on("click", function () {
                handleRemoveAll();
            });

            $("#uploadfiles").on("click", function () {
