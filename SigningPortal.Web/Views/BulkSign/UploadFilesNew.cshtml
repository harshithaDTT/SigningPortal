        function cropFileNames(full) {

            let start, end;

            const width = window.innerWidth;

            if (width >= 1300) {
                start = 25;
                end = 25;
            } else if (width >= 768) {
                start = 20;
                end = 20;
            } else if (width >= 460) {
                start = 13;
                end = 13;
            }
            else {
                start = 10;
                end = 10;
            }

            if (full && full.length > start + end) {
                return full.slice(0, start) + '...' + full.slice(-end);
            } else {
                return full
            }



        }
