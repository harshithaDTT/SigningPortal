        function AddTableData() {

            $("#uploadHeader").show();
            $("#uploadedHeader").hide();

            const container = document.getElementById("fileListContainer");
            const fileCountDisplay = document.getElementById("fileCountDisplay");
            const noFilesUI = document.getElementById("noFilesUI");
            const tableContainer = document.getElementById("fileTableContainer");
            currentTableData = filteredFiles();
            const total = currentTableData.length;
            const start = (currentPage - 1) * pageSize;
            const end = start + pageSize;
            const pageFiles = currentTableData.slice(start, end);
            container.innerHTML = "";

            tableContainer.style.display = selectedFiles.length > 0 ? "block" : "none";

            if (total === 0 && selectedFiles.length > 0) {
                noFilesUI.style.display = "block";
                updatePagination(0);
                fileCountDisplay.textContent = `Recent Uploads (0 files)`;
                ActivateUploadfilesButton();
                return;
            } else {
                noFilesUI.style.display = "none";
            }

            pageFiles.forEach((file, index) => {

                const realIndex = start + index;

                const row = document.createElement("div");
                row.className = "file-row three-col";

                const doc = document.createElement("div");
                doc.className = "file-doc";

                const icon = document.createElement("div");
                icon.className = "file-icon";
                icon.innerHTML = '<i class="fa-regular fa-file-lines"></i>';

                const nameBox = document.createElement("div");

                const name = document.createElement("div");
                name.className = "file-name";
                name.textContent = file.name.length > 50 ? cropFileNames(file.name) : file.name;
                name.title = file.name;

                const time = document.createElement("div");
                time.className = "file-time";
                time.textContent = "Uploaded just now";

                nameBox.appendChild(name);
                nameBox.appendChild(time);

                doc.appendChild(icon);
                doc.appendChild(nameBox);

                const status = document.createElement("div");

                status.className = "file-status";
                status.textContent = "Ready";

                const del = document.createElement("button");
                del.className = "file-delete";
                del.innerHTML = '<i class="fa-regular fa-trash-can"></i>';
                del.onclick = function () {
                    removeFile(realIndex);
                };

                row.appendChild(doc);
                row.appendChild(status);
                row.appendChild(del);

                container.appendChild(row);
            });

            fileCountDisplay.textContent = `Recent Uploads (${total} files)`;

            updatePagination(total);
            ActivateUploadfilesButton();
            scrollToRecentUploads();
        }

