@model SigningPortal.Web.ViewModels.FormRequests.AllFormRequestsListViewModel
@using System.Security.Claims;
@using Newtonsoft.Json;
@{
    ViewData["Title"] = "View";

}
@{
    var Suid = User.FindFirst(ClaimTypes.UserData).Value;
    var userEmail = User.FindFirst(ClaimTypes.Email).Value;
    var bulksign = User.IsInRole("bulkSign");
    var AccountType = User.FindFirst("AccountType").Value;
    var OrganizationName = "";
    var OrganizationUid = "";
    var login_esealsignatoryrole = User.IsInRole("eSealSignatory");
    var selfemails = "";
    if (AccountType != "Self")
    {
        selfemails = User.FindFirst("SelfEmails").Value;
        OrganizationName = User.FindFirst("OrganizationName").Value;
        OrganizationUid = User.FindFirst("OrganizationUid").Value;
    }
}
<style>
    :root {
        --df-text-primary: #0f172a;
        --df-text-secondary: #51627a;
        --df-text-muted: #97a1b5;
        --df-bg-page: #f4f6fb;
        --df-bg-card: #fdfefd;
        --df-border-color: #dbe3f0;
        --df-border-light: #eef2fb;
        --df-shadow-sm: 0 8px 18px rgba(15, 23, 42, 0.07);
        --df-shadow-md: 0 18px 30px rgba(15, 23, 42, 0.12);
        --df-radius-md: 12px;
        --df-radius-lg: 18px;
    }

    .df-tabled-wrap {
        background: linear-gradient(135deg, rgba(243, 246, 255, 0.9), rgba(250, 251, 255, 0.9));
        border-radius: 0.5rem;
        padding: 1.75rem;
        border: 1px solid var(--df-border-light);
        box-shadow: var(--df-shadow-sm);
    }

    #refferedList {
        border-collapse: separate;
        border-spacing: 0 12px;
    }

        #refferedList thead th {
            border: none;
            text-transform: uppercase;
            font-size: 0.6875rem;
            letter-spacing: 0.05em;
            font-weight: 600;
            color: var(--df-text-muted);
            background: transparent;
            padding: 0.75rem 1rem;
        }

        #refferedList tbody tr {
            background: linear-gradient(145deg, rgba(255, 255, 255, 0.92), rgba(245, 247, 255, 0.92));
            border: 1px solid rgba(219, 227, 240, 0.65);
            border-radius: var(--df-radius-md);
            box-shadow: 0 20px 30px rgba(15, 23, 42, 0.08);
            transition: all 0.25s ease;
        }

            #refferedList tbody tr:hover {
                border-color: rgba(99, 102, 241, 0.35);
                box-shadow: var(--df-shadow-md);
            }

        #refferedList tbody td {
            border: none;
            padding: 1.25rem 1rem;
            vertical-align: middle;
        }

            #refferedList tbody td:first-child {
                border-top-left-radius: var(--df-radius-md);
                border-bottom-left-radius: var(--df-radius-md);
            }

            #refferedList tbody td:last-child {
                border-top-right-radius: var(--df-radius-md);
                border-bottom-right-radius: var(--df-radius-md);
            }

    .df-doc-shell {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .df-doc-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: linear-gradient(135deg, #eef4ff, #f4fbff);
        border: 1px solid rgba(99, 102, 241, 0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #4c6ef5;
        font-size: 1.25rem;
        flex-shrink: 0;
        box-shadow: inset 0 0 12px rgba(76, 110, 245, 0.08);
    }

    .df-doc-meta {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .df-doc-title {
        font-size: 0.9625rem;
        font-weight: 600;
        color: var(--df-text-primary);
        line-height: 1.4;
    }

    .df-meta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        font-size: 0.8125rem;
        color: var(--df-text-muted);
        line-height: 1.4;
    }

    .df-cell-stack {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        text-align: left;
    }

    .df-cell-label {
        font-size: 0.6875rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-weight: 600;
        color: var(--df-text-muted);
    }

    .df-cell-value {
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--df-text-secondary);
    }

    .newform {
        background: rgba(16, 185, 129, 0.12);
        border: 1px solid rgba(5, 150, 105, 0.3);
        color: #047857;
        padding: 0.375rem 0.875rem;
        border-radius: 0.75rem;
        font-size: 0.8125rem;
        font-weight: 600;
    }

    .formcompletebtn {
        background: rgba(59, 130, 246, 0.12);
        border: 1px solid rgba(37, 99, 235, 0.28);
        color: #1d4ed8;
        padding: 0.375rem 0.875rem;
        border-radius: 6px;
        font-size: 0.8125rem;
        font-weight: 600;
    }

    .inprogressbtn {
        background: rgba(249, 181, 51, 0.14);
        border: 1px solid rgba(217, 119, 6, 0.28);
        color: #b45309;
        padding: 0.375rem 0.875rem;
        border-radius: 6px;
        font-size: 0.8125rem;
        font-weight: 600;
    }

    .otherbtn {
        background: rgba(148, 163, 184, 0.12);
        border: 1px solid rgba(148, 163, 184, 0.3);
        color: #64748b;
        padding: 0.375rem 0.875rem;
        border-radius: 6px;
        font-size: 0.8125rem;
        font-weight: 600;
    }

    .df-status-block {
        display: flex;
        flex-direction: column;
        gap: 0.375rem;
        align-items: flex-start;
    }

    .df-actions .btn {
        border-radius: 999px !important;
        padding: 0.55rem 1.25rem !important;
        font-size: 0.875rem !important;
        font-weight: 600 !important;
        text-transform: none !important;
        background: linear-gradient(120deg, #4f80ff, #3556f2) !important;
        border: none;
        color: #ffffff !important;
        box-shadow: 0 5px 25px rgba(53, 86, 242, 0.3);
        transition: all 0.2s ease;
    }

        .df-actions .btn:hover {
            background: linear-gradient(120deg, #3b68ff, #2743d5) !important;
            box-shadow: 0 18px 30px rgba(37, 73, 210, 0.35);
            transform: translateY(-2px);
        }

    .custom-dropdown {
        position: relative;
        display: inline-block;
    }

    .custom-dropdown-content {
        display: none;
        position: absolute;
        background-color: #ffffff;
        min-width: 200px;
        box-shadow: 0 22px 45px rgba(15, 23, 42, 0.15);
        border: 1px solid rgba(148, 163, 184, 0.25);
        border-radius: 14px;
        padding: 0.65rem;
        right: 0;
        z-index: 10;
    }

    .custom-dropdown:hover .custom-dropdown-content {
        display: block;
    }

    .custom-dropdown-content a {
        color: var(--df-text-primary);
        padding: 0.625rem 0.85rem;
        text-decoration: none;
        display: block;
        font-size: 0.875rem;
        font-weight: 500;
        border-radius: 8px;
        transition: all 0.15s ease;
    }

        .custom-dropdown-content a:hover {
            background: rgba(59, 130, 246, 0.08);
            color: #1d4ed8 !important;
        }

    .custom-dropdown-content li {
        list-style: none;
    }

    .btn {
        text-transform: capitalize !important;
    }

    /* Status popup */
    .status-container {
        position: relative;
        display: inline-block;
    }

    .popup {
        display: none;
        position: absolute;
        min-width: 280px;
        padding: 15px;
        background: #2563eb;
        color: #ffffff;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        font-size: 0.875rem;
        z-index: 10000;
        bottom: 100%;
        right: 0;
    }

    .status-container:hover .popup {
        display: block;
    }

    .popup .header {
        font-weight: 600;
        margin-bottom: 0.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.2);
        padding-bottom: 0.5rem;
    }

    .popup .email-list {
        padding-left: 1rem;
        margin: 0;
    }

    /* DataTables styling */
    table.dataTable > tbody > tr > td.control::before,
    table.dataTable > tbody > tr.parent > td.control::before {
        background: #dbeafe;
        color: #1e40af !important;
        border-radius: 6px;
        width: 20px;
        height: 20px;
        line-height: 20px;
        font-weight: 600;
        border: 1px solid #bfdbfe;
    }

    .dataTables_wrapper .dataTables_filter input {
        border-radius: 0.5rem;
        border: 1px solid rgba(148, 163, 184, 0.45);
        padding: 0.55rem 1.15rem;
        background: rgba(255, 255, 255, 0.9);
        font-size: 0.9rem;
        box-shadow: 0 10px 25px rgba(15, 23, 42, 0.08);
        transition: all 0.2s ease;
    }

        .dataTables_wrapper .dataTables_filter input:focus {
            outline: none;
            border-color: rgba(59, 130, 246, 0.65);
            box-shadow: 0 15px 30px rgba(59, 130, 246, 0.2);
            background: #ffffff;
        }

    .dataTables_wrapper .dataTables_paginate .paginate_button {
        border-radius: 8px !important;
        margin: 0 0.25rem !important;
        padding: 0.4rem 0.85rem !important;
        border: 1px solid rgba(148, 163, 184, 0.4) !important;
        background: rgba(248, 250, 255, 0.9) !important;
        color: var(--df-text-secondary) !important;
        font-weight: 500 !important;
        transition: all 0.15s ease;
    }

        .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
            background: var(--df-bg-page) !important;
            border-color: var(--df-border-color) !important;
            color: var(--df-text-primary) !important;
        }

        .dataTables_wrapper .dataTables_paginate .paginate_button.current {
            background: linear-gradient(120deg, #5469ff, #3d5afe) !important;
            border-color: transparent !important;
            color: #ffffff !important;
            box-shadow: 0 10px 22px rgba(61, 90, 254, 0.35);
        }

    .dataTables_wrapper .dataTables_info {
        color: var(--df-text-muted);
        font-weight: 500;
        font-size: 0.875rem;
        padding-top: 1rem;
    }

    .df-empty-card {
        border-radius: var(--df-radius-lg);
        background: rgba(255, 255, 255, 0.95);
        border: 1px dashed rgba(148, 163, 184, 0.4);
        padding: 2rem;
        box-shadow: var(--df-shadow-sm);
        color: var(--df-text-secondary);
        font-weight: 500;
        text-align: center;
    }

    /* Hide DataTables responsive control */
    table.dataTable td.control,
    table.dataTable th.control {
        display: none !important;
        width: 0 !important;
        padding: 0 !important;
    }

    @@media (max-width:992px) {
        .popup {
            display: none !important;
        }
    }

    @@media (max-width: 768px) {
        .df-tabled-wrap {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        .dataTables_wrapper .dataTables_length,
        .dataTables_wrapper .dataTables_filter {
            float: none !important;
            text-align: center !important;
            margin-bottom: 0.5rem;
        }

        .dataTables_wrapper .dataTables_filter input {
            width: 100% !important;
            max-width: 280px;
            margin: 0.5rem auto !important;
        }

        .dataTables_wrapper .dataTables_info,
        .dataTables_wrapper .dataTables_paginate {
            float: none !important;
            text-align: center !important;
        }

        .dataTables_wrapper .dataTables_paginate .paginate_button {
            padding: 0.4rem 0.6rem !important;
        }

        table.dataTable thead th,
        table.dataTable tbody td {
            font-size: 0.8rem !important;
            padding: 0.5rem 0.25rem !important;
        }

        .df-doc-shell {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.5rem;
        }

        .df-meta-row {
            flex-wrap: wrap;
            gap: 4px;
        }
    }

    @@media (max-width: 480px) {
        .dataTables_wrapper .dataTables_paginate .paginate_button {
            padding: 0.3rem 0.4rem !important;
            font-size: 0.7rem !important;
        }

        table.dataTable thead th,
        table.dataTable tbody td {
            font-size: 0.7rem !important;
            padding: 0.35rem 0.2rem !important;
        }

        .df-empty-card {
            padding: 1.5rem 1rem;
        }
    }

</style>

@if (Model.receiveRequests.Count == 0)
{
    <div class="df-empty-card text-center">
        <i class="fa-regular fa-folder-open" style="font-size: 2rem; color: var(--df-text-muted); margin-bottom: 1rem;"></i>
        <div>No Records Are Found</div>
    </div>
}
else
{
    <div class="df-tabled-wrap">
        <table id="refferedList" class="table table-bordered table-checkable order-column full-width" style="width:100%;">
            <thead style="text-align:center;display:none">
                <tr>
                    <th></th>
                    <th style="text-align:left!important">Form Name</th>
                    <th>Received From</th>
                    <th>Received On</th>
                    <th>Form Expiry</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.receiveRequests)
                {
                    var className = "";
                    if (item.Status == "Completed")
                    {
                        className = "formcompletebtn";
                    }
                    else if (item.Status == "In Progress")
                    {
                        className = "inprogressbtn";
                    }
                    else if (item.Status == "New")
                    {
                        className = "newform";
                    }
                    else
                    {
                        className = "otherbtn";
                    }
                    <tr class="odd gradeX">
                        <td></td>
                        <td>
                            <div class="df-doc-shell">
                                <div class="df-doc-icon">
                                    <i class="fa-regular fa-file-lines"></i>
                                </div>
                                <div class="df-doc-meta">
                                    <span class="df-doc-title">@item.DocumentName</span>
                                    <span class="df-meta-row">
                                        <span>From: @item.Owner.email</span>
                                    </span>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="df-cell-stack">
                                <span class="df-cell-label">Received From</span>
                                <span class="df-cell-value">@item.Owner.email</span>
                            </div>
                        </td>
                        <td class="convert-time" data-timestamp="@item.CreatedAt.ToString("o")">
                            <div class="df-cell-stack">
                                <span class="df-cell-label">Received On</span>
                                <span class="df-cell-value">@item.CreatedAt.ToString("dd/MM/yyyy")</span>
                            </div>
                        </td>
                        <td class="convert-time" data-timestamp="@item.ExpieryDate.ToString("o")">
                            <div class="df-cell-stack">
                                <span class="df-cell-label">Form Expiry</span>
                                <span class="df-cell-value">@item.ExpieryDate.ToString("dd/MM/yyyy")</span>
                            </div>
                        </td>
                        <td>
                            <div class="df-status-block">
                                <span class="df-cell-label">Status</span>
                                <div class="status-container" style="position: relative; display: inline-block;">
                                    <span class="@className" style="cursor:pointer;">@item.Status</span>

                                    @if (item.Status == "Completed")
                                    {
                                        <div class="popup ">
                                            <p class="header">
                                                <span class="headersp">
                                                    TOTAL RECIPIENTS: @(item.CompleteSignList?.Count() + item.PendingSignList?.Count())
                                                </span>
                                            </p>
                                            <div class="row">
                                                <p style="text-align:left">
                                                    SIGNED: @(item.CompleteSignList?.Count() ?? 0)
                                                </p>
                                                @* <ul class="email-list" style="margin-bottom:0;">
                            @foreach (var signer in item.CompleteSignList)
                            {
                            <li class="first-email" style="display:flex;justify-content:start;">
                            <span class="sec" style="padding-left:6%">@signer.email</span>
                            </li>
                            }
                            </ul> *@
                                                <ul class="email-list" style="margin-bottom:0;">
                                                    @if (item.CompleteSignList.Count > 0)
                                                    {

                                                        foreach (var i in item.TemplateRecepients)
                                                        {
                                                            if (i.Status == "Signed")
                                                            {
                                                                if (i.HasDelegation)
                                                                {
                                                                    // Render the first alternate signatory with a bullet
                                                                    <li class="first-email" style="display:flex;justify-content:start;">
                                                                        @foreach (var alt in i.AlternateSignatories.Take(1))
                                                                        {
                                                                            <span class="sec" style="padding-left:6%">@alt.email</span>
                                                                        }
                                                                    </li>

                                                                    // Render the remaining alternate signatories without bullets
                                                                    @foreach (var alt in i.AlternateSignatories.Skip(1))
                                                                    {
                                                                        <li class="no-bullet" style="display:flex;">
                                                                            <span class="sec" style="padding-left:6%">@alt.email</span>
                                                                        </li>
                                                                    }

                                                                    // Render the delegator label and email
                                                                    <li class="no-bullet delegator-section" style="display:flex;">
                                                                        <span class="sec" style="padding-left:6%">Delegator:</span>
                                                                    </li>
                                                                    <li class="no-bullet delegator-section" style="display:flex;">
                                                                        <span class="sec" style="padding-left:6%">@i.Signer.email</span>
                                                                    </li>
                                                                }
                                                                else
                                                                {
                                                                    <li class="first-email" style="display:flex;justify-content:start;">
                                                                        <span class="sec" style="padding-left:6%">@i.Signer.email</span>
                                                                    </li>
                                                                }


                                                            }
                                                        }

                                                    }
                                                </ul>
                                            </div>
                                        </div>
                                    }
                                    @if (item.Status == "In Progress" || item.Status == "New")
                                    {
                                        <div class="popup">
                                            <p class="header">
                                                <span class="headersp">
                                                    TOTAL RECIPIENTS: @(item.CompleteSignList?.Count() + item.PendingSignList?.Count())
                                                </span>
                                            </p>
                                            <div class="row">
                                                <p style="text-align:left">
                                                    PENDING: @(item.PendingSignList?.Count() ?? 0)
                                                </p>

                                                @* <ul class="email-list" style="margin-bottom:0;">
                            @foreach (var signer in item.PendingSignList)
                            {
                            <li class="first-email" style="display:flex;justify-content:start;">
                            <span class="sec" style="padding-left:6%">@signer.email</span>
                            </li>
                            }
                            </ul> *@
                                                <ul class="email-list" style="margin-bottom:0;">
                                                    @if (item.PendingSignList.Count > 0)
                                                    {


                                                        foreach (var i in item.TemplateRecepients)
                                                        {
                                                            if (i.Status == "Pending")
                                                            {
                                                                if (i.HasDelegation)
                                                                {

                                                                    <li class="first-email" style="display:flex;justify-content:start;">
                                                                        @foreach (var alt in i.AlternateSignatories.Take(1))
                                                                        {
                                                                            <span class="sec" style="padding-left:6%">@alt.email</span>
                                                                        }
                                                                    </li>

                                                                    @foreach (var alt in i.AlternateSignatories.Skip(1))
                                                                    {
                                                                        <li class="no-bullet" style="display:flex;">
                                                                            <span class="sec" style="padding-left:6%">@alt.email</span>
                                                                        </li>
                                                                    }

                                                                    <li class="no-bullet delegator-section" style="display:flex;">
                                                                        <span class="sec" style="padding-left:6%">Delegator:</span>
                                                                    </li>
                                                                    <li class="no-bullet delegator-section" style="display:flex;">
                                                                        <span class="sec" style="padding-left:6%">@i.Signer.email</span>
                                                                    </li>
                                                                }
                                                                else
                                                                {
                                                                    <li class="first-email" style="display:flex;justify-content:start;">
                                                                        <span class="sec" style="padding-left:6%">@i.Signer.email</span>
                                                                    </li>
                                                                }
                                                            }
                                                        }

                                                    }
                                                </ul>
                                            </div>
                                            @if (item.TemplateRecepients?.Count() != item.PendingSignList?.Count())
                                            {
                                                <div class="row">
                                                    <p style="text-align:left">
                                                        SIGNED: @(item.CompleteSignList?.Count() ?? 0)
                                                    </p>

                                                    <ul class="email-list" style="margin-bottom:0;">
                                                        @if (item.CompleteSignList.Count > 0)
                                                        {

                                                            foreach (var i in item.TemplateRecepients)
                                                            {
                                                                if (i.Status == "Signed")
                                                                {
                                                                    if (i.HasDelegation)
                                                                    {
                                                                        // Render the first alternate signatory with a bullet
                                                                        <li class="first-email" style="display:flex;justify-content:start;">
                                                                            @foreach (var alt in i.AlternateSignatories.Take(1))
                                                                            {
                                                                                <span class="sec" style="padding-left:6%">@alt.email</span>
                                                                            }
                                                                        </li>

                                                                        // Render the remaining alternate signatories without bullets
                                                                        @foreach (var alt in i.AlternateSignatories.Skip(1))
                                                                        {
                                                                            <li class="no-bullet" style="display:flex;">
                                                                                <span class="sec" style="padding-left:6%">@alt.email</span>
                                                                            </li>
                                                                        }

                                                                        // Render the delegator label and email
                                                                        <li class="no-bullet delegator-section" style="display:flex;">
                                                                            <span class="sec" style="padding-left:6%">Delegator:</span>
                                                                        </li>
                                                                        <li class="no-bullet delegator-section" style="display:flex;">
                                                                            <span class="sec" style="padding-left:6%">@i.Signer.email</span>
                                                                        </li>
                                                                    }
                                                                    else
                                                                    {
                                                                        <li class="first-email" style="display:flex;justify-content:start;">
                                                                            <span class="sec" style="padding-left:6%">@i.Signer.email</span>
                                                                        </li>
                                                                    }


                                                                }
                                                            }

                                                        }
                                                    </ul>
                                                </div>
                                            }

                                        </div>
                                    }

                                </div>
                            </div>
                        </td>
                        @* @if (item.DisableOrder == false) {
            @if (item.Status == "New" || item.Status == "In Progress")
            {
            var firstUser = item.PendingSignList.FirstOrDefault();
            if (firstUser != null && firstUser.suid == @Suid)
            {
