<script src="~/local-cdns/Shared/pdfjs/2.10.377/pdf.min.js"></script>
<script>
    var pdfjsLib = window['pdfjs-dist/build/pdf'];
    if (!pdfjsLib) {
        console.error('PDF.js library is not loaded.');
    } else {
        pdfjsLib.GlobalWorkerOptions.workerSrc = '@Url.Content("~/local-cdns/Shared/pdfjs/2.10.377/pdf.worker.min.js")';
    }
    var loginOrgId = '@OrganizationUid';
    var viewName = "RefferedDocuments";
    var bulksignPermisson = '@bulksign';
    var suid = '@Suid';
    $(document).ready(function () {
        $('#networkOverlay').hide();
        $('#refferedList').DataTable({
        paging: true,
        lengthChange: false,
        pageLength: 5,
        orderClasses: false,
        stripeClasses: [],
        info: true,
        "ordering": false
        });

        updateTimestamps();


    });


    // Overlay function for showing loader
    function showOverlay(matchedEsealData, matchedSignData) {
        if (matchedEsealData == null && matchedSignData !== null) {
            $('#overlay8').css('display', 'flex');
        } else if (matchedEsealData !== null && matchedSignData === null) {
            $('#overlay6').css('display', 'flex');

        } else if (matchedEsealData !== null && matchedSignData !== null) {
            $('#overlay7').css('display', 'flex');

        } else {
            $('#overlay8').css('display', 'flex');

        }
    }

    // Overlay function for hiding loader
    function hideOverlay(matchedEsealData, matchedSignData) {
        if (matchedEsealData == null && matchedSignData !== null) {
            $('#overlay8').hide();
        } else if (matchedEsealData !== null && matchedSignData === null) {
            $('#overlay6').hide();

        } else if (matchedEsealData !== null && matchedSignData !== null) {
            $('#overlay7').hide();
        } else {
            $('#overlay8').hide();

        }

    }




    var formbase64 = "";

    function renderPDF(pdf) {
        const pdfContainer = document.getElementById('pdf-container');
        pdfContainer.innerHTML = '';
        const numPages = pdf.numPages;
        for (let pageNum = 1; pageNum <= numPages; pageNum++) {
            pdf.getPage(pageNum).then(page => {
                const scale = 1.5;
                const viewport = page.getViewport({ scale });
                const canvas = document.createElement('canvas');
                const context = canvas.getContext('2d');
                canvas.height = viewport.height;
                canvas.width = viewport.width;
                canvas.style.width = '100%';
                const pageContainer = document.createElement('div');
                pageContainer.className = 'pdf-page';
                pageContainer.style.position = 'relative';
                pageContainer.appendChild(canvas);
                pdfContainer.appendChild(pageContainer);

                const renderContext = {
                    canvasContext: context,
                    viewport: viewport
                };
                page.render(renderContext)
            });
        }

    }

    function fillFormData(tempId, edmsId, documentName, flag, docuid, status) {
        $.ajax({
            type: "POST",
            url: '@Url.Action("ValidateEseal", "FormRequests")',
            data: {
                docuid: docuid,

            },
            beforeSend: function () {
                $('#overlay').show();
            },
            complete: function () {
                $('#overlay').hide();
            },

            success: function (response) {
                if (response.success) {
                    $('#overlay').hide();
                    document.getElementById('navigationNetworkOverlay').style.display = 'block'
                    window.location.href = '@Url.Action("FillFormData", "FormRequests")' + `?tempId=${tempId}&edmsId=${edmsId}&documentName=${encodeURIComponent(documentName)}&flag=${flag}&docuid=${docuid}&Status=${status}`;

                } else {
                    // Show Swal message if validation fails
                    swal({
                        icon: "error",
                        title: "Info",
                        text: response.message,
                    });
                }
            },
            error: ajaxErrorHandler
        });
    }


    function base64ToArrayBuffer(base64) {
        const binaryString = window.atob(base64);
        const len = binaryString.length;
        const bytes = new Uint8Array(len);
        for (let i = 0; i < len; i++) {
            bytes[i] = binaryString.charCodeAt(i);
        }
        return bytes.buffer;
    }
    function modalForm(EdmsId, SignerName, status1) {
        const ele = document.getElementById('downloadbutton');
        const ele1 = document.getElementById('showclose');
        if (status1 === "In Progress") {

            if (ele) {
                ele.style.display = 'none'
            }
            if (ele1) {
                ele1.style.marginLeft = "auto";
            }
        }
        else {
            if (ele) {
                ele.style.display = 'block'
            }
            if (ele1) {
                ele1.style.marginLeft = "3%"
            }
        }
        $("#digitalShowModal").modal('show');
        FileName = SignerName + "_signed";

        $.ajax({
            url: '@Url.Action("GetPreviewConfig", "DigitalForms")',
            type: 'GET',
            data: {
                edmsId: EdmsId
            },
            beforeSend: function () {
                $('#overlay').show();
            },
            complete: function () {
                $('#overlay').hide();
            },
            success: function (resp) {
                if (resp.success) {

                    formbase64 = resp.result;
                    const pdfArrayBuffer = base64ToArrayBuffer(resp.result);
                    pdfjsLib.getDocument({ data: pdfArrayBuffer }).promise.then(pdf => {
                        renderPDF(pdf);
                    }).catch(error => {
                        console.error('Error loading PDF:', error);
                    });

                } else {
                    swal({
                        title: 'Error',
                        text: resp.message,
                        type: 'error',
                    }, function (isConfirm) {
                        if (isConfirm) {
                            document.getElementById("navigationNetworkOverlay").style.display = "block";
                            window.location.href = '@Url.Action("Index", "DigitalForms")';
                        }
                    });
                }
            },
            error: function (xhr, status, error) {

                swal({
                    title: 'Error',
                    text: 'Something went wrong!',
                    type: 'error',
                }, function (isConfirm) {
                    if (isConfirm) {
                        document.getElementById("navigationNetworkOverlay").style.display = "block";
                        window.location.href = '@Url.Action("Index", "DigitalForms")';
                    }
                });
            }
        });
    }

    function DownloadForm() {
        var byteCharacters = atob(formbase64); // decode base64
        var byteNumbers = new Array(byteCharacters.length);

        for (var i = 0; i < byteCharacters.length; i++) {
            byteNumbers[i] = byteCharacters.charCodeAt(i);
        }

        var byteArray = new Uint8Array(byteNumbers);
        var blob = new Blob([byteArray], { type: 'application/pdf' });

        // Create a download link and trigger the download
        var link = document.createElement('a');
        link.href = URL.createObjectURL(blob);
        link.download = 'SignedForm.pdf'; // The name of the downloaded file
        link.click(); // Trigger the download
    };
</script>