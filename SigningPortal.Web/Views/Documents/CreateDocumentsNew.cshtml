        window.IndexDocuments = '@Url.Action("MyDocumentsList", "Documents")';
        window.OrgDetailsByEmail = '@Url.Action("OrgDetailsByEmail", "Documents")';
        window.SendSigningRequest = '@Url.Action("SendSigningRequest", "Documents")';
        window.sentredirecturl = '@Url.Action("SentDocumentsList", "Documents")';
        window.GetFileConfigurationUrl = '@Url.Action("GetFileConfiguration", "Documents")';
        window.DocumentDetailsByIdUrl = '@Url.Action("DocumentDetailsById", "Documents")';
        window.GetPreviewimagesUrl = '@Url.Action("GetPreviewimages", "Documents")';
        window.ProcessRecipientsUrl = '@Url.Action("ProcessRecipients", "Documents")';
        window.GetDelegationbyorgidsuidUrl = '@Url.Action("GetDelegationbyorgidsuid", "Documents")';
        window.IndexLogin = '@Url.Action("Index", "Login")';
        window.GetStoratgeConfiguration = '@Url.Action("GetStoratgeConfiguration", "StorageIntegrationCallback")';
        window.GetTemplatePreviewimages = '@Url.Action("GetTemplatePreviewimages", "Documents")';
        window.paramval = '@ViewBag.ParamValue';
