                                                                                                                   SIGNATURE TEMPLATES DROPDOWN - ENHANCED
                                                                                                                   ======================================== */
    .workflow-field {
        display: flex;
        flex-direction: row;
        gap: 8px;
    }

        .workflow-field .form-label {
            font-size: 0.875rem;
            font-weight: 600;
            color: #374151;
            margin: 0;
        }

    .template-select-row {
        display: flex;
        align-items: center;
        gap: 10px;
    }

        /* Modern Select Wrapper */
        .template-select-row .select-wrapper {
            position: relative;
            flex: 1;
            display: flex;
            align-items: center;
            background: #FFFFFF;
            border: 1px solid #D1D5DB;
            border-radius: 10px;
            height: 40px;
            overflow: hidden;
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.03);
        }

            .template-select-row .select-wrapper:hover {
                border-color: #9CA3AF;
                box-shadow: 0 2px 6px rgba(0, 0, 0, 0.06);
            }

            .template-select-row .select-wrapper:focus-within {
                border-color: #2563EB;
                box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.08);
            }

        /* Enhanced Select Element */
        .template-select-row .form-select {
            -webkit-appearance: none;
            -moz-appearance: none;
            appearance: none;
            width: 100%;
            height: 100%;
            padding: 0 36px 0 12px;
            border: none;
            background: transparent;
            font-size: 0.875rem;
            font-weight: 500;
            color: #1F2937;
            cursor: pointer;
            outline: none;
            line-height: 1.5;
        }

            .template-select-row .form-select:focus {
                outline: none;
            }

            .template-select-row .form-select option {
                padding: 10px;
                background: #ffffff;
                color: var(--text-primary);
            }

        /* Enhanced Dropdown Arrow Icon */
        .template-select-row .select-wrapper .select-icon {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            pointer-events: none;
            font-size: 0.75rem;
            color: #6B7280;
            transition: all 0.25s ease;
        }

        .template-select-row .select-wrapper:hover .select-icon {
            color: #374151;
        }

    /* Preview Button - Modern Styling */
    .template-preview-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        background: #EFF6FF;
        border: 1px solid #BFDBFE;
        border-radius: 10px;
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        flex-shrink: 0;
    }

        .template-preview-btn:hover {
            background: var(--primary-blue);
            border-color: var(--primary-blue);
