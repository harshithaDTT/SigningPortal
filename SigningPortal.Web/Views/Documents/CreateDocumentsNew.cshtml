<div class="page-container" id="create">
   
    <form id="createDoc" enctype="multipart/form-data" style="padding:1rem">
        @Html.AntiForgeryToken()
        <input type="checkbox" id="addSignatoriesCheckbox" class="classshide" />
        <input type="checkbox" id="DiasbleOrder" name="DiasbleOrder" class="classshide" />
        <input type="checkbox" id="AllSignatoriesRequired" name="AllSignatoriesRequired" class="classshide" checked />
        <!-- SCREEN 1: UPLOAD DOCUMENT (BEFORE UPLOAD) -->
        <div id="uploadScreen" class="upload-screen">
            <div class="page-header">
                <div class="page-header-content">
                    <h1 class="page-title">Upload Document</h1>
                    <p class="page-subtitle">Choose your document from local storage or cloud drive</p>
                </div>
                <div class="step-indicator">
                    <span class="step-indicator__current">1</span>
                    <span class="step-indicator__text">Step 1</span>
                    <span class="step-indicator__total">of 3</span>
                    <span class="step-indicator__divider"></span>
                    <span class="step-indicator__label">Upload</span>
                </div>
            </div>

            <div class="upload-grid">
                <!-- Local Storage Card -->
                <div class="storage-card">
                    <div class="card-header">
                        <div class="card-icon">
                            <i class="fa fa-hdd" aria-hidden="true"></i>
                        </div>
                        <div>
                            <h2 class="card-title">Local Storage</h2>
                            <p class="card-description">Drag & drop or browse files</p>
                        </div>
                    </div>

                    <div role="button" tabindex="0" class="dropzone" id="dropzone">
                        <div class="sr-only">
                            <input asp-for="File" type="file" accept=".docx,.pdf,.xlsx" autocomplete="off" tabindex="-1" id="File">
                        </div>

                        <div class="dropzone-icon">
                            <i class="fa fa-cloud-upload" aria-hidden="true"></i>
                        </div>
                        <h3 class="dropzone-title">Drag & drop your document</h3>
                        <p class="dropzone-subtitle">or click to browse from your device</p>
                        <button type="button" class="btn-primary" id="browseButton">
                            <i class="fa fa-file"></i>
                            Browse Files
                        </button>
                        <p class="file-support-text">
                            <strong>Supported:</strong> PDF, DOCX, XLSX (Max 100MB)
                        </p>
                    </div>
                </div>

                <!-- Cloud Storage Card -->
                <!-- Cloud Storage Card -->
                <div class="cloud-card" id="driveIntegration">

                    <div class="card-header">
                        <div class="card-icon">
                            <i class="fa fa-cloud" aria-hidden="true"></i>
                        </div>
                        <div>
                            <h2 class="card-title">Cloud Storage</h2>
                            <p class="card-description">Upload documents from cloud storage.</p>
                        </div>
                    </div>

                    <div class="cloud-providers">

                        <!-- Google Drive -->
                        <button type="button" class="cloud-provider-btn" id="googleDirve" data-modern-id="googleDrive">
                            <div class="provider-info">
                                <div class="provider-logo icon-logo" style="background:#E0F2FF;">
                                    <i class="fa-brands fa-google"></i>
                                </div>
                                <div>
                                    <div class="provider-name" style="text-align:left">Google Drive</div>
                                    <div class="provider-description">Access files from your Google Drive</div>
                                </div>
                            </div>
                            <span class="btn-connect">Upload</span>
                        </button>

                        <!-- OneDrive -->
                        <button type="button" class="cloud-provider-btn" id="oneDrive">
                            <div class="provider-info">
                                <div class="provider-logo icon-logo" style="background:#E0F2FF;">
                                    <i class="fa-brands fa-microsoft"></i>
                                </div>
                                <div>
                                    <div class="provider-name" style="text-align:left">OneDrive</div>
                                    <div class="provider-description">Connect to Microsoft OneDrive</div>
                                </div>
                            </div>
                            <span class="btn-connect">Upload</span>
                        </button>

                    </div>

                    <div class="cloud-note">
                        <strong>Note:</strong> Cloud integrations require authorization. You'll be redirected to authenticate with your cloud provider.
                    </div>

                </div>

            </div>
        </div>

        <!-- SCREEN 2: PREPARE DOCUMENT (AFTER UPLOAD) -->
        <div id="prepareScreen" class="prepare-screen">
            <div class="page-header">
                <div class="page-header-content">
                    <h1 class="page-title">Prepare Document</h1>
                    <p class="page-subtitle">Configure document details before sending for signatures</p>
                </div>
                <div class="step-indicator">
                    <span class="step-indicator__current">2</span>
                    <span class="step-indicator__text">Step 2</span>
                    <span class="step-indicator__total">of 3</span>
                    <span class="step-indicator__divider"></span>
                    <span class="step-indicator__label">Configure</span>
                </div>
            </div>

            <div class="prepare-card">
                <!-- Header -->
                <div class="prepare-header">
                    <div class="prepare-badge">
                        <i class="fa fa-folder-open"></i>
                        Prepare Document
                    </div>
                </div>

                <!-- Body -->
                <div class="prepare-body">
                    <!-- File Info -->
                    <div class="file-info-box d-none" id="fileInfoDisplay">
                        <div class="file-icon-large">
                            <i class="fa fa-file-pdf"></i>
                        </div>
                        <div class="file-details">
                            <h4 id="fileNameDisplay1">Document.pdf</h4>
                            <p class="file-meta mb-0"><span id="fileSizeDisplay1">0.17</span>&nbsp;<span>MB</span>&nbsp;<span id="fileTypeDisplay">PDF</span></p>
                        </div>
                    </div>

                    <!-- Form Fields -->
                    <div class="signature-config-section">
                        <div class="config-header">
                            <i class="fa fa-file-lines"></i>
                            <span>Document Details</span>
                        </div>
                        <div class="form-grid">
                            <div class="form-group d-none">
                                <label class="form-label" asp-for="DocumentName">
                                    Document Title<span class="required">*</span>
                                </label>
                                <input asp-for="DocumentName" class="form-input" id="DocumentName" placeholder="Enter document title" readonly />
                                <span asp-validation-for="DocumentName" class="text-error"></span>
                            </div>


                            <div class="form-grid" style="display:inline-flex;gap:15px;padding:1rem">
                                <div class="file-icon-large">
                                    <i class="fa fa-file-pdf"></i>
                                </div>
                                <div class="file-details">
                                    <h4 id="fileNameDisplay">Document.pdf</h4>
                                    <p class="file-meta mb-0"><span id="fileSizeDisplay">0.17 MB</span>&nbsp;<span id="fileTypeDisplay">PDF</span></p>
                                </div>
                            </div>

                            <div class="form-group">
                                <label class="form-label" asp-for="DaysToComplete">
                                    Days to Complete<span class="required">*</span>
                                </label>
                                <input asp-for="DaysToComplete" type="number" class="form-input" id="DaysToComplete" value="3" min="2" max="6" />
                                <p class="expiry-info">Expires on: <span id="expiryDate"></span></p>
                                <span id="daysToCompleteError" class="text-error"></span>
                            </div>
                        </div>

                    </div>

                    <!-- Hidden Inputs for File Upload Processing -->
                    <input type="hidden" id="filebase64" name="filebase64" value="" />
                    <input type="hidden" id="originalFileName" name="originalFileName" value="" />

                    <!-- Signature Configuration (Document-level settings) -->
                    <div class="signature-config-section" id="signatureConfigSection">
                        <div class="config-header">
                            <i class="fa fa-pen-fancy"></i>
                            <span>Signing Requirements</span>
                        </div>
                        <div class="config-grid">
                            <!-- Template Selector -->
                            <div class="config-item template-item" id="templateSelectdiv" style="border:none;background:none">
                                <div class="config-label">Signature Template</div>
                                <div class="config-control">
                                    <select name="TemplateName" id="templateSelect" class="config-select">
                                        @foreach (var item in Model.Templates.Where(x => x.Type.ToLower() == "sign"))
                                        {
                                            <option data-preview="@item.SamplePreview" value="@item.Id">@item.DisplayName</option>
                                        }
                                    </select>
                                    <button type="button" id="innerModel" class="config-preview-btn" title="Preview template">
                                        <i class="fa fa-eye"></i>
                                    </button>
                                </div>
                            </div>
                            <!-- Requirement Toggles -->
                            <div class="config-item toggle-item" id="InitialReq" style="display:none;">
                                <div class="config-label">
                                    <i class="fa-solid fa-signature" style="margin-right:1px"></i>
                                    Initials
                                </div>
                                <label class="config-toggle">
                                    <input type="checkbox" class="custom-check-box initialCheckBox" id="InitialRequired" name="InitialRequired" value="1">
                                    <span class="toggle-track"></span>
                                </label>
                            </div>
                            <div class="config-item toggle-item" id="EsealReq" style="display:none;">
                                <div class="config-label">
                                    <i class="fa-solid fa-stamp" style="margin-right:1px"></i>

                                    E-Seal
                                </div>
                                <label class="config-toggle">
                                    <input type="checkbox" class="custom-check-box esealCheckBox" id="Eseal_Required" name="RecpientList[0].Eseal" value="1">
                                    <span class="toggle-track"></span>
                                </label>
                            </div>
                            <div class="config-item toggle-item" id="QrCodeReq" style="display:none;">
                                <div class="config-label">
                                    <i class="fa-solid fa-qrcode" style="margin-right:1px"></i>
                                    QR Code
                                </div>
                                <label class="config-toggle">
                                    <input type="checkbox" class="custom-check-box" id="QrCodeRequired" name="QrCodeRequired" value="1">
                                    <span class="toggle-track"></span>
                                </label>
                            </div>
                        </div>
                        <!-- Warning -->
                        <div id="signatureWarning" class="config-warning">
                            <i class="fa fa-info-circle"></i>
                            <span>
                                Signed documents do not support @if (AccountType != "Self"){
                                <text>initials, QR codes, or </text>
                                                                }
                                watermarks.
                            </span>
                        </div>
                    </div>

                    <!-- Recipients & Workflow -->
                    <div class="recipients-section sequential-mode" id="signatorySection">
                        <div class="recipients-header">
                            <div class="recipients-title">
                                <i class="fa fa-users"></i>
                                <h3>Recipients</h3>
                                <span class="recipient-count-badge" id="recipientCount">0</span>
                            </div>
                            <button type="button" class="btn-add-recipient" id="addRecipientBtn">
                                <i class="fa fa-plus"></i>
                                <span>Add Recipient</span>
                            </button>
                        </div>

                        <!-- Signing Mode Selector (visible when 2+ recipients) -->
                        <div class="signing-mode-container" id="signingModeContainer" style="display:none;">
                            <span class="signing-mode-label">Signing Mode</span>
                            <div class="signing-mode-selector" id="signingModeSelector">
                                <button type="button" class="signing-mode-option active" data-mode="sequential" id="sequentialModeBtn">
                                    <i class="fa fa-arrow-down-1-9"></i>
                                    <span>Sequential</span>
                                </button>
                                <button type="button" class="signing-mode-option" data-mode="parallel" id="parallelModeBtn">
                                    <i class="fa-solid fa-grip-lines-vertical"></i>
                                    <span>Parallel</span>
                                </button>
                            </div>
                            <div class="min-signatures-display" id="minSignaturesDisplay" title="Click to edit minimum required signatures">
                                <i class="fa fa-check-circle"></i>
                                <span class="min-sig-text">Required: <span class="sig-count" id="requiredSignaturesCount">0</span> of <span id="totalRecipientsCount">0</span></span>
                                <input type="number" class="sig-count-input" id="minSigInput" min="0" max="99" value="0" />
                                <span class="edit-total-text">of <span class="edit-total-count">0</span></span>
                            </div>
                        </div>

                        <!-- Hidden inputs for legacy compatibility -->
                        <input type="hidden" id="sequentialSigning" value="true" />
                        <input type="hidden" id="allSignersRequiredToggle" value="true" />
                        <input type="hidden" id="RequiredSignatureInput" asp-for="RequiredSignatureNo" value="1" />

                        <!-- Container for dynamically added recipient cards -->
                        <div id="recplist" class="recipient-cards-wrapper">
                            <div id="recipientsList" class="recipients-list"></div>
                        </div>
                    </div>
                </div>

                <!-- Footer Actions -->
                <div class="action-footer">
                    <button type="button" class="btn-cancel" id="cancelBtn">Cancel</button>
                    <button type="button" class="btn-quick" id="quickSign">Quick Sign</button>
                    <button type="button" class="btn-save" id="Continue">
                        <span id="continueButtonText">Continue</span>
                    </button>
                </div>
            </div>
    </form>
</div>

<!-- Viewer Section (Hidden by default, shown when Continue is clicked) -->
<div class="card-body background-image classshide pr-0 mr-0 ml-3" id="viwer">
    <div class="viewer-flex-container">

        <!-- LEFT: PDF Viewer -->
        <div id="viewerdivtag" class="viewer-left">

            <!-- Toolbar -->
            <div class="viewer-toolbar" id="viewerToolbar">
                <div class="zoom-controls">
                    <button type="button" class="toolbar-btn" id="zoomOutBtn">
                        <i class="fa fa-search-minus"></i>
                    </button>
