        .file-support-text {
            display: none;
        }

        .cloud-providers {
            flex-direction: row;
            flex-wrap: wrap;
            gap: clamp(0.25rem, 0.5vh, 0.375rem);
            margin-bottom: clamp(0.1875rem, 0.5vh, 0.375rem);
        }

        .cloud-provider-btn {
            flex: 1;
            min-width: 140px;
            padding: clamp(0.25rem, 0.75vh, 0.375rem);
        }

        .provider-description {
            display: none;
        }

        .provider-logo {
            width: clamp(20px, 3vh, 24px);
            height: clamp(20px, 3vh, 24px);
        }

        .provider-name {
            font-size: clamp(0.625rem, 0.875vh, 0.6875rem);
        }

        .btn-connect {
            padding: clamp(3px, 0.5vh, 4px) clamp(6px, 1vw, 8px);
            font-size: clamp(0.5625rem, 0.75vh, 0.625rem);
        }

        .cloud-note {
            display: none;
        }
    }

    /* ========================================
                                                           UPLOAD ROW VERTICAL BUDGET (CARD-LEVEL COORDINATION) - ADDED
                                                           Ensures combined card height never exceeds viewport. Internal panels
                                                           (dropzone, provider list) shrink first and scroll internally when needed.
                                                           ======================================== */

    /* Primary constraint for tablets and small screens */
    @@media (max-width: 1024px) and (max-height: 900px) {
        .upload-grid {
            /* Reserve ~140px for header + spacing; adjust if header changes */
            max-height: calc(100svh - 140px);
            grid-auto-rows: 1fr; /* rows will share available vertical space when stacked */
            align-items: stretch;
        }
        /* Cards become full-height flex columns so their internals can flex */
        .storage-card,
        .cloud-card {
            display: flex;
            flex-direction: column;
            height: 100%;
            flex: 1 1 0%;
            min-height: 0; /* critical for flex children to shrink properly */
        }
        /* Header and note are fixed-size (do not take flex space) */
        .card-header,
        .cloud-note {
            flex: 0 0 auto;
        }
        /* Panels that contain the bulk of content should shrink first and scroll internally */
        .dropzone,
        .cloud-providers {
            flex: 1 1 auto;
            min-height: 0;
            overflow: auto;
        }
        /* Preserve readability by slightly tightening line-height under budget */
        .dropzone-title,
        .dropzone-subtitle,
        .file-support-text {
            line-height: 1.3;
        }
    }

    /* Stronger constraint for shorter/tablet heights */
    @@media (max-width: 1024px) and (max-height: 700px) {
        .upload-grid {
            max-height: calc(100svh - 120px);
        }

        .dropzone,
        .cloud-providers {
            padding-left: clamp(0.5rem, 1vw, 0.75rem);
            padding-right: clamp(0.5rem, 1vw, 0.75rem);
        }
    }

    /* Very constrained heights (landscape phones) */
    @@media (max-height: 560px) {
        .upload-grid {
            max-height: calc(100svh - 88px);
        }
        /* Hide non-essential supportive text only in extreme constraints */
        .card-description,
        .dropzone-subtitle,
        .file-support-text,
        .provider-description,
        .cloud-note {
            display: none;
        }
        /* Keep main panels scrollable */
        .dropzone,
        .cloud-providers {
            overflow: auto;
        }
    }
</style>

@{
    await Html.RenderPartialAsync("_AlertBox");
