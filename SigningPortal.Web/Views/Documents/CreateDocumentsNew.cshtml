        window.SelfEmails = '@selfemails';
        window.loginSuid = '@userSuid';
        window.loginName = '@name';
        window.loginorgUid = '@OrganizationUid';
        window.loginuserAccount = '@AccountType';
        window.loginorgName = '@OrganizationName';
        window.loginesealsignatoryrole = '@login_esealsignatoryrole';
        window.initial_Image = '';
