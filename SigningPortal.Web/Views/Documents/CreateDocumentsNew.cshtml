            font-size: 1.125rem;
            color: var(--primary-blue);
            transition: color 0.2s ease;
        }

        .template-preview-btn:hover i {
            color: #ffffff;
        }

        .template-preview-btn:active {
            transform: translateY(0);
            box-shadow: 0 2px 6px rgba(37, 99, 235, 0.2);
        }

