        if (window.loginuserAccount == 'Self') {
           $('#signatureConfigSection').hide();
        }
    </script>

    <script>
        // ========================================
        // INITIALIZATION - Event Setup Delegation
        // ========================================
        // Pure JavaScript initialization moved to CreateDocumentsNew.js
        // This section only initializes the document setup

        window.globalFile = null;
        window.workerpath = '@Url.Content("~/local-cdns/Shared/pdfjs/2.10.377/pdf.worker.min.js")';

        $(document).ready(function () {
            // Delegate to external .js functions
            if (typeof window.initializeUI === 'function') {
                window.initializeUI();
            }
            if (typeof window.setupEventListeners === 'function') {
                window.setupEventListeners();
            }
        });
    </script>

    <!-- Toastr CDN injection and account dropdown UI helpers moved to CreateDocumentsNew.js -->
    <!-- These helper functions are now part of the external .js file initialization -->
    @if (Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Development")
    {
        <script src="~/js/Documents/CreateDocumentsNew.js" type="text/javascript" asp-append-version="true" defer></script>
    }
    else
    {
        <script src="~/js/Documents/CreateDocumentsNew.js" type="text/javascript" asp-append-version="true" defer></script>
    }

    <!-- Account dropdown UI helpers moved to CreateDocumentsNew.js -->
