    /* ========================================
                                                                                                                   ACCOUNT DROPDOWN LOADER - ALIGNED FIX
                                                                                                                   ======================================== */
    /* Container for select + loader */
    .recipient-account-dropdown .selctloader {
        display: flex;
        align-items: center;
        flex: 1;
        position: relative;
        height: 100%;
        gap: 8px;
    }

        /* Loader positioned to the right, before chevron */
        .recipient-account-dropdown .selctloader .loader {
            display: none; /* hidden by default, shown via JS */
            flex-shrink: 0;
            height: 18px !important;
            width: 18px;
            position: relative;
            margin-right: 4px;
        }

            /* Handle both display:block and display:flex set by JS */
            .recipient-account-dropdown .selctloader .loader[style*="display: block"],
            .recipient-account-dropdown .selctloader .loader[style*="display:block"],
            .recipient-account-dropdown .selctloader .loader[style*="display: flex"],
            .recipient-account-dropdown .selctloader .loader[style*="display:flex"] {
                display: flex !important;
                align-items: center;
                justify-content: center;
            }

            .recipient-account-dropdown .selctloader .loader img {
                width: 18px;
                height: 18px;
                object-fit: contain;
            }

    /* Chevron icon positioning - fixed to right side */
    .recipient-account-dropdown .account-wrapper > .fa-chevron-down {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        pointer-events: none;
        color: var(--text-secondary);
        font-size: 0.9rem;
        transition: color 0.2s ease;
        z-index: 1;
    }

    .recipient-account-dropdown .account-wrapper:hover > .fa-chevron-down {
        color: var(--primary-blue);
    }

    /* Adjust select padding to make room for loader + chevron */
    .recipient-account-dropdown .selctloader .account-select {
        padding-right: 60px; /* space for loader (18px) + gap (8px) + chevron (16px) + margin */
        padding-left: 10px;
    }

    /* When loader is visible, ensure chevron stays in place */
    .recipient-account-dropdown .account-wrapper:has(.loader[style*="display: block"]) > .fa-chevron-down,
    .recipient-account-dropdown .account-wrapper:has(.loader[style*="display:block"]) > .fa-chevron-down,
    .recipient-account-dropdown .account-wrapper:has(.loader[style*="display: flex"]) > .fa-chevron-down,
    .recipient-account-dropdown .account-wrapper:has(.loader[style*="display:flex"]) > .fa-chevron-down {
        right: 12px; /* keep position stable */
    }

    /* ========================================
                                                                                                                   END LOADER FIX
                                                                                                                   ======================================== */

    /* make sure the email input and account dropdown are visually aligned */
    .recipient-fields .form-input, .recipient-account-dropdown .account-wrapper {
        height: 44px;
        padding-left: 0px;
