    /* ========================================
                                                                                                                                       STEPPER MODAL (MODERNIZED)
                                                                                                                                       ======================================== */

    .stepper-surface {
        width: 100%;
        background: var(--bg-card);
        border-radius: var(--radius-xl);
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        text-align: center;
        overflow: hidden;
    }

    .stepper-heading {
        border-top-left-radius: var(--radius-xl);
        border-top-right-radius: var(--radius-xl);
        color: #fff;
        font-weight: 600;
        font-size: 1.125rem;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(90deg, var(--accent-green) 0%, var(--dark-green) 100%);
        padding: 20px;
    }

    .stepper-body {
        padding: 1rem;
        padding-top: 1.25rem;
        min-height: 300px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .stepper-layout {
        display: flex;
        justify-content: center;
        align-items: center;
        margin-bottom: 32px;
        position: relative;
        gap: 0;
    }

    .stepper-col {
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
        flex: 1;
    }

    .stepper-circle {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 12px;
        font-size: 18px;
        font-weight: 600;
        transition: all 0.3s ease;
        position: relative;
        z-index: 2;
    }

    .stepper-circle-active {
        background: linear-gradient(135deg, var(--accent-green) 0%, var(--dark-green) 100%);
        color: #fff;
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
    }

    /* Blinking / pulse helpers for active steps */
    .stepper-circle.blinking,
    .circle.blinking {
        animation: stepPulse 1.1s ease-in-out infinite;
    }

    @@keyframes stepPulse {
        0% {
            box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.45);
            transform: scale(1);
        }

        50% {
            box-shadow: 0 0 0 12px rgba(16, 185, 129, 0);
            transform: scale(1.06);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(16, 185, 129, 0);
            transform: scale(1);
        }
    }

    /* Explicit image glow keyframes used by JS */
    @@keyframes blinkGreenGlow {
        0% {
            box-shadow: 0 0 0 0 rgba(16,185,129,0.45);
        }

        50% {
            box-shadow: 0 0 20px 6px rgba(16,185,129,0.22);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(16,185,129,0);
        }
    }

    @@keyframes blinkRedGlow {
        0% {
            box-shadow: 0 0 0 0 rgba(210,23,23,0.45);
        }

        50% {
            box-shadow: 0 0 20px 6px rgba(210,23,23,0.22);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(210,23,23,0);
        }
    }

    /* Convenience classes (optional) */
    .blink-green {
        animation: blinkGreenGlow 1s infinite;
    }

    .blink-red {
        animation: blinkRedGlow 1s infinite;
    }


    .stepper-circle-muted {
        background: #e2e8f0;
        color: #94a3b8;
    }

    .stepper-line {
        height: 3px;
        background-color: #e2e8f0;
        position: absolute;
        top: 24px;
        left: 50%;
