                <thead>
                    <tr style="border:none;"><th style="border:none;"></th></tr>
                </thead>
            </table>


            <div class="d-flex justify-content-center mt-4">
                <div id="allDocsLoadedMsgAction"
                     class="docs-message text-center"
                     style="display:none; width:70%;">

                    <!-- Top Divider with Text -->
