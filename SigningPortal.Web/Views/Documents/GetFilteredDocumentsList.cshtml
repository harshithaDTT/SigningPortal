                <div class="d-flex custom-checkbox-wrapper">
                    <input type="checkbox" class="custom-checkbox" id="selectAllCheckbox" style="margin-right:17px;margin-top:8px;">

                    <label id="selectAllCheckboxlabel" style="margin-top:9px;font-size:medium;">Select All</label>
                </div>

            }
            else
            {

                <div class="d-flex custom-checkbox-wrapper">
                    <input type="checkbox" class="custom-checkbox" id="selectAllCheckbox" style="margin-right:17px;display:none;margin-top:8px;">

                    <label id="selectAllCheckboxlabel" style="margin-top:3px;font-size:medium;display:none;">Select All</label>
