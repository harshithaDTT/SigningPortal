@using System.Security.Claims;
@using Newtonsoft.Json;
@{
    ViewData["Title"] = "View";
}
@{
    var DocumntsStatus = ViewBag.DocumntsStatus;

    var Suid = User.FindFirst(ClaimTypes.UserData).Value;
    var userEmail = User.FindFirst(ClaimTypes.Email).Value;
    var AccountType = User.FindFirst("AccountType").Value;
    var OrganizationUid = "";
    if (AccountType != "Self")
    {

        OrganizationUid = User.FindFirst("OrganizationUid").Value;
    }
}
<link rel="stylesheet" href="~/local-cdns/Shared/fontawesome/6.4.0/css/all.min.css">
<style>

    .viewbutton {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 32px;
        background: #d1f4e0;
        color: #198754;
        font-size: 16px;
        border: none;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
    }

        .viewbutton:hover {
            background: #0ea66b;
            border-color: #0ea66b;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(25, 135, 84, 0.2);
        }

    /* Tooltip */
    .tooltip-message {
        visibility: hidden;
        opacity: 0;
        position: absolute;
        background-color: #333;
        color: #fff;
        padding: 4px 8px;
        border-radius: 4px;
        top: 35px;
        left: 100px;
        transform: translateX(-50%);
        font-size: 12px;
        white-space: nowrap;
        transition: opacity 0.2s;
        z-index: 1;
    }

    .custom-checkbox-wrapper.disabled:hover .tooltip-message {
        visibility: visible;
        opacity: 1;
    }

    .select-mode {
        background-color: darkgrey !important;
    }

    .default-mode {
        background-color: #4caf50 !important;
    }

    .inprogressbtn {
        color: #f57c00;
        text-align: center;
    }

    .Declinedbtn {
        color: red;
        text-align: center;
    }

    .completebtn {
        color: #4caf50 !important;
        text-align: center;
    }

    .otherbtn {
        color: #bdbdbd;
        text-align: center;
    }

    .hidden {
        display: none;
    }



    .card-selected {
        background-color: #f3f3f3 !important; /* Light cyan highlight */
        box-shadow: 0 0 24px rgba(0, 0, 0, .25);
    }

    .status-container {
        position: relative;
        display: inline-block;
    }

    .popup {
        display: none;
        position: absolute;
        min-width: 280px;
        padding: 15px;
        background-image: linear-gradient(90deg, #30b6ac, #81bc73);
        color: #000;
        border-radius: 6px;
        box-shadow: 0 0 24px rgba(0, 0, 0, .25);
        font-size: 80%;
        z-index: 10000;
        opacity: 0;
        transition: opacity 0.3s, visibility 0.3s;
        bottom: 100%;
        /*/ Position above the status / */
        right: 0;
        /*/ Align to the right of the status container / */
        transform: translateX(0) translateY(-10px);
        /*/ Adjust vertical positioning /*/
    }

    .status-container:hover .popup {
        display: block;
        opacity: 1;
        visibility: visible;
    }

    .popup::after {
        content: "";
        position: absolute;
        bottom: -10px;
        /*/ Position the arrow / */
        right: 20px;
        /*/ Adjust arrow to align with the popup /*/
        width: 0;
        height: 0;
        border-left: 10px solid transparent;
        /*/ Transparent left side /*/
        border-top: 10px solid #81bc73;
        /*/ Visible top side /*/
    }

    .popup .header {
        font-weight: 600;
        text-align: center;
        margin-bottom: 0;
        font-size: 14px;
    }

    .popup .headersp {
        padding-bottom: 5px;
        border-bottom: 1px solid;
    }

    .popup .row {
        display: contents;
    }

    .popup p {
        line-height: 1 !important;
        margin-bottom: 0;
        padding-bottom: 5px;
        color: #fff;
        font-weight: 600;
        font-size: 13px;
    }

    .popup ul {
        padding-left: 0;
        color: #fff;
        display: flex;
        flex-direction: column;
        /*/ Ensure vertical alignment /*/
        list-style: none;
    }

        .popup ul li {
            font-size: 14px;
            font-weight: 600;
            position: relative;
            margin-bottom: 0;
        }

            .popup ul li.first-email::before {
                content: "";
                position: absolute;
                left: 0;
                top: 50%;
                transform: translateY(-50%);
                width: 14px;
                height: 14px;
                background-color: transparent;
                border: 2px solid #fff;
                border-radius: 50%;
            }

            .popup ul li.first-email::after {
                content: "";
                width: 6px;
                height: 6px;
                background-color: #fff;
                border-radius: 50%;
                position: absolute;
                top: 50%;
                left: 7px;
                transform: translate(-50%, -50%);
            }

            .popup ul li.no-bullet,
            .popup ul li.delegator-section {
                padding-left: 0;
                list-style-type: none;
                margin-left: 0;
                /*/ Reset margin for left alignment /*/
            }

    /*/ Ensure alignment of items in the popup /*/
    .popup ul {
        padding-left: 0;
        color: #fff;
        display: flex;
        flex-direction: column;
        list-style: none;
    }




    .stats-container {
        display: flex;
        flex-direction: column;
    }

    /* Specific styles for Document Status */
    .docstats-heading {
        font-size: 12px;
        font-weight: 600;
        color: #6c757d;
        margin-bottom: 5px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .docstats-text {
        font-size: 14px;
        font-weight: 500;
        color: #212529;
    }

    /* Specific styles for Signing Status */
    .signingstats-heading {
        font-size: 12px;
        font-weight: 600;
        color: #6c757d;
        margin-bottom: 5px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }



    /* Utility class for gaps */
    .gap-1 {
        gap: 8px;
        display: flex;
        align-items: center;
    }

    .shimmer-wrapper .shimmer-item {
        height: 90px;
        margin-top: 10px;
        margin-bottom: 10px;
        border-radius: 8px;
        background: #f3f3f3;
        position: relative;
        overflow: hidden;
    }

        /* Shimmer band */
        .shimmer-wrapper .shimmer-item::after {
            content: "";
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient( to right, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.6) 50%, rgba(255, 255, 255, 0) 100% );
            animation: shimmer-horizontal 1.6s ease-in-out infinite;
            pointer-events: none;
        }



    @@keyframes shimmer-horizontal {
        0% {
            left: -100%;
        }

        100% {
            left: 100%;
        }
    }


    .toggle-link {
        color: #4A4A4A; /* Neutral dark gray for readability */
        font-weight: 500;
        font-size: 1rem;
        transition: color 0.2s ease-in-out;
        text-decoration: none;
    }

        .toggle-link:hover {
            color: #2C7BE5; /* Modern blue hover (not jarring) */
            text-decoration: underline;
            cursor: pointer;
        }

    .docs-message {
        color: #4A4A4A;
        font-weight: 500;
        font-size: 1rem;
        transition: color 0.2s ease-in-out;
        text-decoration: none;
        white-space: nowrap;
    }

    .sent-by {
        font-size: 14px;
        color: #555;
        display: flex;
        align-items: center;
    }

    .sender-badge {
        color: #555555;
        border-radius: 4px;
        padding: 2px 6px;
        margin-left: 5px;
        font-size: 12px;
        font-weight: 600;
    }

    table, tr, th, td, tbody, tfoot, thead {
        border: none !important;
        border-collapse: collapse;
        padding: 0px !important;
    }

        table thead th {
            padding: 0px !important;
        }


    .search-bar {
        display: flex;
        align-items: center;
        max-width: 400px;
        border: 1px solid #ccc;
        border-radius: 3px;
        overflow: hidden;
        background: #f9f9f9;
    }

    .search-input {
        flex: 1;
        border: none;
        padding: 4px 8px;
        outline: none;
        font-size: 14px;
        border-radius: 25px 0 0 25px;
        background-color: transparent;
    }

    .search-button {
        background-color: rgb(0 0 0 / 20%);
        border: none;
        padding: 0.625rem 0.875rem;
        cursor: pointer;
        border-radius: 0 3px 3px 0;
        color: white;
        font-size: 16px;
    }

        .search-button:focus {
            outline: none;
        }

    .onhoverclass {
        cursor: pointer;
        transition: box-shadow 0.3s ease;
    }

        .onhoverclass:hover {
            box-shadow: 0 3px 12px rgba(0, 0, 0, 0.2) !important;
            transform: scale(1.0125); /* slight zoom */
        }


    .doc-stats-container {
        padding-left: 0px;
    }

    @@media screen and (max-width:1200px) {
        .doc-stats-container {
            padding-left: 89px;
            width: 100%;
        }
    }

    @@media screen and (min-width:1200px) {
        .stats-container {
            min-width: 130px;
        }
    }

    .nd-card {
        background: #fff;
        border-radius: 14px;
        padding: 16px 18px;
        margin-bottom: 16px;
        border: 1px solid #e6f3ee;
        box-shadow: 0 4px 10px rgba(25, 135, 84, 0.15);
    }

    .nd-row {
        display: flex;
        justify-content: space-between;
        gap: 16px;
    }

    /* ---------------- LEFT ---------------- */

    .nd-left {
        display: flex;
        gap: 14px;
        flex: 1;
        align-items: flex-start;
    }

    .nd-icon {
        width: 42px;
        height: 42px;
        background: #0b5c4d;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        flex-shrink: 0;
        margin-top: 2px;
    }

    .nd-info {
        flex: 1;
        min-width: 0;
    }

    .nd-title {
        font-size: 15px;
        font-weight: 600;
        color: #0f172a;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 100%;
    }

    /* TO + DATES */

    .nd-sub {
        margin-top: 4px;
    }

    .nd-to {
        font-size: 13px;
        color: #475569;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

        .nd-to span {
            font-weight: 600;
        }

    .nd-dates {
        margin-top: 2px;
        font-size: 14px;
        font-weight: 500;
        color: #919aa3;
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
    }

    .nd-dot {
        margin: 0 6px;
    }

    /* ---------------- MOBILE STATUS ---------------- */

    .nd-mobile-status {
        display: none;
        margin-top: 8px;
        font-size: 13px;
        color: #475569;
    }



    .nd-label {
        font-weight: 500;
    }

    .nd-value {
        font-weight: 600;
    }

    .nd-users {
        display: flex;
        align-items: center;
        gap: 6px;
        color: #64748b;
        font-size: 12px;
    }

    /* MOBILE ACTION */

    .nd-mobile-action {
        display: none;
        margin-top: 6px;
    }

    .nd-mobile-action-bottom {
        display: none;
        margin-top: 10px;
    }

    /* ---------------- RIGHT (DESKTOP) ---------------- */

    .nd-right {
        display: flex;
        align-items: flex-start;
        gap: 24px;
    }

    /* each status column same width */
    .nd-col {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        justify-content: flex-start;
        min-width: 140px;
    }
    /* heading */
    .nd-head {
        font-size: 12px;
        font-weight: 600;
        color: #7a7a7a;
        margin-bottom: 6px;
        line-height: 1.2;
    }

    .nd-val {
        font-size: 14px;
        font-weight: 600;
        line-height: 1.2;
    }

    /* signed count row */
    .nd-users {
        margin-top: 6px;
        font-size: 12px;
        color: #8a8a8a;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .nd-action {
        margin-left: auto;
        display: flex;
        align-items: center;
    }

    .checkboxContainer.custom-checkbox-wrapper {
        flex-shrink: 0;
    }


    @@media (max-width: 768px) {

        .nd-row {
            flex-direction: column;
        }

        .nd-right {
            display: none;
        }

        .nd-mobile-status {
            display: block;
        }

        .nd-info {
            position: relative;
        }

        .nd-title {
            padding-right: 90px; /* space for button */
        }

        .nd-mobile-action {
            position: absolute;
            display: block;
            top: 0;
            right: 0;
        }
        /* hide bottom button at this size */
        .nd-mobile-action-bottom {
            display: none;
        }

        .nd-title {
            white-space: normal;
        }
    }

    @@media (max-width: 576px) {

        .nd-left {
            gap: 10px;
        }

        .nd-mobile-action {
            display: none;
        }


        .nd-mobile-action-bottom {
            display: block;
        }

            .nd-mobile-action-bottom button,
            .nd-mobile-action-bottom a {
                width: 100% !important;
                display: block;
            }
    }

    @@media (max-width: 480px) {

        .nd-row {
            flex-direction: column;
            gap: 10px;
        }

        .nd-left {
            width: 100%;
        }

        .nd-info {
            width: 100%;
        }
        /* title wrap instead of ellipsis */
        .nd-title {
            white-space: normal;
            line-height: 1.3;
            margin-bottom: 4px;
        }

        .nd-dates {
            font-size: 12px;
            gap: 2px;
        }
        /* button at bottom full width */
        .nd-mobile-action-bottom {
            width: 100%;
            margin-top: 12px;
        }

            .nd-mobile-action-bottom button,
            .nd-mobile-action-bottom .btn,
            .nd-mobile-action-bottom a {
                width: 100%;
            }
        /* reduce padding so card fits better */
        .nd-card {
            padding: 14px;
        }

        .nd-icon {
            width: 36px;
            height: 36px;
            font-size: 15px;
        }

        .checkboxContainer.custom-checkbox-wrapper {
            margin-top: 2px;
        }

        .nd-left {
            gap: 10px;
        }
    }
</style>


<div class="container-fluid p-4" style="background:#F6F7FB; min-height:100vh;">
    @Html.AntiForgeryToken()
    <div class="col-md-12" style="height:100%">

        <div class="d-flex justify-content-between mb-3">
            <h3 class="common-heading-color" id="Filterheading" style="font-size: 25px;"></h3>
            <div id="docsSearchContainer" class="align-items-center gap-2" style="display:none;">
                <label for="searchInput" class="form-label mb-0 fw-semibold pr-1">Search:</label>
                <div class="search-bar">
                    <input type="text" class="search-input" id="searchInput" placeholder="Type File name & Enter" />
                    <button class="search-button" id="searchButton">
                        <i class="fas fa-search"> </i>
                    </button>
                </div>
            </div>
        </div>
        <br />
        <div class="d-flex  mb-4" style="gap:1%;">
            @if (AccountType.ToString().ToLower() != "self")
