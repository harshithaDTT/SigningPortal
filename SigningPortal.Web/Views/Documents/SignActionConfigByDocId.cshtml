            <button id="okButton" class="legacy-primary">Confirm &amp; Sign</button>
        </div>
    </div>
</div>


@section scripts {
    <script>
        var suid = "@Suid";
        var loginEmail = "@userEmail";
        var loginName = "@name";
        var docID = "@Model.DocId";
        var DocumentName = "@Model.DocumentName";
        var completedSignList = @Html.Raw(JsonConvert.SerializeObject(Model.CompleteSignList));
        var viewName = '@Model.ViewName';
        var recipients = @Html.Raw(Json.Serialize(Model.Recepients));
        var pendingSignList = @Html.Raw(JsonConvert.SerializeObject(Model.PendingSignList));
        var multiSign = @Html.Raw(JsonConvert.SerializeObject(Model.MultiSign));
        var useremailvalue = "@userEmail";
        var Edmsidvalue = '@Model.EdmsId';
        var OriginalEdmsId = "@Model.OriginalEdmsId";
        var GetPreviewConfig = "@Url.Action("GetPreviewConfig", "Documents")";
        var SigAnnData = @Html.Raw(JsonConvert.SerializeObject(Model.Annotations ?? "null"));
        var EsealAnnData = @Html.Raw(JsonConvert.SerializeObject(Model.EsealAnnotations ?? "null"));
        var QrAnnData = @Html.Raw(JsonConvert.SerializeObject(Model.QrCodeAnnotations ?? "null"));
        let Annotations = '@Model.Annotations';
        let EsealAnnotations = '@Model.EsealAnnotations';
        let QrCodeAnnotations = '@Model.QrCodeAnnotations';
        var IndexDashboard = '@Url.Action("Index", "Dashboard")';
        var IndexDocuments = '@Url.Action("MyDocumentsList", "Documents")';
        var DocumentDetailsByIdDocuments = '@Url.Action("DocumentDetailsById", "Documents")/';
        var SendSigningRequest = "@Url.Action("SendSigningRequest", "Documents")";
        var usernamevalue = '@name';
        const Signatureconfig = JSON.parse(@Html.Raw(JsonConvert.SerializeObject(Model.Annotations ?? "null")));
        const Esealconfig = JSON.parse(@Html.Raw(JsonConvert.SerializeObject(Model.EsealAnnotations ?? "null")));
        const Qrconfig = JSON.parse(@Html.Raw(JsonConvert.SerializeObject(Model.QrCodeAnnotations ?? "null")));
        var disableorderval = @Model.DisableOrder.ToString().ToLower();
        var CompleteSignListCount = '@Model.CompleteSignList.Count';
        var SignDocument = "@Url.Action("SignDocument", "Documents")";
        var RejectSigning = "@Url.Action("RejectSigning", "Documents")";
        var GetPreviewimagesUrl = "@Url.Action("GetPreviewimages", "Documents")";
        var GetOrganizationStatusUrl = "@Url.Action("GetOrganizationStatus", "Documents")";
        var ProcessRecipientsUrl = "@Url.Action("ProcessRecipients", "Documents")";
        var currentStaging = '@currentStaging';
        var redirectingurl;
        if (viewName == "MyDocuments")
        {
            redirectingurl = "@Url.Action("MyDocumentsList", "Documents")";
        }
        else if (viewName == "SentDocuments")
        {
            redirectingurl = "@Url.Action("SentDocumentsList", "Documents")";
        }
        else if (viewName == "ReceivedDocuments")
        {
            redirectingurl = "@Url.Action("ReceivedDocumentsList", "Documents")";
        }
        else
        {
            redirectingurl = "@Url.Action("MyDocumentsList", "Documents")";
        }
    </script>
    <script>
        window.pdfWorkerPath = '@Url.Content("~/local-cdns/Shared/pdfjs/2.10.377/pdf.worker.min.js")';
    </script>
    @if (Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Development")
    {
        <script src="~/js/Documents/SignActionConfigByDocId.js" type="text/javascript" asp-append-version="true" defer></script>
    }
    else
    {
        <script src="~/js/Documents/SignActionConfigByDocId.js" type="text/javascript" asp-append-version="true" defer></script>
    }
}