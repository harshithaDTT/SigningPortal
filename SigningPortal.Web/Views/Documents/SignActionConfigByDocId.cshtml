    #stepper-loader {
        display: flex;
        justify-content: center;
        align-items: center;
        margin: 0 auto 20px;
        width: 77px;
        height: 77px;
    }

    #digitalShowModal #signing-status-box {
        position: relative;
    }

    #digitalShowModal #stepper-loader[style*="display:block"],
    #digitalShowModal #stepper-loader[style*="display: block"] {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        margin: 0;
        background: rgba(255, 255, 255, 0.72);
        z-index: 25;
    }

        #digitalShowModal #stepper-loader[style*="display:block"] .lds-spinner,
        #digitalShowModal #stepper-loader[style*="display: block"] .lds-spinner {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

    #stepper-loader .lds-spinner {
        width: 77px;
        height: 77px;
        position: relative;
        display: inline-block;
    }

        #stepper-loader .lds-spinner div {
            transform-origin: 40px 40px;
            animation: lds-spinner 1.2s linear infinite;
        }

            #stepper-loader .lds-spinner div:after {
                content: " ";
                display: block;
                position: absolute;
                top: 3px;
                left: 37px;
                width: 6px;
                height: 18px;
                border-radius: 20%;
                background: #10B981;
            }

            #stepper-loader .lds-spinner div:nth-child(1) {
                transform: rotate(0deg);
                animation-delay: -1.1s;
            }

            #stepper-loader .lds-spinner div:nth-child(2) {
                transform: rotate(30deg);
                animation-delay: -1s;
            }

            #stepper-loader .lds-spinner div:nth-child(3) {
                transform: rotate(60deg);
                animation-delay: -0.9s;
            }

            #stepper-loader .lds-spinner div:nth-child(4) {
                transform: rotate(90deg);
                animation-delay: -0.8s;
            }

            #stepper-loader .lds-spinner div:nth-child(5) {
                transform: rotate(120deg);
                animation-delay: -0.7s;
            }

            #stepper-loader .lds-spinner div:nth-child(6) {
                transform: rotate(150deg);
                animation-delay: -0.6s;
            }

            #stepper-loader .lds-spinner div:nth-child(7) {
                transform: rotate(180deg);
                animation-delay: -0.5s;
            }

            #stepper-loader .lds-spinner div:nth-child(8) {
                transform: rotate(210deg);
                animation-delay: -0.4s;
            }

            #stepper-loader .lds-spinner div:nth-child(9) {
                transform: rotate(240deg);
                animation-delay: -0.3s;
            }

            #stepper-loader .lds-spinner div:nth-child(10) {
                transform: rotate(270deg);
                animation-delay: -0.2s;
            }

            #stepper-loader .lds-spinner div:nth-child(11) {
                transform: rotate(300deg);
                animation-delay: -0.1s;
            }

            #stepper-loader .lds-spinner div:nth-child(12) {
                transform: rotate(330deg);
                animation-delay: 0s;
            }

    @@keyframes lds-spinner {
        0% {
            opacity: 1;
        }

        100% {
            opacity: 0;
        }
    }

