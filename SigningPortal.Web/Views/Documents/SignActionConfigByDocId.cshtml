<div class="row" style="height:100vh;margin:0px">
    @Html.AntiForgeryToken()
    <div class="col-md-12" style="height:100%;padding:0px">
        <div class="card" style="height:100%;border:none">
            <div class="card-body background-image signing-theme" id="viwer">
                <form id="createDoc" enctype="multipart/form-data">
                    <div class="viewer-flex-container">
                        <div id="viewerdivtag" class="viewer-left">
                            <div class="viewer-toolbar" id="viewerToolbar">
                                <div class="zoom-controls">
                                    <button type="button" class="toolbar-btn" id="zoomOutBtn">
                                        <i class="fa fa-search-minus"></i>
                                    </button>
                                    <span id="zoomDisplay">100%</span>
                                    <button type="button" class="toolbar-btn" id="zoomInBtn">
                                        <i class="fa fa-search-plus"></i>
                                    </button>
                                    <button type="button" class="toolbar-btn" id="resetZoomBtn">Reset</button>
                                </div>
                                <div class="page-controls">
                                    <button type="button" class="toolbar-btn" id="pagePrevBtn">
                                        <i class="fa fa-chevron-up"></i>
                                    </button>
                                    <span id="pageIndicator">Page 0 / 0</span>
                                    <button type="button" class="toolbar-btn" id="pageNextBtn">
                                        <i class="fa fa-chevron-down"></i>
                                    </button>
                                </div>
                            </div>
                            <div id="scrollContainer" class="scroll-container">
                                <div id="pdf-container"></div>
                            </div>
                        </div>
                        <div id="fieldsdivtag" class="viewer-right">
                            <div class="action-panel">
                                <div id="signActionButtons" class="actions-group">
                                    <button type="button" id="signButton" class="submit-button primary-action">Sign</button>
                                    <button type="button" id="Rejectbutton" class="submit-button secondary-action">Reject</button>
                                </div>


                                <div id="commentBox" class="comment-card" style="display:none;">
                                    <textarea id="rejectComment" style="margin-bottom:2%" class="form-control" placeholder="Enter rejection comment"></textarea>
                                    <button id="btnSubmitReject" type="button" class="submit-button secondary-action small" style="color:#0d6efd;border:2px solid #0d6efd">Submit</button>
                                </div>

                                <div class="sign-action-card" id="commentButton" style="display:none">
                                    <div class="Button-Box">
                                        <div class="draggable-buttons">
                                            <button type="button">
                                                <i class="fa fa-comment"></i>
                                                <span>Comment</span>
                                            </button>
                                        </div>
                                    </div>
                                    <div id="addcommentBox" class="comment-card" style="display:none;">
                                        <textarea id="comment-field" class="form-control" placeholder="Enter comments"></textarea>
                                        <button type="button" id="btnSaveComment" class="submit-button primary-action small">Save</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
