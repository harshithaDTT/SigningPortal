</style>
<style>

    .lds-spinner div:after {
        content: " ";
        display: block;
        position: absolute;
        top: 3px;
        left: 37px;
        width: 6px;
        height: 18px;
        border-radius: 20%;
        background: #059669;
    }

    @@keyframes blinkRedGlow {
        0%, 100% {
            box-shadow: 0 0 15px 4px #dc8c94;
        }

        50% {
            box-shadow: 0 0 0px 0px #dc8c94;
        }
    }

    @@keyframes blinkGreenGlow {
        0%, 100% {
            box-shadow: 0 0 15px 4px #a5b724;
        }

        50% {
            box-shadow: 0 0 0px 0px #a5b724;
        }
    }

    /* Blinking / pulse helpers copied from CreateDocuments_NEW.cshtml */
    .stepper-circle.blinking,
    .circle.blinking {
        animation: stepPulse 1.1s ease-in-out infinite;
    }

    @@keyframes stepPulse {
        0% {
            box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.45);
            transform: scale(1);
        }

        50% {
            box-shadow: 0 0 0 12px rgba(16, 185, 129, 0);
            transform: scale(1.06);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(16, 185, 129, 0);
            transform: scale(1);
        }
    }

    /* Blinking pulse helper */
    .blinking {
        animation: blink-pulse 1s ease-in-out infinite;
    }

    @@keyframes blink-pulse {
        0%, 100% {
            opacity: 1;
            transform: scale(1);
        }

        50% {
            opacity: 0.6;
            transform: scale(1.05);
        }
    }

    /* Convenience classes using existing glow keyframes */
    .blink-green {
        animation: blinkGreenGlow 1s infinite;
    }

    .blink-red {
        animation: blinkRedGlow 1s infinite;
    }

    .blinkGreenGlow {
        animation: blinkGreenGlow 1.5s ease-in-out 3;
    }

    .blinkRedGlow {
        animation: blinkRedGlow 1.5s ease-in-out 3;
    }

    .pdf-page {
        margin-bottom: 20px !important;
        background-color: white;
    }

    @@media (max-width:480px) {
        .modal-content {
            width: 66% !important;
        }

        .doc-signing-status-modal-content {
            width: 100% !important;
        }
    }

    .swal-modal-new {
        width: 40%;
    }

    .doc-signing-status {
        width: 45%;
    }


    #SigningModalheading {
        font-size: 25px;
    }

    @@media screen and (max-width:992px) {
        .swal-modal-new {
            width: 46%;
        }

        .doc-signing-status {
            width: 60%;
        }

    }

    @@media screen and (max-width:768px) {
