<div class="modal fade modern-modal signing-theme-modal" id="EditFields_Modal" tabindex="-1" role="dialog" aria-labelledby="digitalFormModalLabel" aria-hidden="false" data-backdrop="true" style="display:none;">
    <div class="modal-dialog modal-dialog-centered modal-xl" role="document">
        <div class="modal-content">
            <div id="EditHeader" class="modal-header"></div>
            <div id="EditBody" class="modal-body"></div>
            <div id="EditFooter" class="modal-footer"></div>
        </div>
    </div>
</div>


<div class="modal fade" id="digitalShowModal" tabindex="-1" role="dialog"
     aria-labelledby="digitalFormModalLabel" aria-hidden="false"
     data-backdrop="true"
     style="display:none;opacity: 1;background-color: rgba(0, 0, 0, 0.2);">
    <div class="modal-dialog modal-dialog-centered  doc-signing-status" role="document" style="max-width:650px">
        <div class="modal-content doc-signing-status-modal-content" style="position: relative;background-color:transparent;width:100%;height:auto;border-radius: 12px;">

            <!-- Signing Status Section -->
            <div id="signing-status-box" style="width:100%;height:100%; background: white; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.3); text-align: center;">
                <div id="SigningModalheading" class="p-2 p-md-3" style="border-top-left-radius: 12px;border-top-right-radius: 12px;color:white;font-weight:500;display:flex;text-align:center;justify-content:center;align-items:center;background:#04ad78;font-size:1.25rem">Document Signing Status</div>

                <div style="height:83%;padding-top:5%">
                    <div class="stepper" style="display:flex; justify-content: center; align-items: center; margin-bottom: 3%; position: relative;">


                        <!-- Step 1: Signatory Verification -->
                        <div class="step active" style="display: flex; flex-direction: column; align-items: center; position: relative; flex:1;">
                            <div class="circle blinking" style="width: 40px; height: 40px; border-radius: 50%; background-color: #059669; color: white; display: flex; align-items: center; justify-content: center; z-index: 1; margin-bottom: 8px; font-size: 20px;">
                                <i class="bi bi-person-check"></i>
                            </div>
                            <div class="step-label" style="font-size: 12px;">Signatory Verification</div>
                            <div style="height: 4px; background-color: #dcdcdc; position: absolute; top: 20px; left: 50%; width: 100%; z-index: 0;"></div>
                        </div>



                        <!-- Step 2: Document Signing -->
                        <div class="step" style="display: flex; flex-direction: column; align-items: center; position: relative; flex:1;">
                            <div class="circle" style="width: 40px; height: 40px; border-radius: 50%; background-color: #dcdcdc; color: white; display: flex; align-items: center; justify-content: center; z-index: 1; margin-bottom: 8px; font-size: 20px;">
                                <i class="bi bi-pen"></i>
                            </div>
                            <div class="step-label" style="font-size: 12px;">Document Signing</div>
                            <div style="height: 4px; background-color: #dcdcdc; position: absolute; top: 20px; left: 50%; width: 100%; z-index: 0;"></div>
                        </div>



                        <!-- Step 3: Signing Successful -->
                        <div class="step" style="display: flex; flex-direction: column; align-items: center; position: relative; flex:1;">
                            <div class="circle" style="width: 40px; height: 40px; border-radius: 50%; background-color: #dcdcdc; color: white; display: flex; align-items: center; justify-content: center; z-index: 1; margin-bottom: 8px; font-size: 20px;">
                                <i class="bi bi-check-circle"></i>
                            </div>
                            <div class="step-label" style="font-size: 12px;">Signing Successful</div>
                        </div>

                    </div>
                    <div class="image-wrapper" style="width: 100px;height:100px; margin-bottom: 15px;margin-left:auto;margin-right:auto">
                        <img id="stepper-image" asp-append-version="true" src='@Url.Content("~/assets/images/smartphone2.png")' alt="Signing Step Image" style="width:100%;height:100%" />
                    </div>

                    <div id="stepper-loader" style="display:none;margin-bottom:10px">

                        <div class="lds-spinner"><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div><div></div></div>
                    </div>

                    <div id="stepper-message" style="color: #333;max-width:530px;white-space:normal;word-break:break-word;margin:0 auto 1%">
                        Check for @currentStaging mobile app notification and approve signing request...
                    </div>

                    <div class="mb-3" style="display:flex;justify-content:space-evenly">
                        <button id="gobackbtn" class="btn btn-success mt-3" style="display:none;background-color: #04ad78 !important; color: white; padding: 10px 25px; border: none; border-radius: 6px;float:right">Go Back</button>
                        <button id="cancelbtn" class="btn btn-success mt-3" style="display:none;background-color: #04ad78 !important; color: white; padding: 10px 25px; border: none; border-radius: 6px;">Cancel</button>
                        <button id="retrybtn" class="btn btn-success mt-3" style="display:none;background-color: #04ad78 !important; color: white; padding: 10px 25px; border: none; border-radius: 6px;">Retry</button>
                        <input type="hidden" id="signingdocid" />
                    </div>
                    <div id="signstatusloader" class="cv-spinner1 mb-3 mb-md-4" style="height:10% !important;width:24%">
                        <div class="dot"></div>
                        <div class="dot"></div>
                        <div class="dot"></div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<div id="overlay9" class="legacy-overlay" style="display:none;">
