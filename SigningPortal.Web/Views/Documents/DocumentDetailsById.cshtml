@model SigningPortal.Web.ViewModels.Documents.DocumentDetailsViewModel
@inject IConfiguration Configuration
@using System.Security.Claims;
@using Newtonsoft.Json
@{
    ViewData["Title"] = "Documents Details";
    var loginSuid = User.FindFirst(ClaimTypes.UserData).Value;
    var userEmail = User.FindFirst(ClaimTypes.Email).Value;
    var loginEmail = User.FindFirst(ClaimTypes.Email).Value;
    var AccountType = User.FindFirst("AccountType").Value;
    var loginOrgUid = "";
    if (AccountType != "Self")
    {

        loginOrgUid = User.FindFirst("OrganizationUid").Value;
    }

    var declinedComment = "";
    var documentIdValue = Model.docId;
    List<string> signsuidList = new List<string>(); // Declare the list
    List<string> esealsuidList = new List<string>(); // Declare the list
    List<string> qrcodesuidList = new List<string>(); // Declare the list
    var pdflogoimagepath = Configuration.GetSection("PDFLogoPath").Value;
    var pdflogoimage = '/' + pdflogoimagepath.ToString();
    if (Model.DeclineRemark != null)
    {
        declinedComment = Model.DeclineRemark;
    }
    if (ViewBag.DocumentReportResponse != null)
    {
        var signatoryDetails = ViewBag.DocumentReportResponse.SignatoryDetails;
        var esealannotationsstring = ViewBag.DocumentReportResponse.DocumentDetails.EsealAnnotations;

        if (esealannotationsstring != null)
        {
            var esealAnnotations = JsonConvert.DeserializeObject<Dictionary<string, dynamic>>(esealannotationsstring);

            // Prepare a list to hold all suids (keys)

            // Loop through the dictionary to get the keys (suid values)
            foreach (var key in esealAnnotations.Keys)
            {
                esealsuidList.Add(key);
            }
        }
        var signannotationsstring = ViewBag.DocumentReportResponse.DocumentDetails.SignatureAnnotations;

        if (signannotationsstring != null)
        {
            var signAnnotations = JsonConvert.DeserializeObject<Dictionary<string, dynamic>>(signannotationsstring);


            // Loop through the dictionary to get the keys (suid values)
            foreach (var key in signAnnotations.Keys)
            {
                signsuidList.Add(key);
            }
        }
        var qrcodeannotationsstring = ViewBag.DocumentReportResponse.DocumentDetails.QrCodeAnnotations;

        if (qrcodeannotationsstring != null)
        {
            var qrcodeAnnotations = JsonConvert.DeserializeObject<Dictionary<string, dynamic>>(qrcodeannotationsstring);



            // Loop through the dictionary to get the keys (suid values)
            foreach (var key in qrcodeAnnotations.Keys)
            {
                qrcodesuidList.Add(key);
            }
        }
    }

}

