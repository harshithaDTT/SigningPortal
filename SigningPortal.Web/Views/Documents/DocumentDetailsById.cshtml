                                @if (Model.Status == "In Progress")

                                {

                                    <tr>

                                        <td style="text-align:left;">Signing Status</td>

                                        <td style="text-align:left;">:</td>

                                        <td id="status" style="color:rgb(229, 184, 0)"></td>

                                    </tr>

                                }



                                @if (Model.Status == "Completed")

                                {

                                    <tr>

                                        <td style="text-align:left;">Signing Status</td>

                                        <td style="text-align:left;">:</td>

                                        <td id="status" style="color:rgb(44, 175, 87)"></td>

                                    </tr>

                                }

                                @if (Model.Status == "Declined")

                                {

                                    <tr>

                                        <td style="text-align:left;">Signing Status</td>

                                        <td style="text-align:left;">:</td>

                                        <td id="status" style="color:#fb0404"></td>

                                    </tr>

                                }

                                @if (Model.Status == "Expired")

                                {

                                    <tr>

                                        <td style="text-align:left;">Signing Status</td>

                                        <td style="text-align:left;">:</td>

                                        <td id="status" style="color:#bdbdbd"></td>

                                    </tr>

                                }



                            </table>

                        }





                    </div>

                    @*                     <div>

                <label style="font-size:16px; float:right;margin-top:2%;">

                Report Generated On

                <span id="currentDateTime" ></span>

                </label>

                </div> *@



                    <div class="col-md-12" style="text-align: right;display:none !important;">

                        <label style="font-size:15px; margin-top:2%;">

                            Report Generated On :

                        </label>

                        <label id="currentDateTime" style="font-size:15px; margin-top:2%; width:170px !important">

                        </label>

                    </div>



                </div>







                <div class="modal-footer d-none" style="border-top: 1px solid #efefef;">

                    <button type="button" id="closebutton" class="btn closebuttonclass">Close</button>

                </div>

            </div>

        </div>

    </div>

}


