@functions {
    public string CropFileName(string full)
    {
        const int start = 25;
        const int end = 25;

        if (!string.IsNullOrEmpty(full) && full.Length > start + end)
        {
            return full.Substring(0, start) + "..." + full.Substring(full.Length - end);
        }
        return full;
    }
}


@{
    var bgColor = Model.Status switch
    {
        "In Progress" => "#f57c00",
        "Completed" => "rgb(19 180 105)",
        "Failed" or "Declined" => "red",
        "Expired" => "#bdbdbd",
        "Recalled" => "#B366F6",
        _ => "#f57c00"
    };
    var documentName = CropFileName(Model.DocumentName);
    var titleAttr = documentName != Model.DocumentName ? $"title=\"{Model.DocumentName}\"" : "";
}

<link rel="stylesheet" asp-append-version="true" href="~/css/Documents/DocumentDetailsById.css" />

<div class="container-fluid p-4" style="background:#F6F7FB; min-height:100vh;">
    @Html.AntiForgeryToken()
    <div class="col-md-12">

        <div>
            <div class="card-body">
                <div class="card shadow-sm p-4" style="border-radius: 12px;">

                    <div class="row">

                        <!-- LEFT COLUMN : Document Details -->
                        <div class="col-lg-7">
                            <h1 style="font-weight:700;font-size:20px !important;margin-bottom:16px;">Document Details</h1>

                            <div style="max-width: 600px;">

                                <!-- Name -->
                                <div class="row mb-2 d-block d-sm-flex align-items-sm-center">
                                    <div class="fw-semibold d-inline d-sm-block col-sm-4 pr-0">
                                        <i class="bi bi-file-earmark-text-fill me-1" style="color:#6c757d !important"></i> Name
                                    </div>
                                    <div class="d-inline d-sm-block text-end col-sm-1">:</div>
                                    <div class="d-inline d-sm-block col-sm-7" @Html.Raw(titleAttr)>@documentName</div>
                                </div>

                                <!-- Status -->
                                <div class="row mb-2 d-block d-sm-flex align-items-sm-center">
                                    <div class="fw-semibold d-inline d-sm-block col-sm-4 pr-0">
                                        <i class="bi bi-info-circle-fill me-1 text-info" style="color:#6c757d !important"></i> Status
                                    </div>
                                    <div class="d-inline d-sm-block text-end col-sm-1">:</div>
                                    <div class="d-inline d-sm-block col-sm-7">
                                        <span style="background-color: @bgColor; color: white; border-radius: 16px; padding: 4px 16px; font-size: 15px;">
                                            @(Model.Status == "In Progress" ? "Signatures Pending" : Model.Status)
                                        </span>
                                    </div>
                                </div>

                                <!-- Created / Received On -->
                                @if (Model.ViewName == "MyDocuments" || Model.ViewName == "SentDocuments")
                                {
                                    <div class="row mb-2 d-block d-sm-flex align-items-sm-center">
                                        <div class="fw-semibold d-inline d-sm-block col-sm-4 pr-0">
                                            <i class="bi bi-clock-fill me-1" style="color:#6c757d !important"></i> Created on
                                        </div>
                                        <div class="d-inline d-sm-block text-end col-sm-1">:</div>
                                        <div class="d-inline d-sm-block col-sm-7 convert-date" data-timestamp="@Model.CreatedAt.ToString("o")"></div>
                                    </div>
                                }
                                else
                                {
                                    <div class="row mb-2 d-block d-sm-flex align-items-sm-center">
                                        <div class="fw-semibold d-inline d-sm-block col-sm-4 pr-0">
                                            <i class="bi bi-clock-fill me-1" style="color:#6c757d !important"></i> Received on
                                        </div>
                                        <div class="d-inline d-sm-block text-end col-sm-1">:</div>
                                        <div class="d-inline d-sm-block col-sm-7 convert-date" data-timestamp="@Model.CreatedAt.ToString("o")"></div>
                                    </div>
                                }

                                <!-- Expires On -->
                                <div class="row mb-2 d-block d-sm-flex align-items-sm-center">
                                    <div class="fw-semibold d-inline d-sm-block col-sm-4 pr-0">
                                        <i class="bi bi-hourglass-split me-1 text-warning" style="color:#6c757d !important"></i> Expires on
                                    </div>
                                    <div class="d-inline d-sm-block text-end col-sm-1">:</div>
                                    <div class="d-inline d-sm-block col-sm-7 convert-date" data-timestamp="@Model.ExpiredAt.ToString("o")"></div>
                                </div>

                                <!-- Completed On -->
                                @if (Model.Status == "Completed")
                                {
                                    <div class="row mb-2 d-block d-sm-flex align-items-sm-center">
                                        <div class="fw-semibold d-inline d-sm-block col-sm-4 pr-0">
                                            <i class="bi bi-check-circle-fill me-1 text-success" style="color:#6c757d !important"></i> Completed on
                                        </div>
                                        <div class="d-inline d-sm-block text-end col-sm-1">:</div>
                                        <div class="d-inline d-sm-block col-sm-7 convert-date" data-timestamp="@Model.CompleteTime.ToString("o")"></div>
                                    </div>
                                }

                                <!-- Created By & Account -->
                                @if (Model.OwnerEmail != userEmail)
                                {
                                    <div class="row mb-2 d-block d-sm-flex align-items-sm-center">
                                        <div class="fw-semibold d-inline d-sm-block col-sm-4 pr-0">
                                            <i class="bi bi-person-fill me-1 text-secondary" style="color:#6c757d !important"></i> Created By
                                        </div>
                                        <div class="d-inline d-sm-block text-end col-sm-1">:</div>
                                        <div class="d-inline d-sm-block col-sm-7">@Model.OwnerEmail</div>
                                    </div>

                                    <div class="row d-block d-sm-flex align-items-sm-center">
                                        <div class="fw-semibold d-inline d-sm-block col-sm-4 pr-0">
                                            <i class="bi bi-building me-1 text-dark" style="color:#6c757d !important"></i> Account
                                        </div>
                                        <div class="d-inline d-sm-block text-end col-sm-1">:</div>
                                        <div class="d-inline d-sm-block col-sm-7">
                                            @(Model.AccountType == "organization" ? @Model.OrganizationName : "Self")
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- RIGHT COLUMN : Image + Buttons -->
                        <div class="col-lg-5 col-md-12 p-0 d-flex flex-column align-items-center" style="margin-top:30px;">
                            <div class="document-container d-flex gap-20 w-100">

                                @if (Model.Status == "Completed")
                                {
                                    <img src='@Url.Content("~/img/icon/Signed-icons-green.png")' asp-append-version="true" id="completedImage" class="document-image jss19 img-fluid">
                                }
                                else if (Model.Status == "Failed" || Model.Status == "Declined")
                                {
                                    <img src='@Url.Content("~/img/icon/Declined-icons-gray.png")' asp-append-version="true" id="declinedExpiredImage" class="document-image jss19 img-fluid">
                                }
                                else if (Model.Status == "In Progress")
                                {
                                    <img src='@Url.Content("~/img/icon/Viewed-icons-orange.png")' asp-append-version="true" id="viewedImage" class="document-image jss19 img-fluid">
                                }
                                else
                                {
                                    <img src='@Url.Content("~/img/icon/Expired icon.svg")' asp-append-version="true" id="sentImage" class="document-image jss19 img-fluid">
                                }

                                @if (Model.Status != "Recalled")
                                {
                                    <div class="signaturesRequired">
                                        <div id="signaturesRequireddiv" style="font-size:1.1rem;margin-left:20px;margin-right:10px;">
                                            Number of signatures required including mandatory signatures to download document: @Model.SignaturesRequiredCount
                                        </div>
                                    </div>
                                }
                            </div>

                            <br />

                            <div class="d-flex justify-content-start align-items-center gap-20" style="align-self:flex-start;margin-left:10px;">
                                @if (Model.OwnerEmail == userEmail && Model.Status == "In Progress")
                                {
                                    <button id="recallbutton" class="submit-button recallbutton">Recall</button>
                                }

                                <button id="downloadbutton" class="submit-button Downloadbutton" style="display:none;font-size:14px;padding:6px 12px;margin-right:10px;">
                                    <i class="bi bi-download mr-1"></i> Download
                                </button>

                                <div>
                                    <button class="submit-button btn-primary" style="padding:6px 12px;float:right;margin-right:75px;font-size:14px;" id="Viewdetails">
                                        <i class="fa-regular fa-eye mr-1"></i> More Details
                                    </button>
                                </div>
                            </div>
                        </div>

                    </div>


                    @if (Model.Status == "Declined")
                    {
                        <div class="mt-4 p-3"
                             style="background:#faf5ff; border-left:4px solid #a855f7; border-radius:8px;">

                            <h5 style="color:#7e22ce; font-size:16px; margin-bottom:8px;">
                                Decline Remarks
                            </h5>

                            <div style="font-size:14px; color:#333; line-height:1.5; word-wrap:break-word;">
                                @declinedComment
                            </div>

                        </div>
                    }

                </div>



                <div class="row">
                </div>
                <div class="card shadow-sm p-4 mt-4" style="border-radius: 12px;">
                    <h4 style="font-weight:600;margin-bottom:23px;">Signatories</h4>

                    <div class="signatories-container">
                        @for (int i = 0; i < Model.Recepients.Count; i++)
                        {
                            var item = Model.Recepients[i];
                            var id = item._id;
                            //var userThumbnail = sendEmailToGetThumbnail(item.Email);
                            //src="/img/Signatory_dp.png"
                            var displayStatus = (item.Status == "Signing_Pending" || item.Status == "Signing_in_Progress")
                            ? "In Progress"
                            : (item.Status == "Failed" || item.Status == "Pin_Failed")
                            ? "Failed"
                            : item.Status;

                            <div class="signatory-card">
                                <div class="signatory-header">
                                    <div class="signatory-profile">
                                        <div style="width:50px;height:50px;border-radius:50px;" id="loader-@i" class="spinner"></div>
                                        <img id="thumb-@i" asp-append-version="true" style="width:50px;height:50px;border-radius:50px;display:none;" />
                                        <div class="signatory-info">
                                            <div class="signatory-name">
                                                @(string.IsNullOrWhiteSpace(item.Name) ? "NA" : item.Name.ToUpper())
                                                @if (!item.HasDelegation && item.AlternateSignatories != null && item.AlternateSignatories.Count > 0)
                                                {
                                                    var tooltipContent = "<div style='text-align:left; background:rgb(19 180 105) !important; width:500px;display:block'>" +
                                                    "<div style='font-weight: 600; color: #ffffff; background: #4CAF50; border-radius: 4px 4px 0 0; padding: 4px;'>Alternative Signatories:</div>" +
                                                    "<ul style='margin: 0; padding: 8px 20px; background: #f8f9fa; list-style: disc; border: 1px solid #dee2e6; border-top: none; border-radius: 0 0 4px 4px;'>";

                                                    int count = 1;
                                                    foreach (var alt in item.AlternateSignatories)
                                                    {
                                                        tooltipContent += $"<li style='font-size: 13px; color: #333; list-style: none;'><span style='white-space: nowrap; display: inline-block;'>{count}. {alt.email}</span></li>";
                                                        count++;
                                                    }

                                                    tooltipContent += "</ul></div>";
                                                    <span data-bs-toggle="tooltip"
                                                          data-bs-placement="bottom"
                                                          data-bs-html="true"
                                                          title="@Html.Raw(tooltipContent)"
                                                          style="cursor: pointer; margin-left: 4px;">
                                                        <i class="fas fa-user-friends" style="color: rgb(19 180 105) !important;"></i>
                                                    </span>
                                                }
                                            </div>
                                            <div class="signatory-email">
                                                <i class="fas fa-envelope"></i>
                                                @item.Email
                                            </div>
                                            @if (item.HasDelegation && item.AlternateSignatories != null)
                                            {
                                                <div class="detail-item"><span class="detail-label">Delegatee:</span><span class="detail-value">@item.AlternateSignatories[0].email</span></div>
                                            }

                                            @if (item.AccountType == "organization")
                                            {
                                                <div class="detail-item"><span class="detail-label">Organization:</span><span class="detail-value">@item.OrganizationName</span></div>
                                            }
                                            else
                                            {
                                                <div class="detail-item"><span class="detail-label">Account:</span><span class="detail-value">@item.AccountType</span></div>
                                            }


                                            @if (item.Status == "Signed" && (item.HasDelegation || (item.AlternateSignatories != null && item.AlternateSignatories.Count >= 1)))
                                            {
                                                <div class="d-none d-sm-flex d-xxl-none">
                                                    <div class="signingstats-heading">Signed by</div>
                                                    <div class="signingstats-heading pr-2">:</div>
                                                    <div class="gap-1 signingstats-text">
                                                        @item.SignedBy
                                                    </div>
                                                </div>
                                            }

                                            @if (item.Status == "Signed")
                                            {
                                                <div class="d-none d-sm-flex d-xl-none">
                                                    <div class="signingstats-heading">Signed on</div>
                                                    <div class="signingstats-heading pr-2">:</div>
                                                    <div class="gap-1 signingstats-text convert-time" data-timestamp="@item.SigningCompleteTime.ToString("o")">
                                                        @item.SigningCompleteTime
                                                    </div>
                                                </div>
                                            }


                                            <div class="d-none d-sm-flex d-lg-none ">
                                                <div class="signingstats-heading">Mandatory</div>
                                                <div class="signingstats-heading pr-2">:</div>
                                                <div class="gap-1 signingstats-text">
                                                    @(item.SignatureMandatory ? "Yes" : "No")
                                                </div>
                                            </div>


                                        </div>
                                    </div>

                                </div>
                                <div class="signatory-status">

                                    @if (item.Status == "Signed" && (item.HasDelegation || (item.AlternateSignatories != null && item.AlternateSignatories.Count >= 1)))
                                    {
                                        <div class="d-flex d-sm-none d-xxl-flex flex-sm-column mr-sm--5">
                                            <div class="signingstats-heading">Signed by</div>
                                            <div class="signingstats-heading d-sm-none pr-2">:</div>
                                            <div class="gap-1 signingstats-text">
                                                @item.SignedBy
                                            </div>
                                        </div>
                                    }

                                    @if (item.Status == "Signed")
                                    {
                                        <div class="d-flex d-sm-none d-xl-flex flex-sm-column mr-sm-5">
                                            <div class="signingstats-heading">Signed on</div>
                                            <div class="signingstats-heading d-sm-none pr-2">:</div>
                                            <div class="gap-1 signingstats-text convert-time" data-timestamp="@item.SigningCompleteTime.ToString("o")">
                                                @item.SigningCompleteTime
                                            </div>
                                        </div>
                                    }


                                    <div class="d-flex d-sm-none d-lg-flex flex-sm-column mr-sm-5">
                                        <div class="signingstats-heading">Mandatory</div>
                                        <div class="signingstats-heading d-sm-none pr-2">:</div>
                                        <div class="gap-1 signingstats-text">
                                            @(item.SignatureMandatory ? "Yes" : "No")
                                        </div>
                                    </div>


                                    @if (item.Status == "Need to sign")
                                    {
                                        bool isPrimarySigner = item.Email == userEmail && Model.PendingSignList[0].email == userEmail;
                                        bool isAlternativeSigner = item.Email == Model.PendingSignList[0].email && item.AlternateSignatories != null &&
                                        item.AlternateSignatories.Any(a => a.email == userEmail);
                                        bool isDisableOrder = Model.DisableOrder;

                                        if (Model.Status == "Expired" || Model.Status == "Recalled")
                                        {
                                            <div class="d-flex flex-sm-column mr-sm-1" style="min-width:130px;">
                                                <div class="signingstats-heading">Signing Status</div>
                                                <div class="signingstats-heading d-sm-none pr-2">:</div>
                                                <div class="gap-1 signingstats-text" style="color:#bdbdbd;">
                                                    @item.Status
                                                </div>
                                            </div>
                                        }
                                        else if (isPrimarySigner || isAlternativeSigner || (isDisableOrder && item.Email == userEmail))
                                        {
                                            <div class="d-flex justify-content-end flex-sm-column justify-content-sm-start mr-sm-1" style="width:100%;min-width:130px;">
                                                <button type='button' class="btn btn-success deepGreen-bgcolor no-margin signBtn" style="font-size:small;padding:6px 8px;max-width:90px;width:100%;text-transform: none !important;" data-docid="@Model.docId">
                                                    <i class='fa fa-pencil'></i>&nbsp;Sign
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="d-flex flex-sm-column mr-sm-1" style="min-width:130px;">
                                                <div class="signingstats-heading">Signing Status</div>
                                                <div class="signingstats-heading d-sm-none pr-2">:</div>
                                                <div class="gap-1 signingstats-text" style="color: #f57c00;">
                                                    @item.Status
                                                </div>
                                            </div>
                                        }
                                    }
                                    else if (item.Status == "Failed" || item.Status == "Pin_Failed")
                                    {
                                        bool isPrimarySigner = item.Email == userEmail && Model.PendingSignList[0].email == userEmail;
                                        bool isAlternativeSigner = item.Email == Model.PendingSignList[0].email && item.AlternateSignatories != null &&
                                        item.AlternateSignatories.Any(a => a.email == userEmail);
                                        bool isDisableOrder = Model.DisableOrder;
                                        if (Model.Status == "Expired" || Model.Status == "Recalled")
                                        {
                                            <div class="d-flex flex-sm-column mr-sm-1" style="min-width:130px;">
                                                <div class="signingstats-heading">Signing Status</div>
                                                <div class="signingstats-heading d-sm-none pr-2">:</div>
                                                <div class="gap-1 signingstats-text" style="color:#bdbdbd;">
                                                    @item.Status
                                                </div>
                                            </div>
                                        }
                                        else if (isPrimarySigner || isAlternativeSigner || (isDisableOrder && item.Email == userEmail))
                                        {
                                            <div class="d-flex justify-content-end flex-sm-column justify-content-sm-start mr-sm-1" style="width:100%;min-width:130px;">

                                                <button type='button' class="btn btn-success deepGreen-bgcolor no-margin retryBtn" style="font-size:small;padding:6px 8px;max-width:90px;width:100%;text-transform: none !important;" data-docid="@Model.docId">
                                                    <i class='fa-solid fa-arrow-rotate-left'></i>&nbsp;Retry
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="d-flex flex-sm-column mr-sm-1" style="min-width:130px;">
                                                <div class="signingstats-heading">Signing Status</div>
                                                <div class="signingstats-heading d-sm-none pr-2">:</div>
                                                <div class="gap-1 signingstats-text" style="color:red;">
                                                    @item.Status
                                                </div>
                                            </div>
                                        }

                                    }
                                    else if (item.Status == "Signed")
                                    {
                                        <div class="d-inline-flex justify-content-end align-items-center signed-btn">
                                            <div class="d-inline-flex justify-content-center align-items-center bg-success text-white px-3 py-2 shadow-sm mr-1" style="font-size: 0.95rem;border-radius:16px;min-width:80px;background-color:rgb(19 180 105) !important;">
                                                <i class="bi bi-check-circle-fill me-2" style="margin-right:10px;"></i>
                                                Signed
                                            </div>
                                        </div>
                                    }
                                    else if (item.Status == "Signing_Pending" || item.Status == "Signing_in_Progress")
                                    {
                                        if (Model.Status == "Expired" || Model.Status == "Recalled")
                                        {
