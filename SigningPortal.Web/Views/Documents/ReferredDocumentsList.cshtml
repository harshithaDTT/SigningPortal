    async function signActionConfigByDocIdOnclick(docId, currentDocNo = 0, totalDocs = 0) {

        try {
            const response = await $.ajax({
                type: 'POST',
                headers: {

                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()

                },
                url: IsDocumentBlocked,
