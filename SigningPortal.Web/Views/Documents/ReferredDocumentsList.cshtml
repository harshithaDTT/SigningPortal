    /* Custom Styling for Radio Buttons */
    .custom-radio input[type="radio"] {
        display: none; /* Hide the default radio button */
    }

        /* Label Styling */
        .custom-radio input[type="radio"] + label {
            position: relative;
            padding-left: 25px; /* Space for the custom radio button circle */
            cursor: pointer;
            font-size: 14px;
            line-height: 1.5;
            color: black;
            /* color: #555; */
            transition: color 0.3s ease;
            margin-bottom: 5px;
            white-space: nowrap;
        }

    @@media screen and (max-width:576px) {
        .custom-radio input[type="radio"] + label {
            padding-left: 25px;
            white-space: normal;
        }
    }

    /* Custom Radio Button Circle (Initial State) */
    .custom-radio input[type="radio"] + label::before {
        content: '';
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 16px;
        height: 16px;
        border: 2px solid #bbb; /* Grey border */
        border-radius: 50%; /* Circle */
        background-color: #fff; /* White background */
        transition: all 0.3s ease; /* Smooth transition for border and background */
    }

    /* Active (Checked) State */
    .custom-radio input[type="radio"]:checked + label::before {
        background-color: #198754;
        border: 0.5px solid #198754;
        width: 16px;
        height: 16px;
        /* box-shadow: 0 0 8px rgba(0, 123, 255, 0.5);  */
    }

    /* Inner White Circle when Active */
    .custom-radio input[type="radio"]:checked + label::after {
        content: '';
        position: absolute;
        left: 4px; /* Align it inside the blue circle */
        top: 50%;
        transform: translateY(-50%);
        width: 8px; /* Inner white circle */
        height: 8px; /* Inner white circle */
        background-color: #fff; /* White color */
        border-radius: 50%; /* Circle shape */
        border: 0.5px solid #198754;
    }

