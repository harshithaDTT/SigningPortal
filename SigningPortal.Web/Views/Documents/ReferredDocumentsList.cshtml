@using System.Security.Claims;
@using Newtonsoft.Json;

@{
    var documentStatusOptions = new List<(string Id, string Display)>
    {
        ("All", "All"),
        ("In Progress","Signatures Pending"),
        ("Completed", "Completed"),
        ("Expired", "Expired"),
        ("Recalled", "Recalled"),
        ("Declined", "Declined")
    };
    var signingStatusOptions = new List<(string Id, string Display)>
    {
        ("All", "All"),
        ("Need to sign","Need to Sign"),
        ("Signed","Signed"),
        ("Signing_in_Progress", "Signing in Progress"),
        ("Failed","Failed"),
        ("Rejected","Rejected"),
        ("Waiting_for_Others","Waiting for Others")

    };
    var Suid = User.FindFirst(ClaimTypes.UserData).Value;
    var userEmail = User.FindFirst(ClaimTypes.Email).Value;
    var AccountType = User.FindFirst("AccountType").Value;
    var OrganizationUid = "";
    if (AccountType != "Self")
    {

        OrganizationUid = User.FindFirst("OrganizationUid").Value;
    }

}



