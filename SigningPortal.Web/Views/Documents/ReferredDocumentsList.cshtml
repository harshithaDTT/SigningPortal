<script>
    var loginEmail = '@userEmail';
    var loginorgUid = '@OrganizationUid';
    var loginSuid = '@Suid';
    var loginAccounttype = '@AccountType';
    var GetReferredDocuments = '@Url.Action("GetReferredDocuments", "Documents")';
    var GetReferreddocumentsStatstics = '@Url.Action("GetReferredDocumentsStatistics", "Documents")';
    var IsDocumentBlocked = '@Url.Action("IsDocumentBlocked", "Documents")';
    var SignActionByDocIdForReferedDoc = '@Url.Action("SignActionByDocIdForReferedDoc", "Documents")';
    var IndexDocuments = '@Url.Action("Index", "Documents")';
    var GetOrganizationStatusUrl = '@Url.Action("GetOrganizationStatus", "Documents")';
    var DocumentDetailsByIdUrl = '@Url.Action("DocumentDetailsById", "Documents")';
    var GetDelegationbyorgidsuidUrl = '@Url.Action("GetDelegationbyorgidsuid", "Documents")';

    var GroupSigningStatus = '@Url.Action("GroupSigningStatus", "GroupSigning")';
    var PerformGroupSigning = '@Url.Action("PerformGroupSigning", "GroupSigning")';
    var documentsobjectslist = [];
    var previousDocNo = parseInt(localStorage.getItem("CurrentDocNo")) || 0;
    var previousTotalDocs = parseInt(localStorage.getItem("TotalDocs")) || 0;
    var updatedPageLength = 0;
    var updatedStart = 0;

    var scrollToDocNo = previousDocNo;
    var shimmer;


    var currentPage = 0;
    var pageSize = 5;
    var totalRecords = 0;

    var selectedFilterTab = localStorage.getItem("selectedFilterTab");
    var selectedDocumentDays = localStorage.getItem("selectedDocumentDays");
    var selectedDocumentCount = localStorage.getItem("selectedDocumentCount");
    var selectedDocumentStatus = localStorage.getItem("selectedDocumentStatus");
    var selectedSigningStatus = localStorage.getItem("selectedSigningStatus");
    var viewname = '@ViewBag.ViewName';
    var UserEmail = '@userEmail';
    var GroupSigningStatus = '@Url.Action("GroupSigningStatus", "GroupSigning")';
    var PerformGroupSigning = '@Url.Action("PerformGroupSigning", "GroupSigning")';
    var DocumentDetailsUrl = '@Url.Action("DocumentDetails", "Documents")';

    let initialLoading = true;
    let currentSentAjaxRequest = null;
    var activeTab = "";
    var initialFilterActiveTab = "";
    var initialFilterdaysVal = "";
    var initialFilterCountVal = "";
    var initialFilterDocumentStatusVal = "";
    var initialFilterSigningStatusVal = "";
    var documentFilterActiveTab = "timePeriod";
    var selectedIdListData = [];
    const currentYear = new Date().getFullYear();
    const container = document.getElementById('daysFilterSection');
    let isAllSelected = false; // Global flag


    const filterSelector = document.getElementById("filterSelector");
    const daysFilterSection = document.getElementById("daysFilterSection");
    const docsFilterSection = document.getElementById("docsFilterSection");
    let isDown = false;
    let startY;
    let scrollTop;

    const scrollArea = document.getElementById("referredCardsScrollArea");

    scrollArea.addEventListener("mousedown", (e) => {
        isDown = true;
        scrollArea.classList.add('active');
        startY = e.pageY - scrollArea.offsetTop;
        scrollTop = scrollArea.scrollTop;
    });

    scrollArea.addEventListener("mouseleave", () => {
        isDown = false;
    });

    scrollArea.addEventListener("mouseup", () => {
        isDown = false;
    });

    scrollArea.addEventListener("mousemove", (e) => {
        if (!isDown) return;
        e.preventDefault();
        const y = e.pageY - scrollArea.offsetTop;
        const walk = (y - startY) * 1; // Scroll speed multiplier
        scrollArea.scrollTop = scrollTop - walk;
    });

    $(document).ready(function () {
        /*  $('#DocumentMenu').addClass('active');
         $('#networkOverlay').hide(); */
        $('#referredCardsContainer').empty();

        localStorage.setItem("selectedFilterTab", "time");
        localStorage.setItem("selectedDocumentDays", "last90days");
        localStorage.setItem("selectedDocumentCount", "latest50");
        localStorage.setItem("selectedDocumentStatus", "All");
        localStorage.setItem("selectedSigningStatus", "All");
        $("#filterDataBtn").on("click", function (e) {
            FilterData();
        });
        $("#closeFilterIcon").on("click", function () {
            closefilter();
        });
        $("#selectAllCheckbox").on("change", function () {
            toggleSelectAll(this);
        });

        $("#toggleCheckboxesBtn").on("click", function () {
            toggleCheckboxes();
        });
        $("#applyFilterBtn").on("click", function () {
            applyfilter();
        });

        $("#resetFilterBtn").on("click", function () {
            ResetFilter();
        });
        $("#signSelectedBtn").on("click", function () {
            performGroupSigningAction();
        });
        getstatstics();
        loadReferredDocuments();



        // ===============================
        // SHOW MORE BUTTON
        // ===============================
        $('#showMoreBtnref').on('click', function () {
            currentPage++;
            $('#showMoreBtnref').hide();
            fetchDocuments();      // <-- Re-fetch directly, no DataTable reload
        });

        // ===============================
        // SEARCH
        // ===============================
        $('#searchButton').on('click', function () {
            const searchValue = $('#searchInput').val().trim();

            if (searchValue === "") {
                toastr.error('Please enter at least one character');
                return;
            }

            localStorage.setItem("DocumentsSearchValue", searchValue);
            currentPage = 0;

            $('#referredCardsContainer').empty();
            $('#allDocsLoadedMsgRef').hide();
            $('#noDataMessageref').hide();
            $('#showMoreBtnref').hide();


            loadReferredDocuments();   // <-- Direct fetch
        });

        // Show/hide clear button as user types
        $('#searchInput').on('input', function () {
            $('#searchClearBtn').toggle(this.value.length > 0);
        });

        // Enter key triggers search
        $('#searchInput').on('keypress', function (e) {
            if (e.key === 'Enter') { e.preventDefault(); $('#searchButton').trigger('click'); }
        });

        // Clear button: reset search and reload
        $('#searchClearBtn').on('click', function () {
            $('#searchInput').val('');
            $(this).hide();
            localStorage.removeItem("DocumentsSearchValue");
            currentPage = 0;
            $('#referredCardsContainer').empty();
            $('#allDocsLoadedMsgRef').hide();
            $('#noDataMessageref').hide();
            $('#showMoreBtnref').hide();
            loadReferredDocuments();
        });

        // ===============================
        // ACTION BUTTONS
        // ===============================

        $(document).on("click", ".redirect-doc", function () {
            const id = $(this).data("id");
            redirectToDocumentDetails(id);
        });

        $(document).on("click", ".toggle-row", function (event) {
            event.stopPropagation();
            toggleRowHighlight(this.querySelector('input'));
        });

        const actions = {
            signActionConfigByDocIdOnclick: (id, current, total) =>
                signActionConfigByDocIdOnclick(id, current, total),

            redirectToDocumentDetails: (id) =>
                redirectToDocumentDetails(id)
        };

        $(document).on("click", ".action-btn", function (event) {
            event.stopPropagation();

            const action = $(this).data("action");
            const id = $(this).data("id");
            const current = $(this).data("current");
            const total = $(this).data("total");

            if (actions[action]) {
                actions[action](id, current, total);
            }
        });

    });
    function toggleSelectAll(masterCheckbox) {
        const checked = masterCheckbox.checked;
        isAllSelected = checked;

        // Get only checkboxes inside visible containers
        const visibleContainers = Array.from(document.querySelectorAll('.checkboxContainer')).filter(container => {
            return container.offsetParent !== null; // visible on screen
        });

        let checkboxes = [];
        visibleContainers.forEach(container => {
            checkboxes.push(...container.querySelectorAll('.document-checkbox'));
        });

        checkboxes.forEach(checkbox => {
            const cardElement = checkbox.closest('.card');

            if (cardElement) {

                if (checkbox.disabled) {
                    checkbox.checked = false;
                    cardElement.classList.remove('card-selected');
                } else {
                    checkbox.checked = checked;
                    cardElement.classList.toggle('card-selected', checked);
                }
            }
        });

        updateSelectedIdList();
    }
    function toggleCheckboxes() {
        const containers = document.querySelectorAll('.checkboxContainer');
        const button = document.getElementById('toggleCheckboxesBtn');
        const icon = document.getElementById('checkboxToggleIcon');
        const signingButtonGroup = document.getElementById('signingButtonGroup');
        const showButtonGroup = document.getElementById('showButtonGroup');
        const anyVisible = Array.from(containers).some(container => container.style.display === 'block');

