                    localStorage.setItem("TotalDocs", totalDocs);
                    window.location.href = SignActionByDocIdForReferedDoc + '?docId=' + docId + '&viewName=' + viewName;
                }
            }
        } catch (error) {
            ajaxErrorHandler(error);
        }
