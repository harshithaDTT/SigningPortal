        let documentFilter = "";

        if (selectedTab === "time") {
            // Get Selected Value
            const daysInput = document.querySelector(`input[name="filterDays"][value="${selectedDocumentDays}"]`);
            const daysLabel = document.querySelector(`label[for="${daysInput?.id}"]`);
